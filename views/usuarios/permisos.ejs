              <div class="toggle-wrap">
                <% if (_bUS) { %>
                  <span class="blocked-badge"><i data-lucide="lock"></i> Bloqueado por rol</span>
                <% } else { %>
                  <span class="toggle-label-off" id="lbl-sec_usuarios_stats-off" style="<%= usuario.sec_usuarios_stats ? 'display:none' : '' %>">Oculto</span>
                  <span class="toggle-label-on"  id="lbl-sec_usuarios_stats-on"  style="<%= usuario.sec_usuarios_stats ? '' : 'display:none' %>">Visible</span>
                <% } %>
                <label class="toggle">
                  <input type="checkbox" name="sec_usuarios_stats" value="1"
                    <%= _bUS ? 'disabled' : "onchange=\"syncLabel(this,'sec_usuarios_stats')\"" %>
                    <%= !_bUS && usuario.sec_usuarios_stats ? 'checked' : '' %>>
                  <span class="toggle-slider"></span>
                </label>
              </div>
            </div>

            <% const _bUF = blq('sec_usuarios_filtros'); %>
            <div class="perm-row <%= _bUF ? 'bloqueado' : '' %>">
              <div class="perm-label">
                <i data-lucide="list-filter"></i>
                <div>
                  <div class="perm-label-text">Pestañas de filtro por rol</div>
                  <div class="perm-label-desc"><%= _bUF ? _bUF : 'Todos, Admins, Superusuarios, Operadores, Clientes' %></div>
                </div>
              </div>
              <div class="toggle-wrap">
                <% if (_bUF) { %>
                  <span class="blocked-badge"><i data-lucide="lock"></i> Bloqueado por rol</span>
                <% } else { %>
                  <span class="toggle-label-off" id="lbl-sec_usuarios_filtros-off" style="<%= usuario.sec_usuarios_filtros ? 'display:none' : '' %>">Oculto</span>
                  <span class="toggle-label-on"  id="lbl-sec_usuarios_filtros-on"  style="<%= usuario.sec_usuarios_filtros ? '' : 'display:none' %>">Visible</span>
                <% } %>
                <label class="toggle">
                  <input type="checkbox" name="sec_usuarios_filtros" value="1"
                    <%= _bUF ? 'disabled' : "onchange=\"syncLabel(this,'sec_usuarios_filtros')\"" %>
                    <%= !_bUF && usuario.sec_usuarios_filtros ? 'checked' : '' %>>
                  <span class="toggle-slider"></span>
                </label>
              </div>
            </div>

            <% const _bUN = blq('sec_usuarios_nuevo'); %>
            <div class="perm-row <%= _bUN ? 'bloqueado' : '' %>">
              <div class="perm-label">
                <i data-lucide="plus-circle"></i>
                <div>
                  <div class="perm-label-text">Botón "Nuevo Usuario"</div>
                  <div class="perm-label-desc"><%= _bUN ? _bUN : 'Acceso para registrar nuevos usuarios' %></div>
                </div>
              </div>
              <div class="toggle-wrap">
                <% if (_bUN) { %>
                  <span class="blocked-badge"><i data-lucide="lock"></i> Bloqueado por rol</span>
                <% } else { %>
                  <span class="toggle-label-off" id="lbl-sec_usuarios_nuevo-off" style="<%= usuario.sec_usuarios_nuevo ? 'display:none' : '' %>">Oculto</span>
                  <span class="toggle-label-on"  id="lbl-sec_usuarios_nuevo-on"  style="<%= usuario.sec_usuarios_nuevo ? '' : 'display:none' %>">Visible</span>
                <% } %>
                <label class="toggle">
                  <input type="checkbox" name="sec_usuarios_nuevo" value="1"
                    <%= _bUN ? 'disabled' : "onchange=\"syncLabel(this,'sec_usuarios_nuevo')\"" %>
                    <%= !_bUN && usuario.sec_usuarios_nuevo ? 'checked' : '' %>>
                  <span class="toggle-slider"></span>
                </label>
              </div>
            </div>

          </div>
        </div>

        <!-- SECCIONES: ENVÍOS RETRASADOS -->
        <div class="perms-card">
          <div class="perms-card-header">
            <div class="header-icon" style="background:#fee2e2;color:#dc2626;"><i data-lucide="alert-triangle"></i></div>
            <div>
              <h3>Página: Envíos Retrasados</h3>
              <p>Secciones visibles dentro de la página de retrasados</p>
            </div>
          </div>
          <div class="perms-list">

            <div class="perm-row">
              <div class="perm-label">
                <i data-lucide="credit-card"></i>
                <div>
                  <div class="perm-label-text">Tarjetas de criticidad</div>
                  <div class="perm-label-desc">Total, críticos, altos y medios + barra de distribución</div>
                </div>
              </div>
              <div class="toggle-wrap">
                <span class="toggle-label-off" id="lbl-sec_retrasados_stats-off" style="<%= usuario.sec_retrasados_stats ? 'display:none' : '' %>">Oculto</span>
                <span class="toggle-label-on"  id="lbl-sec_retrasados_stats-on"  style="<%= usuario.sec_retrasados_stats ? '' : 'display:none' %>">Visible</span>
                <label class="toggle">
                  <input type="checkbox" name="sec_retrasados_stats" value="1" onchange="syncLabel(this,'sec_retrasados_stats')" <%= usuario.sec_retrasados_stats ? 'checked' : '' %>>
                  <span class="toggle-slider"></span>
                </label>
              </div>
            </div>

            <div class="perm-row">
              <div class="perm-label">
                <i data-lucide="list-filter"></i>
                <div>
                  <div class="perm-label-text">Pestañas de criticidad</div>
                  <div class="perm-label-desc">Todos, Críticos, Altos, Medios</div>
                </div>
              </div>
              <div class="toggle-wrap">
                <span class="toggle-label-off" id="lbl-sec_retrasados_filtros-off" style="<%= usuario.sec_retrasados_filtros ? 'display:none' : '' %>">Oculto</span>
                <span class="toggle-label-on"  id="lbl-sec_retrasados_filtros-on"  style="<%= usuario.sec_retrasados_filtros ? '' : 'display:none' %>">Visible</span>
                <label class="toggle">
                  <input type="checkbox" name="sec_retrasados_filtros" value="1" onchange="syncLabel(this,'sec_retrasados_filtros')" <%= usuario.sec_retrasados_filtros ? 'checked' : '' %>>
                  <span class="toggle-slider"></span>
                </label>
              </div>
            </div>

          </div>
        </div>

        <!-- ACTIONS -->
        <div class="form-actions">
          <a href="/usuarios/<%= usuario.id %>" class="btn-back">
            <i data-lucide="arrow-left"></i>
            Volver al usuario
          </a>
          <button type="submit" class="btn-save">
            <i data-lucide="save"></i>
            Guardar permisos
          </button>
        </div>

      </form>
      </div><!-- /perms-content -->

    </main>
  </div>

  <script>
    lucide.createIcons();

    function syncLabel(input, campo) {
      document.getElementById('lbl-' + campo + '-on').style.display  = input.checked ? '' : 'none';
      document.getElementById('lbl-' + campo + '-off').style.display = input.checked ? 'none' : '';
    }

    const userProfileBtn = document.getElementById('userProfileBtn');
    const userDropdown   = document.getElementById('userDropdown');
    if (userProfileBtn && userDropdown) {
      userProfileBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        userDropdown.classList.toggle('show');
        lucide.createIcons();
      });
      document.addEventListener('click', function(e) {
        if (!userProfileBtn.contains(e.target)) userDropdown.classList.remove('show');
      });
    }
  </script>
  <script>window._userMenu=<%- locals.userMenuJson||"null" %>;</script>
  <script src="/js/sidebar.js"></script>
</body>
</html>
