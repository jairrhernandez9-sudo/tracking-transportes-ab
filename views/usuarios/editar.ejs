          </div><!-- /tab-info -->

          <!-- TAB: Permisos de Vista -->
          <% if (['admin','superusuario'].includes(user.rol) && usuario.rol !== 'cliente') { %>
          <div id="tab-permisos" class="tab-panel">

            <div class="permisos-section">
              <div class="permisos-section-title">Detalle del Envío</div>

              <div class="permiso-row">
                <div class="permiso-row-info">
                  <span class="permiso-label">Botones de acción</span>
                  <span class="permiso-desc">Guía Expedida y Editar</span>
                </div>
                <label class="switch">
                  <input type="checkbox" name="ver_botones_detalle" value="1" <%= (usuario.ver_botones_detalle !== 0) ? 'checked' : '' %>>
