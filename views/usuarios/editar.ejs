                </label>
              </div>

              <div class="permiso-row">
                <div class="permiso-row-info">
                  <span class="permiso-label">Teléfono</span>
                  <span class="permiso-desc">Campo teléfono del cliente en el envío</span>
                </div>
                <label class="switch">
                  <input type="checkbox" name="ver_telefono_detalle" value="1" <%= (usuario.ver_telefono_detalle !== 0) ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>

              <div class="permiso-row">
                <div class="permiso-row-info">
                  <span class="permiso-label">Contacto y Email</span>
                  <span class="permiso-desc">Nombre de contacto y correo electrónico</span>
                </div>
                <label class="switch">
                  <input type="checkbox" name="ver_contacto_detalle" value="1" <%= (usuario.ver_contacto_detalle !== 0) ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>

              <div class="permiso-row">
                <div class="permiso-row-info">
                  <span class="permiso-label">Editado por</span>
                  <span class="permiso-desc">Nombre del usuario que editó el envío</span>
                </div>
                <label class="switch">
                  <input type="checkbox" name="ver_editado_por_detalle" value="1" <%= (usuario.ver_editado_por_detalle !== 0) ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>

              <div class="permiso-row">
                <div class="permiso-row-info">
                  <span class="permiso-label">Actualizado por</span>
                  <span class="permiso-desc">Usuario que registró el último cambio de estado</span>
                </div>
                <label class="switch">
                  <input type="checkbox" name="ver_actualizado_por_detalle" value="1" <%= (usuario.ver_actualizado_por_detalle !== 0) ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>

              <div class="permiso-row">
                <div class="permiso-row-info">
                  <span class="permiso-label">Impreso desde Portal</span>
                  <span class="permiso-desc">Usuarios del portal que han impreso documentos de este envío</span>
                </div>
                <label class="switch">
                  <input type="checkbox" name="ver_reimp_por_detalle" value="1" <%= (usuario.ver_reimp_por_detalle !== 0) ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>

            </div>

            <div class="permisos-section">
              <div class="permisos-section-title">Paneles laterales</div>

