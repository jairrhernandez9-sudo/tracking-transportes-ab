  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    lucide.createIcons();
    actualizarLabelSuc();

    function switchTab(tabId, btn) {
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.edit-tab').forEach(b => b.classList.remove('active'));
      document.getElementById(tabId).classList.add('active');
      btn.classList.add('active');
    }

    function toggleSubpermiso(subId, visible) {
      document.getElementById(subId).style.display = visible ? '' : 'none';
    }

    // ── Búsqueda global ──────────────────────────────────
    (function() {
      var si = document.getElementById('searchInput');
      if (!si) return;
      var t;
      si.addEventListener('input', function() {
        clearTimeout(t);
        var v = this.value.trim();
        if (v) t = setTimeout(function() {
          window.location.href = '/envios?buscar=' + encodeURIComponent(v);
        }, 500);
      });
      si.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && this.value.trim()) {
          clearTimeout(t);
          window.location.href = '/envios?buscar=' + encodeURIComponent(this.value.trim());
        }
      });
    })();

    // User Profile Dropdown
    const userProfileBtn = document.getElementById('userProfileBtn');
    const userDropdown = document.getElementById('userDropdown');
    
    if (userProfileBtn && userDropdown) {
      userProfileBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        userProfileBtn.classList.toggle('open');
        userDropdown.classList.toggle('show');
        lucide.createIcons();
      });
      
      document.addEventListener('click', function(e) {
        if (!userProfileBtn.contains(e.target)) {
          userProfileBtn.classList.remove('open');
          userDropdown.classList.remove('show');
        }
      });
      
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          userProfileBtn.classList.remove('open');
          userDropdown.classList.remove('show');
        }
      });
    }
  </script>

  
<script>
  // ============================================
  // FUNCIÓN: Mostrar/Ocultar Contraseña
  // ============================================
  function togglePassword(inputId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(`icon-${inputId}`);
    
    if (!input || !icon) {
      console.error('No se encontró el input o icono:', inputId);
      return;
    }
    
    if (input.type === 'password') {
      // Mostrar contraseña
      input.type = 'text';
      icon.setAttribute('data-lucide', 'eye-off');
    } else {
      // Ocultar contraseña
      input.type = 'password';
      icon.setAttribute('data-lucide', 'eye');
    }
    
    // Recrear iconos de Lucide para actualizar el icono
    lucide.createIcons();
  }

  // ============================================
  // VALIDACIÓN: Contraseñas coinciden (OPCIONAL)
  // ============================================
  document.addEventListener('DOMContentLoaded', function() {
    const passwordNueva = document.getElementById('passwordNueva');
    const passwordConfirmar = document.getElementById('passwordConfirmar');
    
    if (passwordNueva && passwordConfirmar) {
      function checkPasswordMatch() {
        const nueva = passwordNueva.value;
        const confirmar = passwordConfirmar.value;
        
        // Solo validar si ambos tienen contenido
        if (nueva.length > 0 && confirmar.length > 0) {
          if (nueva !== confirmar) {
            // No coinciden - borde rojo
            passwordConfirmar.style.borderColor = '#ef4444';
            passwordConfirmar.style.borderWidth = '2px';
          } else {
            // Coinciden - borde verde
            passwordConfirmar.style.borderColor = '#10b981';
            passwordConfirmar.style.borderWidth = '2px';
          }
        } else {
          // Vacíos - borde normal
          passwordConfirmar.style.borderColor = '#e2e8f0';
          passwordConfirmar.style.borderWidth = '2px';
        }
      }
      
      // Ejecutar validación cuando el usuario escribe
      passwordNueva.addEventListener('input', checkPasswordMatch);
      passwordConfirmar.addEventListener('input', checkPasswordMatch);
    }
    
    // Inicializar iconos de Lucide
    lucide.createIcons();
  });
</script>


<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('form');
  const password1 = document.getElementById('passwordNueva');
  const password2 = document.getElementById('passwordConfirmar');
  
  // Deshabilitar confirmar contraseña si no hay contraseña nueva
  password1.addEventListener('input', function() {
    if (!this.value) {
      password2.value = '';
      password2.disabled = true;
      password2.placeholder = 'Primero ingresa una nueva contraseña';
    } else {
      password2.disabled = false;
      password2.placeholder = 'Repite la nueva contraseña';
    }
  });
  
  // Validar al enviar el formulario
  form.addEventListener('submit', function(e) {
    const pass1 = password1.value;
    const pass2 = password2.value;
    
    // Si se llenó una pero no la otra
    if ((pass1 && !pass2) || (!pass1 && pass2)) {
      e.preventDefault();
      alert('Si deseas cambiar la contraseña, debes completar ambos campos.\n\nSi no deseas cambiarla, deja ambos campos vacíos.');
      return false;
    }
    
    // Si ambas tienen valor pero no coinciden
    if (pass1 && pass2 && pass1 !== pass2) {
      e.preventDefault();
      alert('Las contraseñas no coinciden. Por favor verifica e intenta nuevamente.');
      return false;
    }
    
    // Si ambas están vacías, mostrar confirmación
    if (!pass1 && !pass2) {
      // No mostrar confirmación, esto es correcto
      return true;
    }
  });
});
</script>
  <script src="/js/notifications.js"></script>
