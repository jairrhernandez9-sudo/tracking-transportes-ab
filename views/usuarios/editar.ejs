              <label class="form-label">
                <i data-lucide="shield"></i>
                Rol <span class="required">*</span>
              </label>
              <select name="rol" class="form-select" required id="rolSelectEditar" onchange="toggleClienteFieldEditar()">
                <option value="superusuario" <%= usuario.rol === 'superusuario' ? 'selected' : '' %>>⚡ Superusuario</option>
                <option value="admin"        <%= usuario.rol === 'admin'        ? 'selected' : '' %>>🔑 Administrador</option>
                <option value="operador"     <%= usuario.rol === 'operador'     ? 'selected' : '' %>>🛠️ Operador</option>
                <option value="cliente"      <%= usuario.rol === 'cliente'      ? 'selected' : '' %>>🏢 Cliente</option>
              </select>
            </div>

            <!-- Selector de cliente (solo rol=cliente) -->
            <div class="form-group" id="clienteSelectorEditar" <% if (usuario.rol !== 'cliente') { %>style="display:none"<% } %>>
              <label class="form-label">
                <i data-lucide="building-2"></i>
                Cliente vinculado <span class="required">*</span>
              </label>
              <select name="cliente_id" class="form-select" id="clienteIdEditar" onchange="cargarSucursalesEditar(this.value)">
                <option value="">Selecciona un cliente...</option>
                <% if (typeof clientes !== 'undefined') { clientes.forEach(cl => { %>
                  <option value="<%= cl.id %>" <%= usuario.cliente_id == cl.id ? 'selected' : '' %>>
                    <%= cl.nombre_empresa %>
                  </option>
                <% }); } %>
              </select>
              <p class="form-help">Este usuario solo verá los envíos de este cliente</p>
            </div>

            <!-- Selector de sucursal (solo rol=cliente, si el cliente tiene direcciones) -->
            <div class="form-group" id="sucursalSelectorEditar" <% if (usuario.rol !== 'cliente' || !sucursales || !sucursales.length) { %>style="display:none"<% } %>>
