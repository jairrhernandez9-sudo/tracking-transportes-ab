<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Transportes AB</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    var _sucursalesActuales = <%- JSON.stringify(sucursalesAsignadasIds || []) %>;

    function toggleClienteFieldEditar() {
      const rol = document.getElementById('rolSelectEditar').value;
      const div = document.getElementById('clienteSelectorEditar');
      const sel = document.getElementById('clienteIdEditar');
      const divSuc = document.getElementById('sucursalSelectorEditar');
      div.style.display = rol === 'cliente' ? '' : 'none';
      sel.required = rol === 'cliente';
      if (rol !== 'cliente') {
        divSuc.style.display = 'none';
        document.getElementById('sucursalDirIdEditar').value = '';
      }
    }

    function toggleSucDropdown() {
      const trigger = document.getElementById('sucTrigger');
      const menu = document.getElementById('sucursalPillsEditar');
      trigger.classList.toggle('open');
      menu.classList.toggle('open');
    }

    function actualizarLabelSuc() {
      const checks = document.querySelectorAll('#sucursalPillsEditar input[type="checkbox"]:checked');
      const label = document.getElementById('sucTriggerLabel');
      document.querySelectorAll('#sucursalPillsEditar .suc-item').forEach(function(item) {
        item.classList.toggle('checked', item.querySelector('input').checked);
      });
      if (checks.length === 0) {
        label.textContent = 'Todas las sucursales';
      } else if (checks.length === 1) {
        label.textContent = checks[0].closest('.suc-item').textContent.trim();
      } else {
        label.textContent = checks.length + ' sucursales seleccionadas';
      }
    }

    function cargarSucursalesEditar(clienteId, mantenerActual) {
      const divSuc = document.getElementById('sucursalSelectorEditar');
      const menu = document.getElementById('sucursalPillsEditar');
      const trigger = document.getElementById('sucTrigger');
      menu.innerHTML = '';
      trigger.classList.remove('open');
      menu.classList.remove('open');
      if (!mantenerActual) _sucursalesActuales = [];
      if (!clienteId) { divSuc.style.display = 'none'; return; }
      fetch('/usuarios/api/cliente/' + clienteId + '/sucursales')
        .then(r => r.json())
        .then(function(rows) {
          if (!rows.length) { divSuc.style.display = 'none'; return; }
          rows.forEach(function(s) {
            const checked = _sucursalesActuales.indexOf(s.id) !== -1;
            const lbl = document.createElement('label');
            lbl.className = 'suc-item' + (checked ? ' checked' : '');
            const cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.name = 'sucursal_ids[]';
            cb.value = s.id;
            cb.checked = checked;
            cb.setAttribute('onchange', 'actualizarLabelSuc()');
            lbl.appendChild(cb);
            lbl.appendChild(document.createTextNode(' ' + s.alias + (s.ciudad ? ' — ' + s.ciudad : '')));
            menu.appendChild(lbl);
          });
          divSuc.style.display = '';
          actualizarLabelSuc();
        });
    }

    // Cerrar dropdown al hacer click fuera
    document.addEventListener('click', function(e) {
      const drop = document.getElementById('sucursalSelectorDropdown');
      if (drop && !drop.contains(e.target)) {
        document.getElementById('sucTrigger').classList.remove('open');
        document.getElementById('sucursalPillsEditar').classList.remove('open');
      }
    });
  </script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', sans-serif;
      background: #f8f9fa;
      min-height: 100vh;
    }
    
    .page-wrapper {
      display: flex;
      min-height: 100vh;
    }
    
    /* SIDEBAR */
