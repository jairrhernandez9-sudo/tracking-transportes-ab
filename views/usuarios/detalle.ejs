<body>
  
  <div class="page-wrapper">
    
    <!-- SIDEBAR -->
    <aside class="sidebar">
<div class="logo">
  <div class="logo-icon-image">
    <img src="/images/logo-transportes-ab.png" alt="Logo">
  </div>
  <div class="logo-info">
    <span class="logo-text">Transportes AB</span>
    <span class="logo-tagline">Sistema Tracking</span>
  </div>
</div>
      
      <div class="nav-section">
        <div class="nav-section-title">PRINCIPAL</div>
        <ul class="nav-menu">
          <% if (!user || user.rol !== 'operador') { %>
          <li class="nav-item">
            <a href="/dashboard" class="nav-link">
              <i data-lucide="layout-dashboard"></i>
              <span>Dashboard</span>
            </a>
          </li>
          <% } %>
          <li class="nav-item">
            <a href="/envios" class="nav-link">
              <i data-lucide="package"></i>
              <span>Envíos</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/envios-retrasados" class="nav-link">
              <i data-lucide="alert-triangle"></i>
              <span>Envíos Retrasados</span>
            </a>
          </li>
        </ul>
      </div>
      
      <div class="nav-section">
        <div class="nav-section-title">GESTIÓN</div>
        <ul class="nav-menu">
          <li class="nav-item">
            <a href="/clientes" class="nav-link">
              <i data-lucide="users"></i>
              <span>Clientes</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/reportes" class="nav-link">
              <i data-lucide="bar-chart"></i>
              <span>Reportes</span>
            </a>
          </li>
        </ul>
      </div>
      
      <div class="nav-section">
        <div class="nav-section-title">SISTEMA</div>
        <ul class="nav-menu">
          <li class="nav-item">
            <a href="/usuarios" class="nav-link active">
              <i data-lucide="user-cog"></i>
              <span>Usuarios</span>
            </a>
          </li>
          <li class="nav-item">
            <a href="/configuracion" class="nav-link">
              <i data-lucide="settings"></i>
              <span>Configuración</span>
            </a>
          </li>
          <% if (user && user.email === 'jose.cordoba@transportesab.com') { %>
          <li class="nav-item">
            <a href="/historial/actividad" class="nav-link">
              <i data-lucide="activity"></i>
              <span>Historial</span>
            </a>
          </li>
          <% } %>
        </ul>
      </div>
    </aside>
    
   <!-- MAIN CONTENT -->
    <main class="main-content">
      
      <!-- Page Header -->
      <div class="page-header">
        <div>
          <h1 class="page-title">Detalle del Usuario</h1>
          <nav class="breadcrumb">
            <a href="/dashboard">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/usuarios">Usuarios</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current"><%= usuario.nombre %></span>
          </nav>
        </div>
        <div class="page-actions">
          <a href="/usuarios" class="btn-secondary">
            <i data-lucide="arrow-left"></i>
            Volver
          </a>
        </div>
      </div>
      
      <!-- PROFILE CARD -->
      <div class="profile-card">
        
        <!-- Header con Avatar y Info Principal -->
        <div class="profile-header">
          <div class="profile-avatar-large">
            <%= usuario.nombre.charAt(0).toUpperCase() %>
          </div>
          <div class="profile-main-info">
            <h2 class="profile-name"><%= usuario.nombre %></h2>
            <p class="profile-email"><%= usuario.email %></p>
            <div class="profile-badges">
              <%
                const _badgeClass = { admin:'badge-admin', superusuario:'badge-superusuario', operador:'badge-operador', cliente:'badge-cliente' };
                const _badgeIcon  = { admin:'shield', superusuario:'shield-check', operador:'user', cliente:'building-2' };
                const _badgeLabel = { admin:'Administrador', superusuario:'Superusuario', operador:'Operador', cliente:'Cliente' };
              %>
              <span class="profile-badge <%= _badgeClass[usuario.rol] || 'badge-operador' %>">
                <i data-lucide="<%= _badgeIcon[usuario.rol] || 'user' %>"></i>
                <%= _badgeLabel[usuario.rol] || usuario.rol %>
              </span>
              <span class="profile-badge <%= usuario.activo ? 'badge-activo' : 'badge-inactivo' %>">
                <i data-lucide="<%= usuario.activo ? 'check-circle' : 'x-circle' %>"></i>
                <%= usuario.activo ? 'Activo' : 'Inactivo' %>
              </span>
            </div>
          </div>
        </div>
        
        <!-- Grid de Información Básica -->
        <div class="info-section">
          <h3 class="section-title">
            <i data-lucide="user" style="width: 20px; height: 20px;"></i>
            Información Personal
          </h3>
          <div class="info-grid">
            
            <!-- ID de Usuario -->
            <div class="info-item">
              <div class="info-label">
                <i data-lucide="hash"></i>
                ID de Usuario
              </div>
              <div class="info-value">#<%= usuario.id %></div>
            </div>
            
            <!-- Nombre Completo -->
            <div class="info-item">
              <div class="info-label">
                <i data-lucide="user"></i>
                Nombre Completo
              </div>
              <div class="info-value"><%= usuario.nombre %></div>
            </div>
            
            <!-- Correo Electrónico -->
            <div class="info-item">
              <div class="info-label">
                <i data-lucide="mail"></i>
                Correo Electrónico
              </div>
              <div class="info-value" style="font-size: 0.95rem; word-break: break-all;">
                <%= usuario.email %>
              </div>
            </div>
            
            <!-- Rol / Nivel de Acceso -->
            <div class="info-item">
              <div class="info-label">
                <i data-lucide="shield-check"></i>
                Rol / Nivel de Acceso
              </div>
              <div class="info-value">
                <%
                  const _rolDesc = { admin:'Administrador Total', superusuario:'Superusuario', operador:'Operador Limitado', cliente:'Cliente' };
                %>
                <%= _rolDesc[usuario.rol] || usuario.rol %>
              </div>
            </div>
            
            <!-- Estado de la Cuenta -->
            <div class="info-item">
              <div class="info-label">
                <i data-lucide="<%= usuario.activo ? 'check-circle-2' : 'x-circle' %>"></i>
                Estado de la Cuenta
              </div>
              <div class="info-value">
                <span class="<%= usuario.activo ? 'text-success' : 'text-danger' %>">
                  <%= usuario.activo ? 'Cuenta Activa - Puede iniciar sesión' : 'Cuenta Deshabilitada - No puede iniciar sesión' %>
                </span>
              </div>
            </div>
            
            <!-- Fecha de Registro -->
            <div class="info-item">
              <div class="info-label">
                <i data-lucide="calendar"></i>
                Fecha de Registro
              </div>
              <div class="info-value">
                <%= new Date(usuario.fecha_creacion).toLocaleDateString('es-MX', {
                  day: '2-digit',
                  month: 'long',
                  year: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit',
                  timeZone: 'America/Mexico_City'
                }) %>
              </div>
            </div>
            
            <!-- Antigüedad -->
            <div class="info-item">
              <div class="info-label">
                <i data-lucide="clock"></i>
                Antigüedad en el Sistema
              </div>
              <div class="info-value">
                <% 
                  const fechaRegistro = new Date(usuario.fecha_creacion);
                  const hoy = new Date();
                  const diasDesdeRegistro = Math.floor((hoy - fechaRegistro) / (1000 * 60 * 60 * 24));
                  const mesesDesdeRegistro = Math.floor(diasDesdeRegistro / 30);
                  const anosDesdeRegistro = Math.floor(diasDesdeRegistro / 365);
                %>
                
                <% if (anosDesdeRegistro > 0) { %>
                  <%= anosDesdeRegistro %> <%= anosDesdeRegistro === 1 ? 'año' : 'años' %>
                  <% const mesesRestantes = Math.floor((diasDesdeRegistro % 365) / 30); %>
                  <% if (mesesRestantes > 0) { %>
                    y <%= mesesRestantes %> <%= mesesRestantes === 1 ? 'mes' : 'meses' %>
                  <% } %>
                <% } else if (mesesDesdeRegistro > 0) { %>
                  <%= mesesDesdeRegistro %> <%= mesesDesdeRegistro === 1 ? 'mes' : 'meses' %>
                <% } else { %>
                  <%= diasDesdeRegistro %> <%= diasDesdeRegistro === 1 ? 'día' : 'días' %>
                <% } %>
              </div>
            </div>
            
            <!-- Última Modificación -->
            <div class="info-item">
              <div class="info-label">
                <i data-lucide="edit-3"></i>
                Última Modificación
              </div>
              <div class="info-value">
                <% if (usuario.fecha_modificacion) { %>
                  <%= new Date(usuario.fecha_modificacion).toLocaleDateString('es-MX', {
                    day: '2-digit',
                    month: 'short',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                    timeZone: 'America/Mexico_City'
                  }) %>
                <% } else { %>
                  Sin modificaciones
                <% } %>
              </div>
            </div>
            
          </div>
        </div>
        
        <!-- Sección de Permisos -->
        <div class="info-section">
          <h3 class="section-title">
            <i data-lucide="key" style="width: 20px; height: 20px;"></i>
            Permisos y Accesos
          </h3>
          <div class="permissions-grid">
            
            <% if (usuario.rol === 'admin' || usuario.rol === 'superusuario') { %>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Acceso Total al Sistema</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Gestionar Usuarios</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Modificar Configuración</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Eliminar Envíos</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Ver Reportes Financieros</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Gestionar Clientes</span></div>

            <% } else if (usuario.rol === 'operador') { %>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Ver Envíos</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Crear Envíos</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Ver Clientes</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Agregar Estados al Historial</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Ver Reportes Básicos</span></div>
              <div class="permission-item denied"><i data-lucide="x-circle"></i><span>Eliminar Envíos (No permitido)</span></div>
              <div class="permission-item denied"><i data-lucide="x-circle"></i><span>Gestionar Usuarios (No permitido)</span></div>
              <div class="permission-item denied"><i data-lucide="x-circle"></i><span>Modificar Configuración (No permitido)</span></div>

            <% } else if (usuario.rol === 'cliente') { %>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Ver sus propios envíos</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Buscar por tracking o referencia</span></div>
              <div class="permission-item allowed"><i data-lucide="check-circle"></i><span>Ver historial de estados</span></div>
              <div class="permission-item denied"><i data-lucide="x-circle"></i><span>Ver envíos de otros clientes (No permitido)</span></div>
              <div class="permission-item denied"><i data-lucide="x-circle"></i><span>Crear o editar envíos (No permitido)</span></div>
              <div class="permission-item denied"><i data-lucide="x-circle"></i><span>Acceso a configuración (No permitido)</span></div>
            <% } %>
            
          </div>
        </div>
        
        <!-- Estadísticas de Actividad -->
        <div class="stats-section">
          <h3 class="stats-title">
            <i data-lucide="bar-chart-2" style="width: 20px; height: 20px;"></i>
            Estadísticas de Actividad
          </h3>
          <div class="stats-grid">
            
            <div class="stat-box">
              <div class="stat-icon" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);">
                <i data-lucide="package"></i>
              </div>
              <div class="stat-info">
                <div class="stat-label">Envíos Creados</div>
                <div class="stat-value"><%= totalEnvios || 0 %></div>
              </div>
            </div>
            
            <div class="stat-box">
              <div class="stat-icon" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                <i data-lucide="calendar-days"></i>
              </div>
              <div class="stat-info">
                <div class="stat-label">Días en el Sistema</div>
                <div class="stat-value"><%= Math.floor((new Date() - new Date(usuario.fecha_creacion)) / (1000 * 60 * 60 * 24)) %></div>
              </div>
            </div>
            
            <div class="stat-box">
              <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                <i data-lucide="clock"></i>
              </div>
              <div class="stat-info">
                <div class="stat-label">Última Sesión</div>
                <div class="stat-value" style="font-size: 0.9rem;">
                  <% if (usuario.ultima_sesion) { %>
                    <%= new Date(usuario.ultima_sesion).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', timeZone: 'America/Mexico_City' }) %>
                  <% } else { %>
                    N/A
                  <% } %>
                </div>
              </div>
            </div>
            
            <div class="stat-box">
              <div class="stat-icon" style="background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);">
                <i data-lucide="activity"></i>
              </div>
              <div class="stat-info">
                <div class="stat-label">Estado Actual</div>
                <div class="stat-value" style="font-size: 0.9rem;">
                  <%= usuario.activo ? 'Activo' : 'Inactivo' %>
                </div>
              </div>
            </div>
            
          </div>
        </div>
        
        <!-- Botones de Acción -->
        <div class="actions-section">
          <a href="/usuarios/<%= usuario.id %>/editar" class="btn btn-edit">
            <i data-lucide="edit"></i>
            Editar Usuario
          </a>
          
          <% if (usuario.id !== user.id) { %>
            <button 
              class="btn btn-delete" 
              data-user-id="<%= usuario.id %>" 
              data-user-name="<%= usuario.nombre %>" 
              onclick="confirmarEliminar(this)"
            >
              <i data-lucide="trash-2"></i>
              Eliminar Usuario
            </button>
          <% } else { %>
            <div class="alert-info">
              <i data-lucide="info"></i>
              No puedes eliminar tu propia cuenta
            </div>
          <% } %>
        </div>
        
      </div>
      
    </main>
    
  </div>
  
  <script>
    lucide.createIcons();
    
    // User Profile Dropdown
    const userProfileBtn = document.getElementById('userProfileBtn');
    const userDropdown = document.getElementById('userDropdown');
    
    if (userProfileBtn && userDropdown) {
      userProfileBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        userProfileBtn.classList.toggle('open');
        userDropdown.classList.toggle('show');
        lucide.createIcons();
      });
      
      document.addEventListener('click', function(e) {
        if (!userProfileBtn.contains(e.target)) {
          userProfileBtn.classList.remove('open');
          userDropdown.classList.remove('show');
        }
      });
      
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          userProfileBtn.classList.remove('open');
          userDropdown.classList.remove('show');
        }
      });
    }
    
    // Delete confirmation
    function confirmarEliminar(button) {
      const id = button.getAttribute('data-user-id');
      const nombre = button.getAttribute('data-user-name');
      
      if (confirm(`¿Estás seguro de eliminar al usuario "${nombre}"?\n\nEsta acción no se puede deshacer.`)) {
        // Crear formulario y enviar
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/usuarios/${id}/eliminar`;
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
  <script src="/js/notifications.js"></script>
  <script src="/js/sidebar.js"></script>
</body>
</html>