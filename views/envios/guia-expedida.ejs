<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Guía <%= envio.numero_tracking %></title>
  <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8pt;
      background: #d1d5db;
      color: #000;
      overflow: hidden;
    }

    /* ── Barra de acciones (solo pantalla) ── */
    .toolbar {
      background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #2563eb 100%);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      height: 56px;
      z-index: 200;
      position: relative;
    }
    .toolbar-left { display: flex; align-items: center; gap: 10px; }
    .toolbar-title { color: #fff; font-size: 14px; font-weight: 700; }
    .toolbar-tracking { color: rgba(255,255,255,0.6); font-size: 12px; margin-left: 4px; }
    .btn-back {
      display: flex; align-items: center; gap: 6px;
      padding: 8px 16px;
      background: rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.85);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 8px;
      font-size: 12px; font-weight: 600;
      text-decoration: none; cursor: pointer;
      transition: all .2s;
    }
    .btn-back:hover { background: rgba(255,255,255,0.2); color: #fff; }
    .btn-print {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 22px;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 13px; font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(37,99,235,.4);
      transition: all .2s;
    }
    .btn-print:hover { background: #1d4ed8; transform: translateY(-1px); }

    /* ── Layout ── */
    .page-layout {
      display: flex;
      height: calc(100vh - 56px);
    }
    .guia-area {
      flex: 1;
      overflow: auto;
      background: #d1d5db;
      cursor: grab;
      user-select: none;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .guia-area.panning { cursor: grabbing; }

    #guia-canvas { display: inline-block; flex-shrink: 0; }

    /* ── Página carta ── */
    .page {
      width: 215.9mm;
      min-height: 279.4mm;
      background: white;
      margin: 20px auto;
      padding: 5mm 6mm;
      box-shadow: 0 4px 30px rgba(0,0,0,0.25);
    }

    /* ── Tabla base ── */
    table { border-collapse: collapse; width: 100%; }
    td, th { border: 1px solid #000; padding: 2px 4px; vertical-align: top; }

    /* ── Cabecera ── */
    .cell-logo  { width: 24%; vertical-align: middle; padding: 4px 6px; text-align: center; }
    .cell-title { width: 50%; text-align: center; vertical-align: middle; padding: 4px 6px; }
    .cell-barcode { width: 26%; text-align: center; vertical-align: middle; padding: 4px 6px; }

    .logo-img { max-height: 44px; max-width: 110px; object-fit: contain; display: block; margin: 0 auto; }
    .company-name { font-size: 9pt; font-weight: bold; margin-top: 2px; }
    .company-rfc  { font-size: 7pt; color: #333; margin-top: 1px; }

    .guia-servicio { font-size: 8pt; color: #333; }
    .guia-titulo   { font-size: 13pt; font-weight: bold; letter-spacing: .5px; margin: 2px 0; }
    .guia-lugar    { font-size: 6.5pt; color: #333; margin-top: 3px; }
    .guia-tel      { font-size: 7.5pt; font-weight: bold; margin-top: 2px; }

    .tracking-big  { font-size: 13pt; font-weight: bold; letter-spacing: 1px; display: block; margin-top: 3px; }
    .folio-row     { font-size: 7pt; color: #444; margin-top: 2px; }
    #barcode       { max-width: 100%; max-height: 36px; width: auto; height: auto; }

    /* ── Secciones (remitente / facturar / destinatario) ── */
    .seccion-label {
      font-size: 7pt; font-weight: bold; text-transform: uppercase;
      background: #e8e8e8; border-bottom: 1px solid #000;
      padding: 2px 4px; display: block;
    }
    .seccion-content { font-size: 7.5pt; line-height: 1.45; padding: 4px 5px; min-height: 58px; }

    /* ── Tabla de carga ── */
    .cargo-th {
      background: #e0e0e0; font-size: 7pt; font-weight: bold;
      text-align: center; padding: 4px 3px; border: 1px solid #000;
    }
    .cargo-td { font-size: 7.5pt; text-align: center; padding: 5px 4px; min-height: 26px; }
    .cargo-td.left { text-align: left; }
    .cargo-td.bold { font-weight: bold; }

    /* ── Mensaje personalizable ── */
    .msg-row {
      border: 1px solid #000;
      border-top: none;
      padding: 5px 7px;
      font-size: 7.5pt;
      min-height: 22px;
      color: #444;
      font-style: italic;
      text-align: center;
    }
    .msg-row.empty { display: none; }

    /* ── Bloque inferior ── */
    .footer-label {
      font-size: 6.5pt; font-weight: bold; text-transform: uppercase;
      background: #ececec; border-bottom: 1px solid #000;
      padding: 3px 5px; display: block;
    }
    .footer-content { font-size: 8pt; padding: 6px 6px; min-height: 48px; line-height: 1.6; }
    .footer-content.tall { min-height: 120px; height: 100%; }
    .referencia-val { font-size: 12pt; font-weight: bold; }

    /* ── Expand footer sections to fill remaining page ── */
    .page { display: flex; flex-direction: column; }
    .footer-grow { flex: 1; }
    .footer-grow tr { height: 100%; }
    .footer-grow td { height: 100%; }
    .footer-grow .footer-content { height: 100%; min-height: 80px; }
    .pago-big  { font-size: 16pt; font-weight: bold; display: block; margin-top: 4px; }
    .fecha-big { font-size: 16pt; font-weight: bold; display: block; margin-top: 4px; }

    /* ── Pie ── */
    .pie-datos {
      font-size: 6.5pt; border: 1px solid #000; border-top: none;
      padding: 3px 6px; line-height: 1.5;
    }
    .disclaimer {
      font-size: 6.5pt; border: 1px solid #000; border-top: none;
      padding: 4px 6px; text-align: center; line-height: 1.4;
    }

    /* ── Tamaños dinámicos desde template ── */
    .guia-titulo    { font-size: var(--sz-guia-titulo,    13pt)  !important; }
    .guia-servicio  { font-size: var(--sz-guia-servicio,   8pt)  !important; }
    .tracking-big   { font-size: var(--sz-tracking-big,   13pt)  !important; }
    .company-name   { font-size: var(--sz-company-name,    9pt)  !important; }
    .seccion-label  { font-size: var(--sz-seccion-label,   7pt)  !important; }
    .seccion-content{ font-size: var(--sz-seccion-content, 7.5pt)!important; }
    .cargo-th       { font-size: var(--sz-cargo-th,        7pt)  !important; }
    .cargo-td       { font-size: var(--sz-cargo-td,        7.5pt)!important; }
    .msg-row        { font-size: var(--sz-msg-row,         7.5pt)!important; }
    .footer-content { font-size: var(--sz-footer-content,  8pt)  !important; }
    .pago-big       { font-size: var(--sz-pago-big,        16pt) !important; }
    .fecha-big      { font-size: var(--sz-pago-big,        16pt) !important; }
    /* ── Elemento oculto ── */
    .guia-hidden { display: none !important; }

    /* ── Impresión ── */
    @page { size: letter; margin: 0; }
    @media print {
      body { background: white; overflow: visible; }
      .toolbar, .panel-guia, .zoom-bar { display: none !important; }
      .page-layout { display: block; height: auto; }
      .guia-area { overflow: visible; display: block; background: white; cursor: default; }
      #guia-canvas { display: block; transform: none !important; zoom: 1 !important; }
      .page {
        width: 215.9mm;
        height: 279.4mm;
        margin: 0;
        padding: 5mm 6mm;
        box-shadow: none;
        display: flex !important;
        flex-direction: column;
        overflow: hidden;
      }
      .footer-grow { flex: 1; min-height: 40px; overflow: hidden; }
      .footer-grow tr { height: 100%; }
      .footer-grow td { height: 100%; }
      .footer-grow .footer-content.tall { min-height: 0; height: 100%; }
    }

    /* ── Panel de toggles ── */
    .panel-guia {
      width: 248px;
      flex-shrink: 0;
      overflow-y: auto;
      padding: 20px 14px 80px;
      background: #f1f5f9;
    }
    .tpl-panel { background: white; border-radius: 14px; padding: 16px 14px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
    .tpl-panel-hdr { font-size: 0.78rem; font-weight: 800; color: #1e293b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px; }
    .tpl-section { font-size: 0.63rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; margin: 10px 0 3px; }
    .tpl-row { display: flex; align-items: center; justify-content: space-between; padding: 4px 0; gap: 8px; }
    .tpl-row-lbl { font-size: 0.78rem; color: #374151; font-weight: 500; line-height: 1.2; }
    .tpl-lock { font-size: 0.56rem; background: #fef3c7; color: #b45309; padding: 1px 4px; border-radius: 3px; font-weight: 700; margin-left: 3px; }
    .tpl-sw { position: relative; width: 36px; height: 19px; flex-shrink: 0; }
    .tpl-sw input { opacity: 0; width: 0; height: 0; }
    .tpl-sl { position: absolute; cursor: pointer; inset: 0; background: #cbd5e1; transition: .25s; border-radius: 20px; }
    .tpl-sl:before { position: absolute; content: ""; height: 13px; width: 13px; left: 3px; bottom: 3px; background: white; transition: .25s; border-radius: 50%; }
    .tpl-sw input:checked + .tpl-sl { background: #3b82f6; }
    .tpl-sw input:checked + .tpl-sl:before { transform: translateX(17px); }
    .tpl-sw input:disabled + .tpl-sl { opacity: 0.55; cursor: not-allowed; }
    .tpl-nota { font-size: 0.68rem; color: #94a3b8; line-height: 1.4; margin-top: 10px; padding-top: 10px; border-top: 1px solid #f1f5f9; }

    /* ── Barra de zoom ── */
    .zoom-bar {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
      background: rgba(15,23,42,0.88); backdrop-filter: blur(10px);
      border-radius: 50px; padding: 9px 18px;
      display: flex; align-items: center; gap: 10px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.35); z-index: 300; user-select: none;
    }
    .zoom-btn { background: rgba(255,255,255,0.12); border: none; color: white; width: 28px; height: 28px; border-radius: 50%; font-size: 1.1rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s; }
    .zoom-btn:hover { background: rgba(255,255,255,0.25); }
    .zoom-slider { -webkit-appearance: none; appearance: none; width: 120px; height: 4px; border-radius: 4px; background: rgba(255,255,255,0.25); outline: none; cursor: pointer; }
    .zoom-slider::-webkit-slider-thumb { -webkit-appearance: none; width: 16px; height: 16px; border-radius: 50%; background: white; cursor: pointer; box-shadow: 0 1px 4px rgba(0,0,0,0.4); }
    .zoom-pct { color: white; font-size: 0.78rem; font-weight: 700; min-width: 36px; text-align: center; }
    .zoom-reset { background: none; border: none; color: rgba(255,255,255,0.5); font-size: 0.75rem; cursor: pointer; padding: 0 2px; transition: color 0.15s; }
    .zoom-reset:hover { color: white; }

  </style>
</head>
<body>

<%
  const _g = guiaCfg || {};
  const szGuiaTitulo     = _g.size_guia_titulo     ? _g.size_guia_titulo + 'pt'     : '13pt';
  const szGuiaServicio   = _g.size_guia_servicio   ? _g.size_guia_servicio + 'pt'   : '8pt';
  const szTrackingBig    = _g.size_tracking_big    ? _g.size_tracking_big + 'pt'    : '13pt';
  const szCompanyName    = _g.size_company_name    ? _g.size_company_name + 'pt'    : '9pt';
  const szSeccionLabel   = _g.size_seccion_label   ? _g.size_seccion_label + 'pt'   : '7pt';
  const szSeccionContent = _g.size_seccion_content ? _g.size_seccion_content + 'pt' : '7.5pt';
  const szCargoTh        = _g.size_cargo_th        ? _g.size_cargo_th + 'pt'        : '7pt';
  const szCargaTd        = _g.size_cargo_td        ? _g.size_cargo_td + 'pt'        : '7.5pt';
  const szMsgRow         = _g.size_msg_row         ? _g.size_msg_row + 'pt'         : '7.5pt';
  const szFooterContent  = _g.size_footer_content  ? _g.size_footer_content + 'pt'  : '8pt';
  const szPagoBig        = _g.size_pago_big        ? _g.size_pago_big + 'pt'        : '16pt';
%>
<style>
  :root {
    --sz-guia-titulo:     <%= szGuiaTitulo %>;
    --sz-guia-servicio:   <%= szGuiaServicio %>;
    --sz-tracking-big:    <%= szTrackingBig %>;
    --sz-company-name:    <%= szCompanyName %>;
    --sz-seccion-label:   <%= szSeccionLabel %>;
    --sz-seccion-content: <%= szSeccionContent %>;
    --sz-cargo-th:        <%= szCargoTh %>;
    --sz-cargo-td:        <%= szCargaTd %>;
    --sz-msg-row:         <%= szMsgRow %>;
    --sz-footer-content:  <%= szFooterContent %>;
    --sz-pago-big:        <%= szPagoBig %>;
  }
</style>

<% const hayLugares   = lugaresExpedicion && lugaresExpedicion.length >= 1; %>
<% const sinSeleccion = hayLugares && !lugarExpedicion; %>
<% const sinLugares   = !hayLugares; %>
<% const esAdmin      = user && (user.rol === 'admin' || user.rol === 'superusuario'); %>
<% const esCliente    = typeof clienteView !== 'undefined' && clienteView; %>

<% if (esCliente) { %>
<div class="toolbar">
  <div class="toolbar-left">
    <a href="/portal-cliente/envio/<%= envio.id %>" class="btn-back">← Volver</a>
    <span class="toolbar-title">Guía Expedida</span>
    <span class="toolbar-tracking"><%= envio.numero_tracking %></span>
  </div>
  <button class="btn-print" onclick="window.print()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px">
      <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
    </svg>
    Imprimir / Descargar PDF
  </button>
</div>
<% } else { %>
<!-- Vista cliente: botón de impresión sin guardar config -->
<div class="toolbar">
  <div class="toolbar-left">
    <a href="/envios/<%= envio.id %>" class="btn-back">← Volver al detalle</a>
    <span class="toolbar-title">Guía Expedida</span>
    <span class="toolbar-tracking"><%= envio.numero_tracking %></span>
  </div>
  <div style="display:flex;align-items:center;gap:10px;">
    <% if (sinLugares) { %>
      <!-- No hay lugares configurados -->
      <div style="display:flex;align-items:center;gap:10px;">
        <% if (esAdmin) { %>
          <span style="color:#fbbf24;font-size:12px;font-weight:500;">⚠️ No hay lugares de expedición configurados.</span>
          <a href="/configuracion?tab=empresa#seccion-lugares-expedicion"
            style="padding:6px 14px;border-radius:7px;background:#fbbf24;color:#1e3a8a;font-size:12px;font-weight:700;text-decoration:none;white-space:nowrap;">
            Ir a Configuración →
          </a>
        <% } else { %>
          <span style="color:#fca5a5;font-size:12px;font-weight:500;">⚠️ Contacta al administrador para configurar los lugares de expedición.</span>
        <% } %>
      </div>
    <% } else { %>
    <div style="display:flex;align-items:center;gap:7px;">
      <span style="color:rgba(255,255,255,0.65);font-size:11px;white-space:nowrap;">📍 Expedido en:</span>
      <select id="lugar-select" onchange="cambiarLugar(this.value)"
        style="padding:6px 10px;border-radius:7px;border:1px solid rgba(255,255,255,0.25);background:rgba(255,255,255,0.1);color:#fff;font-size:12px;font-weight:600;cursor:pointer;outline:none;">
        <% if (!lugarExpedicion) { %>
          <option value="" disabled selected style="background:#1e3a8a;color:#94a3b8;">— Selecciona un lugar —</option>
        <% } %>
        <% lugaresExpedicion.forEach(function(l) { %>
          <option value="<%= l %>" <%= l === lugarExpedicion ? 'selected' : '' %> style="background:#1e3a8a;color:#fff;"><%= l %></option>
        <% }) %>
      </select>
    </div>
    <% } %>
    <button id="btn-print" class="btn-print"
      onclick="guardarYImprimir()"
      <%= (sinSeleccion || sinLugares) ? 'disabled' : '' %>
      style="<%= (sinSeleccion || sinLugares) ? 'opacity:0.45;cursor:not-allowed;pointer-events:none;' : '' %>">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px">
        <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
      </svg>
      Imprimir / Descargar PDF
    </button>
  </div>
</div>
<% } %>

<div class="page-layout" style="<%= esCliente ? 'padding-right:0' : '' %>">
  <div class="guia-area" id="guia-area">
    <div id="guia-canvas">
      <div class="page">

        <%
          const g = guiaCfg;
          function gc(key) { return g['mostrar_' + key] ? '' : 'guia-hidden'; }

          function dirOrigen() {
            const p = [];
            if (envio.origen_calle)      p.push(envio.origen_calle);
            if (envio.origen_colonia)    p.push(envio.origen_colonia);
            if (envio.origen_ciudad && envio.origen_estado) p.push(envio.origen_ciudad + ', ' + envio.origen_estado);
            else if (envio.origen_ciudad) p.push(envio.origen_ciudad);
            if (envio.origen_cp)         p.push('CP ' + envio.origen_cp);
            if (envio.origen_referencia) p.push(envio.origen_referencia);
            return p.join(', ') || (envio.origen || '');
          }
          function dirDestino() {
            const p = [];
            if (envio.destino_calle)      p.push(envio.destino_calle);
            if (envio.destino_colonia)    p.push(envio.destino_colonia);
            if (envio.destino_ciudad && envio.destino_estado) p.push(envio.destino_ciudad + ', ' + envio.destino_estado);
            else if (envio.destino_ciudad) p.push(envio.destino_ciudad);
            if (envio.destino_cp)         p.push('CP ' + envio.destino_cp);
            if (envio.destino_referencia) p.push(envio.destino_referencia);
            return p.join(', ') || (envio.destino || '');
          }

          const pesoTotal = items.reduce((s, it) => s + parseFloat(it.peso || 0), 0);

          const ahora = new Date();
          const fechaEmision = ahora.toLocaleDateString('es-MX', {day:'2-digit',month:'2-digit',year:'numeric'});
          const horaEmision  = ahora.toLocaleTimeString('es-MX', {hour:'2-digit',minute:'2-digit'}) + ' Hrs.';
          const fechaEntrega = envio.fecha_estimada_entrega
            ? (() => {
                const s = envio.fecha_estimada_entrega instanceof Date
                  ? envio.fecha_estimada_entrega.toISOString().split('T')[0]
                  : String(envio.fecha_estimada_entrega).split('T')[0];
                const [y, m, d] = s.split('-');
                return `${d}/${m}/${y}`;
              })()
            : 'Por definir';

          const estadoLabel = {
            'creado':'CREADO','pendiente':'PENDIENTE','en-transito':'EN TRÁNSITO',
            'en-bodega':'EN BODEGA','entregado':'ENTREGADO','retrasado':'RETRASADO','cancelado':'CANCELADO'
          };

          const msg1 = guiaCfg.mensaje_1 || '';
          const msg2 = guiaCfg.mensaje_2 || '';
          const msg3 = guiaCfg.mensaje_3 || '';
          const msg4 = guiaCfg.mensaje_4 || '';

          const descripcionServicio = guiaCfg.descripcion_servicio || 'Servicio de transportes de Carga';
          const tituloGuia = guiaCfg.titulo_guia || 'GUÍA EXPEDIDA';
          const etiquetaColDesc = guiaCfg.etiqueta_col_descripcion || 'DESCRIPCIÓN SEGÚN REMITENTE';
          const etiquetaOperador   = guiaCfg.etiqueta_operador    || 'Operador que entregó:';
          const etiquetaObsOper    = guiaCfg.etiqueta_obs_operador || 'Observaciones:';
          const etiquetaRecibidoPor= guiaCfg.etiqueta_recibido_por || 'Recibido por: (Nombre, firma y sello)';
          const etiquetaObsRecibido= guiaCfg.etiqueta_obs_recibido || 'Observaciones:';

          const nombreEmpresa = config.empresa_nombre || 'TRANSPORTES';
        %>

        <!-- ══ ENCABEZADO ══ -->
        <table>
          <tr>
            <!-- Logo + empresa -->
            <td class="cell-logo <%= gc('logo') %>" data-elem="logo">
              <% if (config.empresa_logo_url) { %>
                <img src="<%= config.empresa_logo_url %>" class="logo-img" alt="Logo">
              <% } %>
              <div class="company-name"><%= nombreEmpresa %></div>
              <div class="company-rfc <%= gc('rfc') %>" data-elem="rfc"><% if (config.empresa_rfc) { %>RFC: <%= config.empresa_rfc %><% } %></div>
            </td>

            <!-- Título central -->
            <td class="cell-title">
              <div class="guia-servicio"><%= descripcionServicio %></div>
              <div class="guia-titulo"><%= tituloGuia %></div>
              <% if (lugarExpedicion) { %>
                <div class="guia-lugar" id="guia-lugar-texto">LUGAR DE EXPEDICIÓN: <%= lugarExpedicion.toUpperCase() %></div>
              <% } %>
              <div class="guia-tel <%= gc('telefono') %>" data-elem="telefono">
                <% if (config.empresa_telefono) { %>
                  Tel: +<%= config.empresa_telefono.replace(/\D/g,'') %><% if (config.empresa_telefono_adicional) { %> &nbsp;|&nbsp; +<%= config.empresa_telefono_adicional.replace(/\D/g,'') %><% } %>
                <% } %>
              </div>
            </td>

            <!-- Barcode + tracking -->
            <td class="cell-barcode <%= gc('barcode') %>" data-elem="barcode">
              <svg id="barcode"></svg>
              <span class="tracking-big"><%= envio.numero_tracking %></span>
              <div class="folio-row">Folio: <%= envio.id %> &nbsp;|&nbsp; Rev.:0</div>
            </td>
          </tr>
        </table>

        <!-- ══ REMITENTE / FACTURAR / DESTINATARIO ══ -->
        <table style="border-top:none;">
          <tr>
            <td style="width:33%;padding:0;" class="<%= gc('seccion_remitente') %>" data-elem="seccion_remitente">
              <span class="seccion-label">Remitente: (Origen)</span>
              <div class="seccion-content">
                <div class="<%= gc('remitente_nombre') %>" data-elem="remitente_nombre"><strong><%= origenAlias || nombreEmpresa %></strong></div>
                <div class="<%= gc('remitente_direccion') %>" data-elem="remitente_direccion"><%= dirOrigen() %></div>
                <% if (config.empresa_telefono) { %><div class="<%= gc('remitente_telefono') %>" data-elem="remitente_telefono">Tel. <%= config.empresa_telefono %></div><% } %>
              </div>
            </td>
            <td style="width:34%;padding:0;border-left:1px solid #000;" class="<%= gc('seccion_facturar') %>" data-elem="seccion_facturar">
              <span class="seccion-label">Facturar a:</span>
              <div class="seccion-content">
                <div class="<%= gc('facturar_nombre') %>" data-elem="facturar_nombre"><strong><%= envio.nombre_empresa || '-' %></strong></div>
                <% if (envio.cliente_direccion) { %><div class="<%= gc('facturar_direccion') %>" data-elem="facturar_direccion"><%= envio.cliente_direccion %></div><% } %>
                <% if (envio.contacto) { %><div class="<%= gc('facturar_contacto') %>" data-elem="facturar_contacto">Attn: <%= envio.contacto %></div><% } %>
                <% if (envio.telefono) { %><div class="<%= gc('facturar_telefono') %>" data-elem="facturar_telefono">Tel. <%= envio.telefono %></div><% } %>
                <% if (envio.cliente_email) { %><div class="<%= gc('facturar_email') %>" data-elem="facturar_email"><%= envio.cliente_email %></div><% } %>
                <% if (envio.cliente_rfc) { %><div class="<%= gc('facturar_rfc') %>" data-elem="facturar_rfc">RFC: <%= envio.cliente_rfc %></div><% } %>
              </div>
            </td>
            <td style="width:33%;padding:0;border-left:1px solid #000;" class="<%= gc('seccion_destinatario') %>" data-elem="seccion_destinatario">
              <span class="seccion-label">Destinatario: (Destino)</span>
              <div class="seccion-content">
                <div class="<%= gc('destinatario_nombre') %>" data-elem="destinatario_nombre"><strong><%= destinoAlias || envio.destino_ciudad || '' %></strong></div>
                <div class="<%= gc('destinatario_direccion') %>" data-elem="destinatario_direccion"><%= dirDestino() %></div>
              </div>
            </td>
          </tr>
        </table>

        <!-- ══ TABLA DE CARGA ══ -->
        <table style="border-top:none;">
          <thead>
            <tr>
              <th class="cargo-th" style="width:5%;">CANT.</th>
              <th class="cargo-th" style="width:12%;">EMBALAJE</th>
              <th class="cargo-th"><%= etiquetaColDesc %></th>
              <th class="cargo-th" style="width:11%;">PESO ESTIMADO Kgs.</th>
              <th class="cargo-th <%= gc('col_peso_facturado') %>" style="width:11%;" data-elem="col_peso_facturado">PESO FACT. Kgs.</th>
              <th class="cargo-th <%= gc('col_volumen') %>" style="width:10%;" data-elem="col_volumen">VOLUMEN Mts.³</th>
              <th class="cargo-th <%= gc('col_servicios') %>" style="width:10%;" data-elem="col_servicios">SERVICIOS</th>
              <th class="cargo-th <%= gc('col_importe') %>" style="width:10%;" data-elem="col_importe">IMPORTE</th>
            </tr>
          </thead>
          <tbody>
            <% if (items && items.length > 0) {
              items.forEach(function(item) { %>
              <tr>
                <td class="cargo-td"><%= item.cantidad || 1 %></td>
                <td class="cargo-td left"><%= item.tipo || '-' %></td>
                <td class="cargo-td left"><%= item.descripcion || '-' %></td>
                <td class="cargo-td"><%= item.peso ? parseFloat(item.peso).toFixed(3) : '0.000' %></td>
                <td class="cargo-td <%= gc('col_peso_facturado') %>" data-elem="col_peso_facturado"></td>
                <td class="cargo-td <%= gc('col_volumen') %>" data-elem="col_volumen"></td>
                <td class="cargo-td left <%= gc('col_servicios') %>" data-elem="col_servicios"></td>
                <td class="cargo-td <%= gc('col_importe') %>" data-elem="col_importe"></td>
              </tr>
            <% }); %>
            <%
              var filasFaltantes = Math.max(0, 4 - items.length);
              for (var i = 0; i < filasFaltantes; i++) { %>
              <tr>
                <td class="cargo-td">&nbsp;</td><td class="cargo-td"></td><td class="cargo-td"></td><td class="cargo-td"></td>
                <td class="cargo-td <%= gc('col_peso_facturado') %>" data-elem="col_peso_facturado"></td>
                <td class="cargo-td <%= gc('col_volumen') %>" data-elem="col_volumen"></td>
                <td class="cargo-td <%= gc('col_servicios') %>" data-elem="col_servicios"></td>
                <td class="cargo-td <%= gc('col_importe') %>" data-elem="col_importe"></td>
              </tr>
            <% } %>
            <% } else { %>
              <% if (envio.descripcion) { %>
              <tr>
                <td class="cargo-td">1</td>
                <td class="cargo-td left">PAQUETE</td>
                <td class="cargo-td left"><%= envio.descripcion %></td>
                <td class="cargo-td"><%= envio.peso ? parseFloat(envio.peso).toFixed(3) : '0.000' %></td>
                <td class="cargo-td <%= gc('col_peso_facturado') %>" data-elem="col_peso_facturado"></td>
                <td class="cargo-td <%= gc('col_volumen') %>" data-elem="col_volumen"></td>
                <td class="cargo-td <%= gc('col_servicios') %>" data-elem="col_servicios"></td>
                <td class="cargo-td <%= gc('col_importe') %>" data-elem="col_importe"></td>
              </tr>
              <% for (var j = 0; j < 3; j++) { %>
              <tr>
                <td class="cargo-td">&nbsp;</td><td class="cargo-td"></td><td class="cargo-td"></td><td class="cargo-td"></td>
                <td class="cargo-td <%= gc('col_peso_facturado') %>" data-elem="col_peso_facturado"></td>
                <td class="cargo-td <%= gc('col_volumen') %>" data-elem="col_volumen"></td>
                <td class="cargo-td <%= gc('col_servicios') %>" data-elem="col_servicios"></td>
                <td class="cargo-td <%= gc('col_importe') %>" data-elem="col_importe"></td>
              </tr>
              <% } %>
              <% } else { %>
              <% for (var k = 0; k < 4; k++) { %>
              <tr>
                <td class="cargo-td">&nbsp;</td><td class="cargo-td"></td><td class="cargo-td"></td><td class="cargo-td"></td>
                <td class="cargo-td <%= gc('col_peso_facturado') %>" data-elem="col_peso_facturado"></td>
                <td class="cargo-td <%= gc('col_volumen') %>" data-elem="col_volumen"></td>
                <td class="cargo-td <%= gc('col_servicios') %>" data-elem="col_servicios"></td>
                <td class="cargo-td <%= gc('col_importe') %>" data-elem="col_importe"></td>
              </tr>
              <% } %>
              <% } %>
            <% } %>
            <!-- Totales -->
            <tr>
              <td class="cargo-td"></td><td class="cargo-td"></td><td class="cargo-td"></td>
              <td class="cargo-td bold"><%= pesoTotal > 0 ? pesoTotal.toFixed(2) : (envio.peso ? parseFloat(envio.peso).toFixed(2) : '') %></td>
              <td class="cargo-td <%= gc('col_peso_facturado') %>" data-elem="col_peso_facturado"></td>
              <td class="cargo-td <%= gc('col_volumen') %>" data-elem="col_volumen"></td>
              <td class="cargo-td <%= gc('col_servicios') %>" data-elem="col_servicios"></td>
              <td class="cargo-td <%= gc('col_importe') %>" data-elem="col_importe"></td>
            </tr>
          </tbody>
        </table>

        <!-- ══ MENSAJE 1 + AVISO PRIVACIDAD ══ -->
        <%
          const avisoPrivacidad = config.empresa_aviso_privacidad || '';
          const avisoVisible = avisoPrivacidad && !!guiaCfg.mostrar_sitio_web;
        %>
        <div class="msg-row <%= gc('clausula_seguro') %> <%= (msg1 || avisoVisible) ? '' : 'empty' %>" data-elem="clausula_seguro"><%= msg1 %><% if (avisoPrivacidad) { %><span data-elem="sitio_web" class="<%= avisoVisible ? '' : 'guia-hidden' %>"><%= msg1 ? ' ' : '' %>Conoce nuestro aviso de Privacidad en: <%= avisoPrivacidad %></span><% } %></div>

        <!-- ══ MENSAJE 2 ══ -->
        <div class="msg-row <%= gc('clausula_seguro') %> <%= msg2 ? '' : 'empty' %>" data-elem="clausula_seguro"><%= msg2 %></div>

        <!-- ══ OBSERVACIONES / CONDICIONES / FECHAS ══ -->
        <table style="border-top:none;">
          <tr>
            <!-- Observaciones (2 filas de altura) -->
            <td style="width:28%;padding:0;border-right:1px solid #000;" rowspan="2" class="<%= gc('observaciones') %>" data-elem="observaciones">
              <span class="footer-label">Observaciones del cliente:</span>
              <div class="footer-content tall">&nbsp;</div>
            </td>
            <!-- Condiciones de pago -->
            <td style="width:36%;padding:0;border-right:1px solid #000;" class="<%= gc('condiciones_pago') %>" data-elem="condiciones_pago">
              <span class="footer-label">Condiciones de pago:</span>
              <div class="footer-content">
                <span class="pago-big"><%= envio.metodo_pago === 'PUE' ? 'CONTADO' : 'CRÉDITO' %></span>
              </div>
            </td>
            <!-- Fecha de emisión -->
            <td style="width:36%;padding:0;" class="<%= gc('fecha_emision') %>" data-elem="fecha_emision">
              <span class="footer-label">Fecha de emisión:</span>
              <div class="footer-content">
                <strong><%= fechaEmision %></strong><br>
                Hora: <%= horaEmision %><br>
                Documento: -
              </div>
            </td>
          </tr>
          <tr>
            <!-- Fecha estimada de entrega -->
            <td style="width:36%;padding:0;border-top:1px solid #000;border-right:1px solid #000;" class="<%= gc('fecha_entrega') %>" data-elem="fecha_entrega">
              <span class="footer-label">Fecha estimada de entrega:</span>
              <div class="footer-content">
                <span class="fecha-big"><%= fechaEntrega %></span>
              </div>
            </td>
            <!-- Referencia del cliente -->
            <td style="width:36%;padding:0;border-top:1px solid #000;" class="<%= gc('referencia_cliente') %>" data-elem="referencia_cliente">
              <span class="footer-label">Referencia del cliente:</span>
              <div class="footer-content"><span class="referencia-val"><%= envio.referencia_cliente || '' %></span></div>
            </td>
          </tr>
        </table>

        <!-- ══ RETORNO DE DOCUMENTOS ══ -->
        <table style="border-top:none;width:100%;" class="footer-grow <%= gc('retorno_documentos') %>" data-elem="retorno_documentos">
          <tr>
            <td style="padding:0;">
              <span class="footer-label">Retorno de documentos:</span>
              <div class="footer-content">&nbsp;</div>
            </td>
          </tr>
        </table>

        <!-- ══ OPERADOR QUE ENTREGÓ ══ -->
        <table style="border-top:none;width:100%;" class="footer-grow <%= gc('operador') %>" data-elem="operador">
          <tr>
            <td style="padding:0;width:40%;">
              <span class="footer-label"><%= etiquetaOperador %></span>
              <div class="footer-content tall">&nbsp;</div>
            </td>
            <td style="padding:0;width:60%;border-left:1px solid #000;" class="<%= gc('obs_operador') %>" data-elem="obs_operador">
              <span class="footer-label"><%= etiquetaObsOper %></span>
              <div class="footer-content tall">&nbsp;</div>
            </td>
          </tr>
        </table>

        <!-- ══ RECIBIDO POR ══ -->
        <table style="border-top:none;width:100%;" class="footer-grow <%= gc('recibido_por') %>" data-elem="recibido_por">
          <tr>
            <td style="padding:0;width:40%;">
              <span class="footer-label"><%= etiquetaRecibidoPor %></span>
              <div class="footer-content tall">&nbsp;</div>
            </td>
            <td style="padding:0;width:60%;border-left:1px solid #000;" class="<%= gc('obs_recibido') %>" data-elem="obs_recibido">
              <span class="footer-label"><%= etiquetaObsRecibido %></span>
              <div class="footer-content tall">&nbsp;</div>
            </td>
          </tr>
        </table>

        <!-- ══ MENSAJE 3 ══ -->
        <div class="msg-row <%= gc('firma_final') %> <%= msg3 ? '' : 'empty' %>" data-elem="firma_final"><%= msg3 %></div>

        <!-- ══ PIE ══ -->
        <div class="pie-datos <%= gc('pie_datos') %>" data-elem="pie_datos">
          <strong>MERCANCÍA TRANSPORTADA SEGÚN ESTADO:</strong> <%= (estadoLabel[envio.estado_actual] || envio.estado_actual || '-').toUpperCase() %>
          &nbsp;&nbsp;&nbsp;
          <strong>TRACKING:</strong> <%= envio.numero_tracking %>
          &nbsp;&nbsp;&nbsp;
          <strong>ORIGEN:</strong> <%= origenAlias || envio.origen || '-' %>
          &nbsp;&nbsp;&nbsp;
          <strong>DESTINO:</strong> <%= destinoAlias || envio.destino || '-' %>
        </div>
        <!-- ══ MENSAJE 4 (al final del documento, editable desde template) ══ -->
        <div class="msg-row <%= gc('disclaimer') %> <%= msg4 ? '' : 'empty' %>" data-elem="disclaimer"><%= msg4 %></div>

      </div><!-- /page -->
    </div><!-- /guia-canvas -->
  </div><!-- /guia-area -->

  <!-- ── Panel de toggles ── -->
  <% if (!esCliente) { %>
  <div class="panel-guia">
    <div class="tpl-panel">
      <div class="tpl-panel-hdr">Elementos de la Guía</div>

      <!-- Sub-tabs del panel -->
      <div style="display:flex;gap:3px;margin-bottom:14px;background:#f1f5f9;border-radius:8px;padding:3px;">
        <button type="button" id="gpanel-btn-elementos" onclick="switchGuiaPanel('elementos')"
          style="flex:1;padding:5px 0;border:none;border-radius:6px;font-size:0.75rem;font-weight:700;cursor:pointer;transition:all .15s;background:#2563eb;color:white;box-shadow:0 1px 4px rgba(37,99,235,.25);">
          Elementos
        </button>
        <button type="button" id="gpanel-btn-tamanos" onclick="switchGuiaPanel('tamanos')"
          style="flex:1;padding:5px 0;border:none;border-radius:6px;font-size:0.75rem;font-weight:700;cursor:pointer;transition:all .15s;background:transparent;color:#64748b;">
          Tamaños
        </button>
      </div>

      <!-- Panel: Elementos (toggles) -->
      <div id="gpanel-elementos">

      <%
        function panelGuiaRow(key, icon, label, showVal, isObl) {
          return { key, icon, label, checked: !!showVal, disabled: !!isObl, isObl: !!isObl };
        }
        const panelEncabezado = [
          panelGuiaRow('logo',      '🖼️', 'Logo',              g.mostrar_logo,     g.obligatorio_logo),
          panelGuiaRow('rfc',       '🪪',  'RFC',               g.mostrar_rfc,      g.obligatorio_rfc),
          panelGuiaRow('telefono',  '📞', 'Teléfonos',         g.mostrar_telefono, g.obligatorio_telefono),
          panelGuiaRow('sitio_web', '🌐', 'Aviso de Privacidad',g.mostrar_sitio_web,g.obligatorio_sitio_web),
          panelGuiaRow('barcode',   '▤',  'Código de barras',  g.mostrar_barcode,  g.obligatorio_barcode),
        ];
        const panelSecciones = [
          panelGuiaRow('seccion_remitente',    '📦', 'Remitente',          g.mostrar_seccion_remitente,    g.obligatorio_seccion_remitente),
          panelGuiaRow('remitente_nombre',     ' ↳', '  Nombre',           g.mostrar_remitente_nombre,     g.obligatorio_remitente_nombre),
          panelGuiaRow('remitente_direccion',  ' ↳', '  Dirección',        g.mostrar_remitente_direccion,  g.obligatorio_remitente_direccion),
          panelGuiaRow('remitente_telefono',   ' ↳', '  Teléfono',         g.mostrar_remitente_telefono,   g.obligatorio_remitente_telefono),
          panelGuiaRow('seccion_facturar',     '🧾', 'Facturar a',         g.mostrar_seccion_facturar,     g.obligatorio_seccion_facturar),
          panelGuiaRow('facturar_nombre',      ' ↳', '  Nombre',           g.mostrar_facturar_nombre,      g.obligatorio_facturar_nombre),
          panelGuiaRow('facturar_direccion',   ' ↳', '  Dirección',        g.mostrar_facturar_direccion,   g.obligatorio_facturar_direccion),
          panelGuiaRow('facturar_contacto',    ' ↳', '  Contacto (Attn)',  g.mostrar_facturar_contacto,    g.obligatorio_facturar_contacto),
          panelGuiaRow('facturar_telefono',    ' ↳', '  Teléfono',         g.mostrar_facturar_telefono,    g.obligatorio_facturar_telefono),
          panelGuiaRow('facturar_email',       ' ↳', '  Email',            g.mostrar_facturar_email,       g.obligatorio_facturar_email),
          panelGuiaRow('facturar_rfc',         ' ↳', '  RFC',              g.mostrar_facturar_rfc,         g.obligatorio_facturar_rfc),
          panelGuiaRow('seccion_destinatario', '📍', 'Destinatario',       g.mostrar_seccion_destinatario, g.obligatorio_seccion_destinatario),
          panelGuiaRow('destinatario_nombre',  ' ↳', '  Nombre',           g.mostrar_destinatario_nombre,  g.obligatorio_destinatario_nombre),
          panelGuiaRow('destinatario_direccion',' ↳','  Dirección',         g.mostrar_destinatario_direccion,g.obligatorio_destinatario_direccion),
          panelGuiaRow('clausula_seguro',      '🛡️', 'Cláusula seguro',    g.mostrar_clausula_seguro,      g.obligatorio_clausula_seguro),
        ];
        const panelCondiciones = [
          panelGuiaRow('observaciones',      '📝', 'Observaciones',    g.mostrar_observaciones,      g.obligatorio_observaciones),
          panelGuiaRow('condiciones_pago',   '💳', 'Cond. de pago',   g.mostrar_condiciones_pago,   g.obligatorio_condiciones_pago),
          panelGuiaRow('fecha_emision',      '📅', 'Fecha emisión',   g.mostrar_fecha_emision,      g.obligatorio_fecha_emision),
          panelGuiaRow('fecha_entrega',      '🗓️', 'Fecha entrega',    g.mostrar_fecha_entrega,      g.obligatorio_fecha_entrega),
          panelGuiaRow('referencia_cliente', '🔖', 'Referencia',      g.mostrar_referencia_cliente, g.obligatorio_referencia_cliente),
          panelGuiaRow('retorno_documentos', '↩️', 'Retorno docs.',    g.mostrar_retorno_documentos, g.obligatorio_retorno_documentos),
          panelGuiaRow('operador',           '🚛', 'Operador',              g.mostrar_operador,           g.obligatorio_operador),
          panelGuiaRow('obs_operador',       '📝', ' ↳ Obs. Operador',      g.mostrar_obs_operador,       g.obligatorio_obs_operador),
          panelGuiaRow('recibido_por',       '✍️',  'Recibido por',          g.mostrar_recibido_por,       g.obligatorio_recibido_por),
          panelGuiaRow('obs_recibido',       '📝', ' ↳ Obs. Recibido por',  g.mostrar_obs_recibido,       g.obligatorio_obs_recibido),
          panelGuiaRow('firma_final',        '📋', 'Condiciones',     g.mostrar_firma_final,        g.obligatorio_firma_final),
        ];
        const panelColumnas = [
          panelGuiaRow('col_volumen',        '📐', 'Volumen',          g.mostrar_col_volumen,        g.obligatorio_col_volumen),
          panelGuiaRow('col_peso_facturado', '⚖️', 'Peso Facturado',   g.mostrar_col_peso_facturado, g.obligatorio_col_peso_facturado),
          panelGuiaRow('col_servicios',      '🔧', 'Servicios',        g.mostrar_col_servicios,      g.obligatorio_col_servicios),
          panelGuiaRow('col_importe',        '💰', 'Importe',          g.mostrar_col_importe,        g.obligatorio_col_importe),
        ];
        const panelPie = [
          panelGuiaRow('pie_datos',  '📊', 'Datos/Estado', g.mostrar_pie_datos,  g.obligatorio_pie_datos),
          panelGuiaRow('disclaimer', '⚠️', 'Aviso fiscal', g.mostrar_disclaimer, g.obligatorio_disclaimer),
        ];

        function renderPanelSection(rows) {
          let html = '';
          rows.forEach(function(r) {
            html += '<div class="tpl-row">';
            html += '<span class="tpl-row-lbl">' + r.icon + ' ' + r.label;
            if (r.isObl) html += '<span class="tpl-lock">FIJO</span>';
            html += '</span>';
            html += '<label class="tpl-sw"><input type="checkbox" onchange="toggleElem(\'' + r.key + '\',this.checked)"';
            if (r.checked) html += ' checked';
            if (r.disabled) html += ' disabled';
            html += '><span class="tpl-sl"></span></label></div>';
          });
          return html;
        }
      %>

      <p class="tpl-section">Encabezado</p>
      <%- renderPanelSection(panelEncabezado) %>

      <p class="tpl-section">Secciones</p>
      <%- renderPanelSection(panelSecciones) %>

      <p class="tpl-section">Condiciones / Fechas</p>
      <%- renderPanelSection(panelCondiciones) %>

      <p class="tpl-section">Columnas tabla</p>
      <%- renderPanelSection(panelColumnas) %>

      <p class="tpl-section">Pie del documento</p>
      <%- renderPanelSection(panelPie) %>

      <p class="tpl-nota">El título, descripción y mensajes se configuran en <strong>Configuración → Guía Expedida</strong>, dentro de cada template.</p>
      </div><!-- /gpanel-elementos -->

      <!-- Panel: Tamaños de texto -->
      <div id="gpanel-tamanos" style="display:none;">
        <p class="tpl-section" style="margin-top:0;">Tamaño de fuente (pt)</p>
        <%
          const panelSizes = [
            { css: '--sz-guia-titulo',     label: 'Título guía',              def: 13, min:  9, max: 18, cur: _g.size_guia_titulo     || 13 },
            { css: '--sz-guia-servicio',   label: 'Subtítulo servicio',        def:  8, min:  6, max: 12, cur: _g.size_guia_servicio   || 8  },
            { css: '--sz-tracking-big',    label: 'Núm. de tracking',         def: 13, min:  9, max: 18, cur: _g.size_tracking_big    || 13 },
            { css: '--sz-company-name',    label: 'Nombre empresa',            def:  9, min:  7, max: 14, cur: _g.size_company_name    || 9  },
            { css: '--sz-seccion-label',   label: 'Etiquetas de sección',      def:  7, min:  5, max: 10, cur: _g.size_seccion_label   || 7  },
            { css: '--sz-seccion-content', label: 'Contenido secciones',       def:  8, min:  6, max: 12, cur: _g.size_seccion_content || 8  },
            { css: '--sz-cargo-th',        label: 'Encabezado tabla',          def:  7, min:  5, max: 10, cur: _g.size_cargo_th        || 7  },
            { css: '--sz-cargo-td',        label: 'Filas tabla de carga',      def:  8, min:  6, max: 11, cur: _g.size_cargo_td        || 8  },
            { css: '--sz-msg-row',         label: 'Mensajes / cláusulas',      def:  8, min:  6, max: 12, cur: _g.size_msg_row         || 8  },
            { css: '--sz-footer-content',  label: 'Contenido footer (fechas)', def:  8, min:  6, max: 12, cur: _g.size_footer_content  || 8  },
            { css: '--sz-pago-big',        label: 'Pago / Fecha grandes',      def: 16, min: 10, max: 24, cur: _g.size_pago_big        || 16 },
          ];
        %>
        <% panelSizes.forEach(function(s) { %>
        <div style="margin-bottom:14px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
            <span class="tpl-row-lbl"><%= s.label %></span>
            <span id="gpsz-lbl-<%= s.css.replace('--','').replace(/-/g,'_') %>"
              style="font-size:0.85rem;font-weight:800;color:#2563eb;min-width:24px;text-align:right;"><%= s.cur %></span>
          </div>
          <input type="range" min="<%= s.min %>" max="<%= s.max %>" step="1" value="<%= s.cur %>"
            oninput="applyGuiaSz('<%= s.css %>',this.value,'gpsz-lbl-<%= s.css.replace('--','').replace(/-/g,'_') %>','<%= s.unit||'pt' %>')"
            style="width:100%;accent-color:#2563eb;height:4px;cursor:pointer;">
          <div style="display:flex;justify-content:space-between;font-size:0.65rem;color:#94a3b8;margin-top:2px;">
            <span><%= s.min %><%= s.unit||'pt' %></span><span>def: <%= s.def %><%= s.unit||'pt' %></span><span><%= s.max %><%= s.unit||'pt' %></span>
          </div>
        </div>
        <% }); %>
        <p class="tpl-nota">Los tamaños se aplican solo en esta vista. Para guardarlos de forma permanente, edita el template en <strong>Configuración</strong>.</p>
      </div><!-- /gpanel-tamanos -->

    </div>
  </div>
  <% } %>

</div><!-- /page-layout -->

<!-- ── Barra de zoom ── -->
<% if (!esCliente) { %>
<div class="zoom-bar">
  <button class="zoom-btn" onclick="changeZoom(-0.1)">−</button>
  <input type="range" id="zoom-slider" class="zoom-slider" min="30" max="200" value="75" step="5" oninput="setZoom(this.value/100)">
  <button class="zoom-btn" onclick="changeZoom(0.1)">+</button>
  <span class="zoom-pct" id="zoom-pct">75%</span>
  <button class="zoom-reset" onclick="setZoom(0.75)">↺</button>
</div>
<% } %>

<script>
  JsBarcode("#barcode", "<%= envio.numero_tracking %>", {
    format: "CODE128", width: 1.2, height: 32, displayValue: false, margin: 2
  });

  var _zoom = 0.75;
  function setZoom(v) {
    _zoom = Math.min(2.0, Math.max(0.3, Math.round(v * 20) / 20));
    document.getElementById('guia-canvas').style.zoom = _zoom;
    var sl = document.getElementById('zoom-slider'); if (sl) sl.value = Math.round(_zoom * 100);
    var pt = document.getElementById('zoom-pct'); if (pt) pt.textContent = Math.round(_zoom * 100) + '%';
  }
  function changeZoom(d) { setZoom(_zoom + d); }

  function cambiarLugar(valor) {
    if (!valor) return;
    // Actualizar texto en el documento
    var el = document.getElementById('guia-lugar-texto');
    if (el) {
      el.textContent = 'LUGAR DE EXPEDICIÓN: ' + valor.toUpperCase();
    } else {
      // Si no existía el elemento, crearlo en la celda del título
      var cell = document.querySelector('.guia-titulo');
      if (cell) {
        var div = document.createElement('div');
        div.id = 'guia-lugar-texto';
        div.className = 'guia-lugar';
        div.textContent = 'LUGAR DE EXPEDICIÓN: ' + valor.toUpperCase();
        cell.parentNode.insertBefore(div, cell.nextSibling);
      }
    }
    // Habilitar botón de imprimir
    var btn = document.getElementById('btn-print');
    if (btn) { btn.disabled = false; btn.style.opacity = ''; btn.style.cursor = ''; btn.style.pointerEvents = ''; }
    // Guardar preferencia silenciosamente
    fetch('/envios/api/lugar-expedicion', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ lugar: valor })
    }).catch(function() {});
  }

  // Estado actual de toggles (se actualiza en cada cambio y se guarda al imprimir)
  var _guiaConfig = <%- JSON.stringify(
    Object.keys(guiaCfg).filter(function(k){ return k.startsWith('mostrar_'); }).reduce(function(acc,k){ acc[k]=!!guiaCfg[k]; return acc; }, {})
  ) %>;
  var _envioId = <%= envio.id %>;

  function toggleElem(key, visible) {
    document.querySelectorAll('[data-elem="' + key + '"]').forEach(function(el) {
      el.classList.toggle('guia-hidden', !visible);
    });
    _guiaConfig['mostrar_' + key] = !!visible;
  }

  function guardarYImprimir() {
    fetch('/envios/api/guardar-config-guia', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ envio_id: _envioId, config: _guiaConfig })
    }).finally(function() {
      window.print();
    });
  }

  function applyGuiaSz(cssVar, value, lblId, unit) {
    document.documentElement.style.setProperty(cssVar, value + (unit || 'pt'));
    var lbl = document.getElementById(lblId);
    if (lbl) lbl.textContent = value;
  }

  function switchGuiaPanel(tab) {
    ['elementos', 'tamanos'].forEach(function(t) {
      var el  = document.getElementById('gpanel-' + t);
      var btn = document.getElementById('gpanel-btn-' + t);
      if (!el || !btn) return;
      var active = t === tab;
      el.style.display     = active ? '' : 'none';
      btn.style.background = active ? '#2563eb' : 'transparent';
      btn.style.color      = active ? 'white'   : '#64748b';
      btn.style.boxShadow  = active ? '0 1px 4px rgba(37,99,235,.25)' : 'none';
    });
  }


  document.addEventListener('DOMContentLoaded', function() {
    setZoom(0.75);
    var area = document.getElementById('guia-area');
    area.addEventListener('wheel', function(e) {
      e.preventDefault();
      changeZoom(e.deltaY < 0 ? 0.05 : -0.05);
    }, { passive: false });

    var _pan = false, _px, _py, _sx, _sy;
    area.addEventListener('mousedown', function(e) {
      if (e.button !== 0) return;
      _pan = true; _px = e.clientX; _py = e.clientY;
      _sx = area.scrollLeft; _sy = area.scrollTop;
      area.classList.add('panning'); e.preventDefault();
    });
    document.addEventListener('mousemove', function(e) {
      if (!_pan) return;
      area.scrollLeft = _sx - (e.clientX - _px);
      area.scrollTop  = _sy - (e.clientY - _py);
    });
    document.addEventListener('mouseup', function() {
      if (_pan) { _pan = false; area.classList.remove('panning'); }
    });
  });
</script>

</body>
</html>
