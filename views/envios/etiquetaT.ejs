<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Etiqueta - <%= envio.numero_tracking %></title>
  <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    @page {
      size: 4in 6in;
      margin: 0;
    }

    body {
      font-family: 'Arial', 'Helvetica', sans-serif;
      background: #e5e7eb;
      padding: 24px;
    }

    /* ================================================
       BARRA DE PREVIEW (no se imprime)
    ================================================ */
    .preview-bar {
      background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #2563eb 100%);
      border-radius: 0;
      padding: 12px 24px;
      margin: -24px -24px 24px -24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      height: 56px;
      position: sticky;
      top: -24px;
      z-index: 100;
    }

    .preview-bar-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .toolbar-title {
      color: #fff;
      font-size: 14px;
      font-weight: 700;
    }

    .toolbar-tracking {
      color: rgba(255,255,255,0.6);
      font-size: 12px;
    }

    .btn-print {
      padding: 10px 22px;
      background: #2563eb;
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 800;
      font-size: 0.88rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 7px;
      box-shadow: 0 4px 14px rgba(37,99,235,0.4);
      transition: all 0.2s;
    }

    .btn-print:hover { background: #1d4ed8; transform: translateY(-1px); box-shadow: 0 6px 18px rgba(37,99,235,0.5); }

    .btn-back {
      padding: 8px 16px;
      background: rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.85);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 8px;
      font-weight: 600;
      font-size: 12px;
      cursor: pointer;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all 0.2s;
    }

    .btn-back:hover { background: rgba(255,255,255,0.2); color: #fff; }

    /* ================================================
       ETIQUETA 4x6 PULGADAS
    ================================================ */
    .etiqueta {
      width: 4in;
      height: 6in;
      background: white;
      margin: 0 auto 32px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.18);
      border-radius: 4px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      page-break-after: always;
    }

    /* ── CABECERA ── */
    .cab {
      display: flex;
      align-items: stretch;
      border-bottom: 3px solid #000;
      flex-shrink: 0;
    }

    .cab-logo {
      padding: 7px 10px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      flex: 1;
      border-right: 2px solid #000;
      gap: 2px;
    }

    .cab-logo img {
      max-width: 140px;
      max-height: 58px;
      object-fit: contain;
      filter: grayscale(100%) contrast(1.3);
      margin-bottom: 2px;
    }

    .cab-logo-nombre {
      font-size: 13px;
      font-weight: 900;
      color: #000;
      letter-spacing: 0.5px;
      line-height: 1;
    }

    .cab-logo-eslogan {
      font-size: 6.5px;
      color: #000;
      font-style: italic;
      letter-spacing: 0.3px;
      line-height: 1;
    }

    .cab-fecha {
      padding: 7px 10px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-width: 68px;
      border-right: 2px solid #000;
    }

    .cab-fecha-label {
      font-size: 8px;
      font-weight: 800;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 2px;
    }

    .cab-fecha-val {
      font-size: 13px;
      font-weight: 900;
      color: #000;
      text-align: center;
      line-height: 1;
    }

    .cab-num {
      padding: 7px 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-width: 58px;
      background: #000;
    }

    .cab-num-label {
      font-size: 8px;
      font-weight: 800;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 2px;
    }

    .cab-num-val {
      font-size: 17px;
      font-weight: 900;
      color: #fff;
      line-height: 1;
    }

    /* ── CONTACTO (toggle) ── */
    .barra-contacto {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      padding: 3px 12px;
      background: #fff;
      border-bottom: 1.5px solid #000;
      flex-shrink: 0;
    }

    .barra-contacto span {
      font-size: 7px;
      color: #000;
    }

    /* ── TRACKING ── */
    .tracking-section {
      text-align: center;
      padding: 6px 12px 4px;
      border-bottom: 1.5px solid #000;
      flex-shrink: 0;
    }

    .tracking-label {
      font-size: 8.5px;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 2px;
    }

    .tipo-badge {
      display: block;
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 1px;
      background: #111;
      color: #fff;
      border-radius: 3px;
      padding: 4px 12px;
      margin-bottom: 5px;
    }

    .tracking-numero {
      font-family: 'Courier New', monospace;
      font-size: 26px;
      font-weight: 900;
      color: #000;
      letter-spacing: 2px;
      line-height: 1;
    }

    /* ── BARCODE (toggle) ── */
    .barcode-wrap {
      padding: 3px 12px 1px;
      text-align: center;
      border-bottom: 1.5px solid #000;
      flex-shrink: 0;
    }

    .barcode-wrap svg { max-width: 100%; }

    /* ── PICTOGRAMAS (toggle) ── */
    .picto-area {
      display: flex;
      align-items: stretch;
      justify-content: center;
      border-bottom: 1.5px solid #000;
      flex-shrink: 0;
      overflow: hidden;
    }

    .picto-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      padding: 4px 4px;
      border-right: 1px solid #ddd;
    }

    .picto-item:last-child { border-right: none; }

    .picto-item img {
      width: auto;
      object-fit: contain;
      filter: grayscale(100%) contrast(1.3);
      flex-shrink: 0;
    }

    .picto-item-name {
      font-size: 6px;
      font-weight: 800;
      color: #000;
      text-transform: uppercase;
      text-align: center;
      letter-spacing: 0.2px;
      line-height: 1;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* ── RUTA (toggle) ── */
    .ruta {
      display: grid;
      grid-template-columns: 1fr 28px 1fr;
      align-items: center;
      background: #111;
      color: white;
      padding: 6px 10px;
      flex-shrink: 0;
    }

    .ruta-box { text-align: center; }

    .ruta-etiqueta {
      font-size: 7.5px;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 2px;
    }

    .ruta-ciudad {
      font-size: 17px;
      font-weight: 900;
      color: #fff;
      line-height: 1;
    }

    .ruta-estado {
      font-size: 8px;
      color: #fff;
      margin-top: 1px;
    }

    .ruta-flecha {
      font-size: 18px;
      color: #fff;
      text-align: center;
      font-weight: 900;
    }

    /* ── DESTINATARIO ── */
    .destinatario {
      margin: 7px 10px 5px;
      border: 2.5px solid #000;
      border-radius: 3px;
      padding: 6px 9px;
      flex: 1;
      min-height: 80px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .dest-label {
      font-size: 8.5px;
      font-weight: 900;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      border-bottom: 1.5px solid #000;
      padding-bottom: 3px;
      margin-bottom: 4px;
    }

    .dest-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .dest-empresa {
      font-size: 13px;
      font-weight: 900;
      color: #000;
      margin-bottom: 3px;
      line-height: 1.1;
    }

    .dest-direccion {
      font-size: 8.5px;
      color: #000;
      line-height: 1.45;
    }

    .dest-contacto {
      font-size: 8px;
      color: #000;
      margin-top: 4px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    /* ── DETALLES ── */
    .detalles {
      display: flex;
      margin: 0 10px 5px;
      border: 1.5px solid #000;
      border-radius: 3px;
      overflow: hidden;
      flex-shrink: 0;
    }

    .detalle-item {
      flex: 1;
      padding: 5px 7px;
      border-right: 1.5px solid #000;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .detalle-item:last-child { border-right: none; }

    .detalle-etiqueta {
      font-size: 7.5px;
      font-weight: 800;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      margin-bottom: 2px;
      text-align: center;
    }

    .detalle-valor {
      font-size: 10px;
      font-weight: 900;
      color: #000;
      line-height: 1;
      text-align: center;
    }

    .detalle-valor.grande { font-size: 13px; }

    /* ── DESCRIPCIÓN + QR ── */
    .fila-bottom {
      display: flex;
      align-items: stretch;
      margin: 0 10px 5px;
      border: 1.5px solid #000;
      border-radius: 3px;
      overflow: hidden;
      flex-shrink: 0;
    }

    .descripcion-box {
      flex: 1;
      padding: 4px 6px;
      border-right: 1.5px solid #000;
      overflow: hidden;
    }

    .descripcion-etiqueta {
      font-size: 7.5px;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      margin-bottom: 1px;
    }

    .descripcion-texto {
      font-size: 8px;
      color: #000;
      line-height: 1.4;
    }

    .qr-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 5px 8px;
      min-width: 66px;
    }

    .qr-box img { width: 52px; height: 52px; }

    .qr-label {
      font-size: 7px;
      color: #000;
      margin-top: 2px;
      text-align: center;
    }

    /* ── FOOTER ── */
    .footer-etiqueta {
      margin: 0 10px;
      border-top: 1.5px dashed #000;
      padding: 3px 0 4px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-shrink: 0;
      margin-top: auto;
    }

    .footer-izq {
      font-size: 6.5px;
      color: #000;
      line-height: 1.5;
    }

    .footer-der {
      font-size: 6px;
      color: #000;
      text-align: right;
      line-height: 1.5;
    }

    /* ── PANEL DE TOGGLES (no se imprime) ── */
    .page-layout { display: flex; gap: 28px; align-items: flex-start; }
    .etiqueta-area { display: flex; flex-direction: column; align-items: center; flex: 1; min-width: 0; }
    .panel-toggles { width: 264px; flex-shrink: 0; position: sticky; top: 56px; }
    .tpl-panel { background: white; border-radius: 14px; padding: 18px 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
    .tpl-panel-hdr { font-size: 0.78rem; font-weight: 800; color: #1e293b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    .tpl-section { font-size: 0.65rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; margin: 12px 0 4px; }
    .tpl-row { display: flex; align-items: center; justify-content: space-between; padding: 5px 0; gap: 8px; }
    .tpl-row-lbl { font-size: 0.8rem; color: #374151; font-weight: 500; line-height: 1.2; }
    .tpl-row-sub { font-size: 0.67rem; color: #94a3b8; }
    .tpl-lock { font-size: 0.58rem; background: #fef3c7; color: #b45309; padding: 1px 4px; border-radius: 3px; font-weight: 700; margin-left: 3px; vertical-align: middle; }
    .tpl-sw { position: relative; width: 38px; height: 20px; flex-shrink: 0; }
    .tpl-sw input { opacity: 0; width: 0; height: 0; }
    .tpl-sl { position: absolute; cursor: pointer; inset: 0; background: #cbd5e1; transition: .25s; border-radius: 20px; }
    .tpl-sl:before { position: absolute; content: ""; height: 14px; width: 14px; left: 3px; bottom: 3px; background: white; transition: .25s; border-radius: 50%; }
    .tpl-sw input:checked + .tpl-sl { background: #3b82f6; }
    .tpl-sw input:checked + .tpl-sl:before { transform: translateX(18px); }
    .tpl-sw input:disabled + .tpl-sl { opacity: 0.55; cursor: not-allowed; }
    .tpl-nota { font-size: 0.7rem; color: #94a3b8; line-height: 1.4; margin-top: 10px; padding-top: 10px; border-top: 1px solid #f1f5f9; }

    /* Elemento oculto (funciona en pantalla Y al imprimir) */
    .etq-hidden { display: none !important; }

    /* ── BARRA DE ZOOM (no se imprime) ── */
    .zoom-bar {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(15, 23, 42, 0.88);
      backdrop-filter: blur(10px);
      border-radius: 50px;
      padding: 9px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.35);
      z-index: 200;
      user-select: none;
    }
    .zoom-btn {
      background: rgba(255,255,255,0.12);
      border: none;
      color: white;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      font-size: 1.1rem;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s;
      line-height: 1;
    }
    .zoom-btn:hover { background: rgba(255,255,255,0.25); }
    .zoom-slider {
      -webkit-appearance: none;
      appearance: none;
      width: 120px;
      height: 4px;
      border-radius: 4px;
      background: rgba(255,255,255,0.25);
      outline: none;
      cursor: pointer;
    }
    .zoom-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 16px; height: 16px;
      border-radius: 50%;
      background: white;
      cursor: pointer;
      box-shadow: 0 1px 4px rgba(0,0,0,0.4);
    }
    .zoom-pct {
      color: white;
      font-size: 0.78rem;
      font-weight: 700;
      min-width: 36px;
      text-align: center;
    }
    .zoom-reset {
      background: none;
      border: none;
      color: rgba(255,255,255,0.5);
      font-size: 0.75rem;
      cursor: pointer;
      padding: 0 2px;
      transition: color 0.15s;
    }
    .zoom-reset:hover { color: white; }

    /* ── PAN (mano) ── */
    .etiqueta-area { cursor: grab; }
    .etiqueta-area.panning { cursor: grabbing; }

    /* ── PRINT ── */
    @media print {
      body { background: white; padding: 0; }
      .no-print { display: none !important; }
      #etiqueta-canvas { zoom: 1 !important; }
      .etiqueta { box-shadow: none; margin: 0; border-radius: 0; }
    }
  </style>
</head>
<body>

  <%
    const cfg = (typeof configuracion !== 'undefined' && configuracion) ? configuracion : {};
    // Toggles individuales — si el campo está vacío, no mostrar aunque el toggle esté activo
    const showLogo              = cfg.mostrar_logo               !== false && !!cfg.logo_bw_url;
    const showNombre            = true; // nombre siempre visible en cabecera
    const showEslogan           = cfg.mostrar_eslogan            !== false && !!cfg.eslogan;
    const showTelefono          = cfg.mostrar_telefono           !== false && !!cfg.telefono;
    const showTelefonoAdicional = cfg.mostrar_telefono_adicional !== false && !!cfg.telefono_adicional;
    const showEmail             = cfg.mostrar_email              !== false && !!cfg.email;
    const showSitioWeb          = cfg.mostrar_sitio_web          !== false && !!cfg.sitio_web;
    const showRfc               = cfg.mostrar_rfc                !== false && !!cfg.rfc;
    const showDireccionFiscal   = cfg.mostrar_direccion_fiscal   !== false && !!cfg.direccion;
    const showBarcode           = cfg.mostrar_barcode            !== false;
    const showQr                = cfg.mostrar_qr                 !== false;
    const showRuta              = cfg.mostrar_ruta               !== false;
    const showDesc              = cfg.mostrar_descripcion        !== false;
    const showDestContacto      = cfg.mostrar_dest_contacto      !== false;
    const showDestTelefono      = cfg.mostrar_dest_telefono      !== false;
    const showDestNombre        = cfg.mostrar_dest_nombre        !== false;
    const showDestDireccion     = cfg.mostrar_dest_direccion     !== false;
    const showDestReferencia    = cfg.mostrar_dest_referencia    !== false;
    // Textos editables del template (con fallback a los valores por defecto)
    const txtEntregarA       = cfg.texto_entregar_a       || 'Entregar a:';
    const txtPeso            = cfg.texto_peso            || 'Peso';
    const txtEntregaEst      = cfg.texto_entrega_estimada || 'Entrega estimada';
    const txtRefCliente      = cfg.texto_ref_cliente      || 'Ref. cliente';
    const txtDescripcion     = cfg.texto_descripcion      || 'Descripción / Contenido';
    const txtFechaEmision    = cfg.texto_fecha_emision    || 'Fecha emisión';
    const txtEtiqueta        = cfg.texto_etiqueta         || 'Etiqueta';
    // Barra de contacto visible si al menos un dato de contacto está activo
    const showContactoBar       = showTelefono || showTelefonoAdicional || showEmail || showSitioWeb;
    const hasPicto              = typeof pictogramas !== 'undefined' && pictogramas.length > 0;
    const showPicto             = hasPicto; // default visible si hay pictogramas
    // Tamaños de texto desde template (con fallback al default CSS)
    const szTracking       = cfg.size_tracking       ? cfg.size_tracking + 'px'       : '26px';
    const szRutaCiudad     = cfg.size_ruta_ciudad    ? cfg.size_ruta_ciudad + 'px'    : '17px';
    const szEmpresaNombre  = cfg.size_empresa_nombre ? cfg.size_empresa_nombre + 'px' : '13px';
    const szDestNombre     = cfg.size_dest_nombre    ? cfg.size_dest_nombre + 'px'    : '13px';
    const szDestDireccion  = cfg.size_dest_direccion ? cfg.size_dest_direccion + 'px' : '8.5px';
    const szEslogan          = cfg.size_eslogan          ? cfg.size_eslogan + 'px'          : '6.5px';
    const szTipoServicio     = cfg.size_tipo_servicio    ? cfg.size_tipo_servicio + 'px'    : '12px';
    const szDetalleValor     = cfg.size_detalle_valor    ? cfg.size_detalle_valor + 'px'    : '10px';
    const szDescripcion      = cfg.size_descripcion      ? cfg.size_descripcion + 'px'      : '8px';
    const szDestContacto     = cfg.size_dest_contacto    ? cfg.size_dest_contacto + 'px'    : '8px';
    const szBarraContacto    = cfg.size_barra_contacto   ? cfg.size_barra_contacto + 'px'   : '7px';
    const szRutaEtiqueta     = cfg.size_ruta_etiqueta    ? cfg.size_ruta_etiqueta + 'px'    : '7.5px';
    const szDetalleEtiqueta  = cfg.size_detalle_etiqueta ? cfg.size_detalle_etiqueta + 'px' : '7.5px';
    const szCabFecha         = cfg.size_cab_fecha        ? cfg.size_cab_fecha + 'px'        : '13px';
    const szCabNum           = cfg.size_cab_num          ? cfg.size_cab_num + 'px'          : '17px';

    // Escalar imagen de pictograma según cantidad — disposición vertical en columna izquierda
    const pictoCount = hasPicto ? pictogramas.length : 0;
    const pictoImgH  = pictoCount <= 1 ? 52 : pictoCount <= 2 ? 40 : pictoCount <= 3 ? 30 : 22;
    const cantidadEtiquetas     = typeof cantidad !== 'undefined' ? parseInt(cantidad) : 1;
    const qrBase                = typeof baseUrl !== 'undefined' ? baseUrl : 'https://portal.transportesab.com';
    // Expandir items en unidades individuales
    const unidades = [];
    if (typeof items !== 'undefined' && items && items.length > 0) {
      items.forEach(function(it) {
        const cant = parseInt(it.cantidad) || 1;
        for (let u = 0; u < cant; u++) {
          unidades.push({ tipo: it.tipo, descripcion: it.descripcion });
        }
      });
    }
    const totalUnidades = unidades.length > 0 ? unidades.length : cantidadEtiquetas;
  %>

  <!-- BARRA DE PREVIEW (no se imprime) -->
  <div class="preview-bar no-print">
    <div class="preview-bar-left">
      <a href="/envios/<%= envio.id %>" class="btn-back">← Volver al detalle</a>
      <span class="toolbar-title">Etiqueta de Envío</span>
      <span class="toolbar-tracking"><%= envio.numero_tracking %> &nbsp;•&nbsp; <%= totalUnidades %> etiqueta(s) &nbsp;•&nbsp; 4 × 6 pulgadas</span>
    </div>
    <button onclick="imprimirEtiqueta()" class="btn-print">🖨️ Imprimir</button>
  </div>

  <!-- ── LAYOUT: etiquetas + panel ── -->
  <div class="page-layout">
  <div class="etiqueta-area">
  <div id="etiqueta-canvas">

  <!-- ── LOOP POR UNIDADES ── -->
  <% for (let i = 1; i <= totalUnidades; i++) {
     const unidadActual = unidades[i-1] || null;
  %>

  <div class="etiqueta">

    <!-- ══ CABECERA ══ -->
    <div class="cab">

      <!-- Empresa / logo -->
      <div class="cab-logo">
        <% if (cfg.logo_bw_url) { %>
          <img src="<%= cfg.logo_bw_url %>"
               alt="Logo"
               data-elem="logo"
               class="<%= !showLogo ? 'etq-hidden' : '' %>">
        <% } %>
        <div class="cab-logo-nombre" style="font-size:<%= szEmpresaNombre %>;"><%= cfg.nombre_empresa || 'TRANSPORTES AB' %></div>
        <div class="cab-logo-eslogan" data-elem="eslogan" class="<%= !showEslogan ? 'etq-hidden' : '' %>" style="font-size:<%= szEslogan %>;"><%= cfg.eslogan %></div>
      </div>

      <!-- Fecha -->
      <div class="cab-fecha">
        <div class="cab-fecha-label"><%= txtFechaEmision %></div>
        <div class="cab-fecha-val" style="font-size:<%= szCabFecha %>;">
          <%= new Date(envio.fecha_creacion).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: '2-digit' }) %>
        </div>
      </div>

      <!-- Número de etiqueta -->
      <div class="cab-num">
        <div class="cab-num-label"><%= txtEtiqueta %></div>
        <div class="cab-num-val" style="font-size:<%= szCabNum %>;"><%= i %>/<%= totalUnidades %></div>
      </div>

    </div>

    <!-- ══ CONTACTO (toggles individuales) ══ -->
    <div class="barra-contacto <%= !showContactoBar ? 'etq-hidden' : '' %>" data-elem="contacto-bar" style="font-size:<%= szBarraContacto %>;">
      <% if (cfg.telefono) { %><span data-contact="telefono" class="<%= !showTelefono ? 'etq-hidden' : '' %>">Tel: <%= cfg.telefono %></span><% } %>
      <% if (cfg.telefono_adicional) { %><span data-contact="telefono_adicional" class="<%= !showTelefonoAdicional ? 'etq-hidden' : '' %>"><%= cfg.telefono_adicional %></span><% } %>
      <% if (cfg.email) { %><span data-contact="email" class="<%= !showEmail ? 'etq-hidden' : '' %>"><%= cfg.email %></span><% } %>
      <% if (cfg.sitio_web) { %><span data-contact="sitio_web" class="<%= !showSitioWeb ? 'etq-hidden' : '' %>"><%= cfg.sitio_web.replace(/https?:\/\/(www\.)?/,'') %></span><% } %>
    </div>

    <!-- ══ TRACKING + BARCODE (con columna de pictogramas si aplica) ══ -->
    <% if (hasPicto) { %>
    <%   const parteLabel2 = envio.es_parcial ? '1' : (envio.numero_parte || '?'); %>
    <div class="<%= !showPicto ? '' : '' %>" data-elem="picto-wrap"
         style="display:flex;flex-shrink:0;border-bottom:1.5px solid #000;">

      <!-- COL IZQUIERDA: Pictogramas -->
      <div class="picto-area <%= !showPicto ? 'etq-hidden' : '' %>" data-elem="picto"
           style="width:38%;border-right:2px solid #000;border-bottom:none;flex-direction:column;justify-content:center;gap:4px;padding:6px 4px;">
        <% pictogramas.forEach(function(p) { %>
        <div class="picto-item" style="border-right:none;border-bottom:none;flex:0 0 auto;width:100%;">
          <img src="<%= p.imagen_url %>" alt="<%= p.nombre %>" title="<%= p.nombre %>"
               style="height:<%= pictoImgH %>px;">
        </div>
        <% }); %>
      </div>

      <!-- COL DERECHA: Tracking + Barcode -->
      <div style="flex:1;display:flex;flex-direction:column;">
        <div class="tracking-section" style="border-bottom:1.5px solid #000;flex:1;">
          <% if (unidadActual) { %>
            <div style="text-align:center;margin-bottom:4px;">
              <span class="tipo-badge" style="font-size:<%= szTipoServicio %>;"><%= unidadActual.tipo %><% if (unidadActual.descripcion) { %> — <%= unidadActual.descripcion %><% } %></span>
            </div>
          <% } %>
          <% if (envio.es_parcial || envio.es_complemento) { %>
            <div style="text-align:center;margin-bottom:3px;">
              <span class="sello-parcial">★ PARTE <%= parteLabel2 %> ★</span>
            </div>
          <% } %>
          <div class="tracking-label">N° de Rastreo</div>
          <div class="tracking-numero" style="font-size:<%= szTracking %>;"><%= envio.numero_tracking %></div>
        </div>
        <div class="barcode-wrap <%= !showBarcode ? 'etq-hidden' : '' %>" data-elem="barcode" style="border-bottom:none;">
          <svg id="barcode-<%= i %>"></svg>
        </div>
      </div>

    </div>
    <% } else { %>

    <!-- Sin pictogramas: layout normal full-width -->
    <div class="tracking-section">
      <% if (unidadActual) { %>
        <div style="text-align:center;margin-bottom:4px;">
          <span class="tipo-badge"><%= unidadActual.tipo %><% if (unidadActual.descripcion) { %> — <%= unidadActual.descripcion %><% } %></span>
        </div>
      <% } %>
      <% if (envio.es_parcial || envio.es_complemento) { %>
        <% const parteLabel = envio.es_parcial ? '1' : (envio.numero_parte || '?'); %>
        <div style="text-align:center;margin-bottom:3px;">
          <span class="sello-parcial">★ PARTE <%= parteLabel %> ★</span>
        </div>
      <% } %>
      <div class="tracking-label">N° de Rastreo</div>
      <div class="tracking-numero" style="font-size:<%= szTracking %>;"><%= envio.numero_tracking %></div>
    </div>

    <div class="barcode-wrap <%= !showBarcode ? 'etq-hidden' : '' %>" data-elem="barcode">
      <svg id="barcode-<%= i %>"></svg>
    </div>

    <% } %>

    <!-- ══ RUTA (toggle) ══ -->
    <div class="ruta <%= !showRuta ? 'etq-hidden' : '' %>" data-elem="ruta">
      <div class="ruta-box">
        <div class="ruta-etiqueta" style="font-size:<%= szRutaEtiqueta %>;">Origen</div>
        <div class="ruta-ciudad" style="font-size:<%= szRutaCiudad %>;"><%= (envio.origen_ciudad || envio.origen.split(',')[0]).toUpperCase() %></div>
        <% if (envio.origen_estado) { %><div class="ruta-estado"><%= envio.origen_estado %></div><% } %>
      </div>
      <div class="ruta-flecha">→</div>
      <div class="ruta-box">
        <div class="ruta-etiqueta" style="font-size:<%= szRutaEtiqueta %>;">Destino</div>
        <div class="ruta-ciudad" style="font-size:<%= szRutaCiudad %>;"><%= (envio.destino_ciudad || envio.destino.split(',')[0]).toUpperCase() %></div>
        <% if (envio.destino_estado) { %><div class="ruta-estado"><%= envio.destino_estado %></div><% } %>
      </div>
    </div>

    <!-- ══ DESTINATARIO ══ -->
    <div class="destinatario">
      <div class="dest-label"><%= txtEntregarA %></div>
      <div class="dest-info">
        <div class="dest-empresa <%= !showDestNombre ? 'etq-hidden' : '' %>" data-elem="dest-nombre" style="font-size:<%= szDestNombre %>;"><%= envio.nombre_empresa || 'Cliente Final' %></div>
        <div class="dest-direccion <%= !showDestDireccion ? 'etq-hidden' : '' %>" data-elem="dest-direccion" style="font-size:<%= szDestDireccion %>;">
          <% if (envio.destino_calle) { %>
            <%= envio.destino_calle %><% if (envio.destino_colonia) { %>, Col. <%= envio.destino_colonia %><% } %><br>
            CP <%= envio.destino_cp || '' %>&nbsp; <%= envio.destino_ciudad || '' %>, <%= envio.destino_estado || '' %>
          <% } else { %>
            <%= envio.destino %>
          <% } %>
          <% if (envio.destino_referencia) { %>
            <span data-elem="dest-referencia" class="<%= !showDestReferencia ? 'etq-hidden' : '' %>" style="display:block;font-size:7.5px;color:#000;">Ref: <%= envio.destino_referencia %></span>
          <% } %>
        </div>
        <% if (envio.contacto || envio.telefono) { %>
        <div class="dest-contacto" style="font-size:<%= szDestContacto %>;">
          <% if (envio.contacto) { %><span data-elem="dest-contacto" class="<%= !showDestContacto ? 'etq-hidden' : '' %>"><%= envio.contacto %></span><% } %>
          <% if (envio.telefono) { %><span data-elem="dest-telefono" class="<%= !showDestTelefono ? 'etq-hidden' : '' %>">Tel: <%= envio.telefono %></span><% } %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- ══ DETALLES DEL PAQUETE ══ -->
    <div class="detalles">
      <div class="detalle-item">
        <div class="detalle-etiqueta" style="font-size:<%= szDetalleEtiqueta %>;"><%= txtPeso %></div>
        <div class="detalle-valor grande" style="font-size:<%= szDetalleValor %>;"><%= envio.peso || '—' %> <span style="font-size:7px;font-weight:600;">kg</span></div>
      </div>
      <div class="detalle-item">
        <div class="detalle-etiqueta" style="font-size:<%= szDetalleEtiqueta %>;"><%= txtEntregaEst %></div>
        <div class="detalle-valor" style="font-size:<%= szDetalleValor %>;">
          <% if (envio.fecha_estimada_entrega) { %>
            <%= new Date(envio.fecha_estimada_entrega).toLocaleDateString('es-MX',{day:'2-digit',month:'short',year:'2-digit'}) %>
          <% } else { %> — <% } %>
        </div>
      </div>
      <div class="detalle-item">
        <div class="detalle-etiqueta" style="font-size:<%= szDetalleEtiqueta %>;"><%= txtRefCliente %></div>
        <div class="detalle-valor" style="font-size:<%= szDetalleValor %>;font-weight:900;line-height:1.2;text-align:center;"><%= envio.referencia_cliente || '—' %></div>
      </div>
    </div>

    <!-- ══ DESCRIPCIÓN + QR (toggles) ══ -->
    <div class="fila-bottom <%= (!showDesc && !showQr) ? 'etq-hidden' : '' %>" data-elem="fila-bottom">
      <div class="descripcion-box <%= !showDesc ? 'etq-hidden' : '' %>" data-elem="descripcion">
        <div class="descripcion-etiqueta"><%= txtDescripcion %></div>
        <% if (typeof items !== 'undefined' && items && items.length > 0) { %>
          <% let _eTotPeso = 0; %>
          <table style="width:100%;border-collapse:collapse;font-size:7px;line-height:1.3;">
            <thead><tr>
              <th style="background:#222;color:#fff;font-size:6px;font-weight:700;text-transform:uppercase;padding:2px 3px;text-align:center;width:22px;">Cant.</th>
              <th style="background:#222;color:#fff;font-size:6px;font-weight:700;text-transform:uppercase;padding:2px 3px;">Tipo</th>
              <th style="background:#222;color:#fff;font-size:6px;font-weight:700;text-transform:uppercase;padding:2px 3px;">Descripción</th>
              <th style="background:#222;color:#fff;font-size:6px;font-weight:700;text-transform:uppercase;padding:2px 3px;text-align:right;width:30px;">kg</th>
            </tr></thead>
            <tbody>
              <% items.forEach(function(it) { _eTotPeso += parseFloat(it.peso)||0; %>
              <tr>
                <td style="padding:1.5px 3px;border-bottom:1px solid #ccc;font-size:7px;text-align:center;"><%= it.cantidad %></td>
                <td style="padding:1.5px 3px;border-bottom:1px solid #ccc;font-size:7px;font-weight:700;"><%= it.tipo %></td>
                <td style="padding:1.5px 3px;border-bottom:1px solid #ccc;font-size:7px;color:#000;"><%= it.descripcion || '' %></td>
                <td style="padding:1.5px 3px;border-bottom:1px solid #ccc;font-size:7px;text-align:right;"><%= parseFloat(it.peso).toFixed(2) %></td>
              </tr>
              <% }); %>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="3" style="padding:2px 3px;font-size:7px;font-weight:700;text-align:right;background:#ddd;border-top:1px solid #000;">Total</td>
                <td style="padding:2px 3px;font-size:7px;font-weight:700;text-align:right;background:#ddd;border-top:1px solid #000;"><%= _eTotPeso.toFixed(2) %></td>
              </tr>
            </tfoot>
          </table>
        <% } else { %>
          <div class="descripcion-texto" style="font-size:<%= szDescripcion %>;"><%= envio.descripcion || 'Manéjese con cuidado' %></div>
        <% } %>
      </div>
      <div class="qr-box <%= !showQr ? 'etq-hidden' : '' %>" data-elem="qr" style="<%= !showDesc && showQr ? 'flex:1;' : '' %>">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=104x104&data=<%= encodeURIComponent(qrBase + '/tracking?numero=' + envio.numero_tracking) %>&color=000000&bgcolor=ffffff&margin=0" alt="QR Tracking">
        <div class="qr-label">Rastrear envío</div>
      </div>
    </div>

    <!-- ══ FOOTER ══ -->
    <div class="footer-etiqueta">
      <div class="footer-izq">
        <% if (cfg.rfc) { %><span data-elem="rfc" class="<%= !showRfc ? 'etq-hidden' : '' %>" style="display:block;"><strong>RFC:</strong> <%= cfg.rfc %></span><% } %>
        <% if (cfg.direccion) { %><span data-elem="direccion_fiscal" class="<%= !showDireccionFiscal ? 'etq-hidden' : '' %>" style="display:block;"><%= cfg.direccion %></span><% } %>
      </div>
      <div class="footer-der">
        <% if (cfg.eslogan) { %><span data-elem="eslogan-footer" class="<%= !showEslogan ? 'etq-hidden' : '' %>" style="display:block;"><em><%= cfg.eslogan %></em></span><% } %>
        <span style="color:#000;">transportesab.com</span>
      </div>
    </div>

  </div><!-- /etiqueta -->

  <% } %><!-- /loop -->

  </div><!-- /etiqueta-canvas -->
  </div><!-- /etiqueta-area -->

  <!-- ── PANEL DE TOGGLES (no se imprime) ── -->
  <div class="panel-toggles no-print">
    <div class="tpl-panel">
      <div class="tpl-panel-hdr">🏷️ Elementos de la Etiqueta</div>
      <p style="font-size:0.72rem;color:#94a3b8;margin-bottom:10px;">Controla qué aparece al imprimir</p>

      <p class="tpl-section">Datos de la empresa</p>

      <% /* Función helper para row del panel */ %>
      <%
        const obligatorio = cfg || {};
        // Helpers para cada fila del panel
        function panelRow(key, icon, label, showVal, hasData, isObl) {
          // Si no hay datos en empresa, deshabilitar aunque template diga true
          const disabled = isObl || !hasData;
          const checked  = showVal && hasData;
          return { key, icon, label, disabled, checked, isObl };
        }
        const panelRows = [
          panelRow('logo',               '🖼️', 'Logo',                showLogo,               !!cfg.logo_bw_url, !!cfg.obligatorio_logo),
          panelRow('eslogan',            '✍️', 'Eslogan / Tagline',   showEslogan,             !!cfg.eslogan,            !!cfg.obligatorio_eslogan),
          panelRow('telefono',           '📞', 'Teléfono principal',  showTelefono,            !!cfg.telefono,           !!cfg.obligatorio_telefono),
          panelRow('telefono_adicional', '📱', 'Teléfono adicional',  showTelefonoAdicional,   !!cfg.telefono_adicional, !!cfg.obligatorio_telefono_adicional),
          panelRow('email',              '✉️', 'Email corporativo',   showEmail,               !!cfg.email,              !!cfg.obligatorio_email),
          panelRow('sitio_web',          '🌐', 'Sitio web',           showSitioWeb,            !!cfg.sitio_web,          !!cfg.obligatorio_sitio_web),
          panelRow('rfc',                '🪪', 'RFC',                  showRfc,                 !!cfg.rfc,                !!cfg.obligatorio_rfc),
          panelRow('direccion_fiscal',   '📍', 'Dirección fiscal',    showDireccionFiscal,     !!cfg.direccion,          !!cfg.obligatorio_direccion_fiscal),
        ];
        const panelRowsEnvio = [
          ...(hasPicto ? [panelRow('picto', '🖼', 'Pictogramas', showPicto, true, false)] : []),
          panelRow('barcode',     '▤',  'Código de barras',        showBarcode, true, !!cfg.obligatorio_barcode),
          panelRow('qr',          '◼',  'Código QR',               showQr,      true, !!cfg.obligatorio_qr),
          panelRow('ruta',        '→',  'Ruta Origen/Destino',     showRuta,    true, !!cfg.obligatorio_ruta),
          panelRow('descripcion',    '📝', 'Descripción del paquete',    showDesc,           true, !!cfg.obligatorio_descripcion),
          panelRow('dest-nombre',     '🏢', 'Nombre destinatario',        showDestNombre,     true,                 !!cfg.obligatorio_dest_nombre),
          panelRow('dest-direccion', '📍', 'Dirección destinatario',     showDestDireccion,  true,                 !!cfg.obligatorio_dest_direccion),
          panelRow('dest-referencia','🔖', 'Referencia destino',         showDestReferencia, !!(envio.destino_referencia), !!cfg.obligatorio_dest_referencia),
          panelRow('dest-contacto',  '👤', 'Contacto destinatario',      showDestContacto,   !!(envio.contacto),   !!cfg.obligatorio_dest_contacto),
          panelRow('dest-telefono',  '📞', 'Teléfono destinatario',      showDestTelefono,   !!(envio.telefono),   !!cfg.obligatorio_dest_telefono),
        ];
      %>

      <% panelRows.forEach(function(r) { %>
      <div class="tpl-row">
        <div>
          <div class="tpl-row-lbl"><%= r.icon %> <%= r.label %><% if (r.isObl) { %><span class="tpl-lock">FIJO</span><% } %></div>
        </div>
        <label class="tpl-sw" title="<%= r.isObl ? 'Obligatorio - no se puede desactivar' : (!r.checked && !r.hasData ? 'Sin datos en Empresa' : '') %>">
          <input type="checkbox" onchange="toggleElem('<%= r.key %>',this.checked)"
            <%= r.checked ? 'checked' : '' %>
            <%= r.disabled ? 'disabled' : '' %>>
          <span class="tpl-sl"></span>
        </label>
      </div>
      <% }) %>

      <p class="tpl-section" style="margin-top:12px;">Elementos del envío</p>

      <% panelRowsEnvio.forEach(function(r) { %>
      <div class="tpl-row">
        <div>
          <div class="tpl-row-lbl"><%= r.icon %> <%= r.label %><% if (r.isObl) { %><span class="tpl-lock">FIJO</span><% } %></div>
        </div>
        <label class="tpl-sw">
          <input type="checkbox" onchange="toggleElem('<%= r.key %>',this.checked)"
            <%= r.checked ? 'checked' : '' %>
            <%= r.disabled ? 'disabled' : '' %>>
          <span class="tpl-sl"></span>
        </label>
      </div>
      <% }) %>

      <p class="tpl-nota">Los campos vacíos no se imprimen aunque el toggle esté activo. Los marcados como <strong>FIJO</strong> siempre se imprimirán.</p>
    </div>
  </div>

  </div><!-- /page-layout -->

  <!-- ── BARRA DE ZOOM (no se imprime) ── -->
  <div class="zoom-bar no-print">
    <button class="zoom-btn" onclick="changeZoom(-0.1)" title="Reducir">−</button>
    <input type="range" id="zoom-slider" class="zoom-slider" min="50" max="250" value="135" step="5" oninput="setZoom(this.value/100)">
    <button class="zoom-btn" onclick="changeZoom(0.1)" title="Ampliar">+</button>
    <span class="zoom-pct" id="zoom-pct">135%</span>
    <button class="zoom-reset" onclick="setZoom(1.35)" title="Restablecer">↺ Reset</button>
  </div>

  <!-- Datos para el script (EJS los renderiza, VS Code no los lintea) -->
  <script id="etiqueta-config" type="application/json">
    {
      "showBarcode": <%= showBarcode ? 'true' : 'false' %>,
      "tracking":    "<%= envio.numero_tracking %>",
      "total":       <%= totalUnidades %>,
      "envioId":     <%= envio.id %>,
      "defaults": {
        "logo":               <%= (showLogo               && !!cfg.logo_url)           ? 'true' : 'false' %>,
        "eslogan":            <%= (showEslogan            && !!cfg.eslogan)             ? 'true' : 'false' %>,
        "telefono":           <%= (showTelefono           && !!cfg.telefono)            ? 'true' : 'false' %>,
        "telefono_adicional": <%= (showTelefonoAdicional  && !!cfg.telefono_adicional)  ? 'true' : 'false' %>,
        "email":              <%= (showEmail              && !!cfg.email)               ? 'true' : 'false' %>,
        "sitio_web":          <%= (showSitioWeb           && !!cfg.sitio_web)           ? 'true' : 'false' %>,
        "rfc":                <%= (showRfc                && !!cfg.rfc)                 ? 'true' : 'false' %>,
        "direccion_fiscal":   <%= (showDireccionFiscal    && !!cfg.direccion)           ? 'true' : 'false' %>,
        "barcode":            <%= showBarcode    ? 'true' : 'false' %>,
        "qr":                 <%= showQr        ? 'true' : 'false' %>,
        "ruta":               <%= showRuta      ? 'true' : 'false' %>,
        "descripcion":        <%= showDesc         ? 'true' : 'false' %>,
        "dest_nombre":        <%= showDestNombre     ? 'true' : 'false' %>,
        "dest_direccion":     <%= showDestDireccion  ? 'true' : 'false' %>,
        "dest_referencia":    <%= showDestReferencia ? 'true' : 'false' %>,
        "dest_contacto":      <%= showDestContacto   ? 'true' : 'false' %>,
        "dest_telefono":      <%= showDestTelefono   ? 'true' : 'false' %>
      }
    }
  </script>

  <script>
    // ── ZOOM ──────────────────────────────────────────────
    var _zoom = 1.35;

    function setZoom(v) {
      _zoom = Math.min(2.5, Math.max(0.5, Math.round(v * 20) / 20));
      document.getElementById('etiqueta-canvas').style.zoom = _zoom;
      document.getElementById('zoom-slider').value = Math.round(_zoom * 100);
      document.getElementById('zoom-pct').textContent = Math.round(_zoom * 100) + '%';
    }

    function changeZoom(delta) { setZoom(_zoom + delta); }

    document.addEventListener('DOMContentLoaded', function() {
      var etqCfg = JSON.parse(document.getElementById('etiqueta-config').textContent);

      // Aplicar zoom inicial
      setZoom(1.35);

      if (etqCfg.showBarcode) {
        renderBarcodes();
      }

      // Scroll en el área de la etiqueta → zoom
      var etqArea = document.querySelector('.etiqueta-area');
      etqArea.addEventListener('wheel', function(e) {
        e.preventDefault();
        changeZoom(e.deltaY < 0 ? 0.05 : -0.05);
      }, { passive: false });

      // ── PAN: arrastra la etiqueta con la mano ──────────────
      var _isPanning = false;
      var _panStartX, _panStartY, _panScrollX, _panScrollY;

      etqArea.addEventListener('mousedown', function(e) {
        if (e.button !== 0) return;
        _isPanning = true;
        _panStartX  = e.clientX;
        _panStartY  = e.clientY;
        _panScrollX = window.scrollX;
        _panScrollY = window.scrollY;
        etqArea.classList.add('panning');
        e.preventDefault();
      });

      document.addEventListener('mousemove', function(e) {
        if (!_isPanning) return;
        window.scrollTo(
          _panScrollX - (e.clientX - _panStartX),
          _panScrollY - (e.clientY - _panStartY)
        );
      });

      document.addEventListener('mouseup', function() {
        if (_isPanning) {
          _isPanning = false;
          etqArea.classList.remove('panning');
        }
      });
    });

    function renderBarcodes() {
      var etqCfg = JSON.parse(document.getElementById('etiqueta-config').textContent);
      for (var i = 1; i <= etqCfg.total; i++) {
        try {
          JsBarcode('#barcode-' + i, etqCfg.tracking, {
            format: 'CODE128', width: 1.7, height: 42,
            displayValue: false, margin: 0, background: 'transparent'
          });
        } catch(e) { console.warn('Barcode ' + i + ':', e); }
      }
    }

    var _contactKeys = ['telefono','telefono_adicional','email','sitio_web'];

    // ── DETECCIÓN DE MODIFICACIONES ──────────────────────────
    var _etqCfgGlobal = JSON.parse(document.getElementById('etiqueta-config').textContent);
    var _defaults     = _etqCfgGlobal.defaults;
    var _toggleState  = Object.assign({}, _defaults);

    function imprimirEtiqueta() {
      var modificada = Object.keys(_defaults).some(function(k) {
        return _toggleState[k] !== _defaults[k];
      });
      if (modificada) {
        fetch('/envios/' + _etqCfgGlobal.envioId + '/marcar-etiqueta-modificada', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        }).finally(function() { window.print(); });
      } else {
        window.print();
      }
    }

    function toggleElem(key, visible) {
      _toggleState[key] = visible;
      if (_contactKeys.includes(key)) {
        // Mostrar/ocultar span de contacto individualmente
        document.querySelectorAll('[data-contact="' + key + '"]').forEach(function(el) {
          el.classList.toggle('etq-hidden', !visible);
        });
        // Actualizar visibilidad de la barra de contacto
        var anyContact = _contactKeys.some(function(k) {
          var s = document.querySelector('[data-contact="' + k + '"]');
          return s && !s.classList.contains('etq-hidden');
        });
        document.querySelectorAll('[data-elem="contacto-bar"]').forEach(function(el) {
          el.classList.toggle('etq-hidden', !anyContact);
        });
        return;
      }

      // Elementos en el footer tienen data-elem-footer pero usamos data-elem genérico
      // eslogan aparece en cab-logo (data-elem="eslogan") y footer (data-elem="eslogan-footer")
      if (key === 'eslogan') {
        document.querySelectorAll('[data-elem="eslogan"],[data-elem="eslogan-footer"]').forEach(function(el) {
          el.classList.toggle('etq-hidden', !visible);
        });
        return;
      }

      // descripcion y qr controlan también la fila-bottom contenedora
      if (key === 'descripcion' || key === 'qr') {
        document.querySelectorAll('[data-elem="' + key + '"]').forEach(function(el) {
          el.classList.toggle('etq-hidden', !visible);
        });
        // Si desc oculta y QR visible → QR ocupa todo el ancho (centrado)
        var descVisible = (function() {
          var s = document.querySelector('[data-elem="descripcion"]');
          return s && !s.classList.contains('etq-hidden');
        })();
        var qrVisible = (function() {
          var s = document.querySelector('[data-elem="qr"]');
          return s && !s.classList.contains('etq-hidden');
        })();
        document.querySelectorAll('[data-elem="qr"]').forEach(function(el) {
          el.style.flex = (!descVisible && qrVisible) ? '1' : '';
        });
        var anyFila = descVisible || qrVisible;
        document.querySelectorAll('[data-elem="fila-bottom"]').forEach(function(el) {
          el.classList.toggle('etq-hidden', !anyFila);
        });
        return;
      }

      // Pictogramas: ocultar columna izquierda (el tracking-wrap pasa a flex normal)
      if (key === 'picto') {
        document.querySelectorAll('[data-elem="picto"]').forEach(function(el) {
          el.classList.toggle('etq-hidden', !visible);
        });
        // Si se ocultan los pictos, el wrapper flex puede quedar con layout raro;
        // simplemente ocultamos la columna y el lado derecho ocupa todo
        document.querySelectorAll('[data-elem="picto-wrap"]').forEach(function(el) {
          // No ocultar el wrapper, solo la columna izquierda ya se ocultó
        });
        return;
      }

      // Toggle genérico
      document.querySelectorAll('[data-elem="' + key + '"]').forEach(function(el) {
        el.classList.toggle('etq-hidden', !visible);
      });

      // Si se activa el barcode, re-renderizar
      if (key === 'barcode' && visible) {
        renderBarcodes();
      }
    }
  </script>

</body>
</html>