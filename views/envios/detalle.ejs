                <div class="info-item">
                  <span class="info-label">Editado Por</span>
                  <span class="info-value"><%= envio.editado_por_nombre %></span>
                </div>
                <% } %>

                <% if (vistaPermisos.actualizadoPor && typeof actualizadoPorNombre !== 'undefined' && actualizadoPorNombre) { %>
                <div class="info-item">
                  <span class="info-label">Actualizado Por</span>
                  <span class="info-value"><%= actualizadoPorNombre %></span>
                </div>
                <% } %>

                <% if (vistaPermisos.reimpPor && typeof reimpPorList !== 'undefined' && reimpPorList && reimpPorList.length > 0) { %>
                <div class="info-item" style="grid-column:1/-1;">
                  <span class="info-label">Impreso desde Portal</span>
                  <div style="display:flex;flex-direction:column;gap:4px;margin-top:2px;">
                    <% reimpPorList.forEach(function(r) { %>
                    <div style="display:flex;align-items:center;gap:8px;">
                      <span class="info-value" style="margin:0;"><%= r.usuario_nombre %></span>
                      <span style="font-size:0.72rem;color:#94a3b8;">
                        <%= new Date(r.ultima_fecha).toLocaleDateString('es-MX', {timeZone:'America/Mexico_City', day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'}) %>
                      </span>
                    </div>
                    <% }); %>
                  </div>
                </div>
                <% } %>
              </div>
              
            </div>

            <!-- CONTENIDO DEL ENVÍO -->
            <div class="info-card">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="package" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Detalle del Contenido
                </h2>
              </div>

              <% if (typeof items !== 'undefined' && items && items.length > 0) { %>
                <% let _totPeso = 0; %>
                <table class="items-detalle">
                  <thead><tr>
                    <th class="c" style="width:70px;">Cant.</th>
                    <th>Tipo</th>
                    <th>Descripción</th>
                    <th style="text-align:right;width:100px;">Peso kg</th>
                  </tr></thead>
                  <tbody>
                    <% items.forEach(it => { _totPeso += parseFloat(it.peso)||0; %>
                    <tr>
                      <td class="c"><%= it.cantidad %></td>
                      <td><strong><%= it.tipo %></strong></td>
                      <td style="color:#6b7280;"><%= it.descripcion || '—' %></td>
                      <td class="r"><%= parseFloat(it.peso).toFixed(2) %></td>
                    </tr>
                    <% }); %>
                  </tbody>
                  <tfoot>
                    <tr class="items-total-row">
                      <td colspan="3" style="text-align:right;padding:9px 14px;">Total aprox.</td>
                      <td class="r" style="padding:9px 14px;"><%= _totPeso.toFixed(2) %> kg</td>
                    </tr>
                  </tfoot>
                </table>
              <% } else if (envio.descripcion) { %>
                <p style="color:#475569;line-height:1.6;margin:0;"><%= envio.descripcion %></p>
              <% } else { %>
                <p style="color:#9ca3af;font-style:italic;margin:0;">Sin detalle de contenido registrado.</p>
              <% } %>
            </div>
            

            <!-- GUÍAS DEL PEDIDO — aparece si es raíz parcial, complemento, o tiene complementos -->
            <% 
              const esRaiz = envio.es_parcial && !envio.es_complemento;
              const esComp = envio.es_complemento;
              const tieneComplementos = guiasRelacionadas && guiasRelacionadas.length > 0;
              const mostrarCard = esRaiz || esComp || tieneComplementos;
            %>
            <% if (mostrarCard) { %>
            <div class="info-card">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="git-branch" style="width: 24px; height: 24px; color: #f59e0b;"></i>
                  Guías del Pedido
                </h2>
                <% if (esRaiz) { %>
                  <span class="badge-parcial-large">
                    <i data-lucide="git-branch" style="width:12px;height:12px;"></i>
                    PARTE 1 — RAÍZ
                  </span>
                <% } else if (esComp) { %>
                  <span class="badge-parcial-large" style="background:#f0fdf4;color:#166534;border-color:#86efac;">
                    <i data-lucide="plus-circle" style="width:12px;height:12px;"></i>
                    PARTE <%= envio.numero_parte || '?' %> — COMPLEMENTO
                  </span>
                <% } %>
              </div>

              <!-- Si es complemento, mostrar la raíz primero -->
              <% if (esComp && guiaOrigen) { %>
                <p style="font-size:12px;color:#6b7280;margin-bottom:8px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;">Guía raíz del pedido</p>
                <div class="guia-relacionada-item" style="border-color:#fcd34d;background:#fffbeb;">
                  <div>
                    <div class="guia-rel-tracking">
                      <span style="font-size:10px;background:#fef3c7;color:#92400e;border:1px solid #fcd34d;border-radius:4px;padding:1px 6px;font-weight:700;margin-right:6px;">PARTE 1</span>
                      <%= guiaOrigen.numero_tracking %>
                    </div>
                    <div class="guia-rel-fecha"><%= new Date(guiaOrigen.fecha_creacion).toLocaleDateString('es-MX', {timeZone:'America/Mexico_City'}) %></div>
                  </div>
                  <div style="display:flex;align-items:center;gap:8px;">
                    <span class="badge badge-<%= guiaOrigen.estado_actual %> guia-rel-badge">
                      <%= guiaOrigen.estado_actual.replace('-',' ').toUpperCase() %>
                    </span>
                    <a href="/envios/<%= guiaOrigen.id %>" class="btn-icon" title="Ver guía raíz">
                      <i data-lucide="eye" style="width:16px;height:16px;"></i>
                    </a>
                  </div>
                </div>
              <% } %>

              <!-- Complementos (visibles desde la raíz o desde cualquier complemento) -->
              <% if (tieneComplementos) { %>
                <p style="font-size:12px;color:#6b7280;margin:10px 0 8px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;">
                  Complementos (<%= guiasRelacionadas.length %>)
                </p>
                <% guiasRelacionadas.forEach(gr => { %>
                <div class="guia-relacionada-item" <% if (gr.id == envio.id) { %>style="border-color:#3b82f6;background:#eff6ff;"<% } %>>
                  <div>
                    <div class="guia-rel-tracking">
                      <span style="font-size:10px;background:#f0fdf4;color:#166534;border:1px solid #86efac;border-radius:4px;padding:1px 6px;font-weight:700;margin-right:6px;">
                        PARTE <%= gr.numero_parte || '?' %>
                      </span>
                      <%= gr.numero_tracking %>
                      <% if (gr.id == envio.id) { %><span style="font-size:11px;color:#3b82f6;font-weight:400;"> (este envío)</span><% } %>
                    </div>
                    <div class="guia-rel-fecha"><%= new Date(gr.fecha_creacion).toLocaleDateString('es-MX', {timeZone:'America/Mexico_City'}) %></div>
                  </div>
                  <div style="display:flex;align-items:center;gap:8px;">
                    <span class="badge badge-<%= gr.estado_actual %> guia-rel-badge">
                      <%= gr.estado_actual.replace('-',' ').toUpperCase() %>
                    </span>
                    <% if (gr.id != envio.id) { %>
                    <a href="/envios/<%= gr.id %>" class="btn-icon" title="Ver complemento">
                      <i data-lucide="eye" style="width:16px;height:16px;"></i>
                    </a>
                    <% } %>
                  </div>
                </div>
                <% }); %>
              <% } %>

              <% if (esRaiz && !tieneComplementos) { %>
                <p style="color:#9ca3af;font-style:italic;margin:0;font-size:13px;">
                  Aún no se han creado complementos para este pedido.
                </p>
              <% } %>
            </div>
            <% } %>
            <!-- HISTORIAL -->
            <div class="info-card">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="clock" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Historial de Estados
                </h2>
              </div>
              
              <div class="timeline">
                <% if (historial && historial.length > 0) { %>
                  <% historial.forEach((item, index) => { 
                    // Determinar icono según estado
                    let iconoEstado = 'circle';
                    if (item.estado === 'entregado') iconoEstado = 'check-circle';
                    else if (item.estado === 'en-transito') iconoEstado = 'truck';
                    else if (item.estado === 'pendiente') iconoEstado = 'clock';
                    else if (item.estado === 'cancelado') iconoEstado = 'x-circle';
                    else if (item.estado === 'creado') iconoEstado = 'package';
                  %>
                    <div class="timeline-item <%= item.estado === 'entregado' ? 'completed' : '' %>" data-estado="<%= item.estado %>">
                      <div class="timeline-marker">
                        <i data-lucide="<%= iconoEstado %>"></i>
                      </div>
                      <div class="timeline-content">

<div class="timeline-header">
  <div class="timeline-header-left">
    <span class="timeline-estado"><%= item.estado.replace('-', ' ') %></span>
    <span class="timeline-fecha">
      <%= new Date(item.fecha_hora).toLocaleDateString('es-MX', {
        day: '2-digit',
        month: 'short',
        hour: '2-digit',
        minute: '2-digit',
        timeZone: 'America/Mexico_City'
      }) %>
    </span>
  </div>
<% if (user && (user.rol === 'admin' || user.rol === 'superusuario')) { %>
<button
  type="button"
  class="btn-eliminar-estado"
  data-estado-id="<%= item.id %>"
  data-estado-nombre="<%= item.estado %>"
  title="Eliminar este estado"
>
  <i data-lucide="trash-2"></i>
</button>
<% } %>
</div>
                        
                        <div class="timeline-ubicacion">
                          <i data-lucide="map-pin"></i>
                          <%= item.ubicacion || 'Sin ubicación especificada' %>
                        </div>
                        
                        <% if (item.comentarios) { %>
                          <div class="timeline-comentario">
                            <i data-lucide="message-square" style="width: 14px; height: 14px; display: inline; vertical-align: middle; margin-right: 6px;"></i>
                            <%= item.comentarios %>
                          </div>
                        <% } %>
                        
                        <div class="timeline-user">
                          <i data-lucide="user"></i>
                          <%= item.usuario_nombre || 'Sistema' %>
                        </div>
                        
<% if (item.fotos && item.fotos.length > 0) { %>
  <div class="timeline-photos">
    <% item.fotos.forEach(foto => { 
      const esPDF = foto.url_foto && foto.url_foto.toLowerCase().endsWith('.pdf');
    %>
      <div class="photo-item <%= esPDF ? 'pdf' : '' %>" onclick="openPhotoModal('<%= foto.url_foto %>')">
        <% if (esPDF) { %>
          <i data-lucide="file-text"></i>
          <span>Ver PDF</span>
        <% } else { %>
          <img src="<%= foto.url_foto %>" alt="Evidencia">
          <div class="photo-zoom-icon">
            <i data-lucide="zoom-in"></i>
          </div>
        <% } %>
      </div>
    <% }); %>
  </div>
<% } %>
                      </div>
                    </div>
                  <% }); %>
                <% } else { %>
                  <div class="no-history">
                    <i data-lucide="inbox"></i>
                    <p>No hay historial de estados disponible</p>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
          
          <!-- COLUMNA DERECHA -->
          <div>

            <!-- HISTÓRICO DE IMPRESOS -->
            <% if (historialImpresos && ((historialImpresos.guia && historialImpresos.guia.length > 0) || (historialImpresos.etiqueta && historialImpresos.etiqueta.length > 0))) { %>
            <div class="action-card" style="margin-bottom:16px;">
              <h3 class="action-title" style="cursor:pointer;user-select:none;" onclick="toggleHistImpresion(this)">
                <i data-lucide="printer" style="width:20px;height:20px;color:#3b82f6;"></i>
                Histórico de Impresos
                <i data-lucide="chevron-down" style="width:16px;height:16px;margin-left:auto;color:#94a3b8;" id="iconHistImpresion"></i>
              </h3>
              <div id="panelHistImpresion">

                <!-- Versiones de Guía -->
                <% if (historialImpresos.guia && historialImpresos.guia.length > 0) { %>
                <div style="font-size:0.7rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;margin-top:4px;">Guía Expedida</div>
                <% historialImpresos.guia.forEach(function(v) { %>
                <div style="display:flex;align-items:flex-start;gap:10px;padding:7px 0;border-bottom:1px solid #f1f5f9;">
                  <% if (v.activa) { %>
                  <i data-lucide="check-circle-2" style="width:16px;height:16px;color:#22c55e;flex-shrink:0;margin-top:2px;" title="Versión activa"></i>
                  <% } else { %>
                  <i data-lucide="circle" style="width:16px;height:16px;color:#cbd5e1;flex-shrink:0;margin-top:2px;" title="Versión anterior"></i>
                  <% } %>
                  <div style="flex:1;min-width:0;">
                    <div style="font-size:0.77rem;font-weight:<%= v.activa ? '600' : '400' %>;color:<%= v.activa ? '#1e293b' : '#94a3b8' %>;word-break:break-all;">
                      <%= v.nombre %>
                    </div>
                    <% if (user && (user.rol === 'admin' || user.rol === 'superusuario')) { %>
                    <div style="font-size:0.71rem;color:#64748b;margin-top:2px;">
                      Impresa <%= v.veces %> vez<%= v.veces !== 1 ? 'es' : '' %>
                      <% if (v.usuario) { %> · Último: <%= v.usuario %><% } %>
                    </div>
                    <% } %>
                  </div>
                </div>
                <% }); %>
                <% } %>

                <!-- Versiones de Etiqueta -->
                <% if (historialImpresos.etiqueta && historialImpresos.etiqueta.length > 0) { %>
                <div style="font-size:0.7rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;margin-top:10px;">Etiqueta Térmica</div>
                <% historialImpresos.etiqueta.forEach(function(v) { %>
                <div style="display:flex;align-items:flex-start;gap:10px;padding:7px 0;border-bottom:1px solid #f1f5f9;">
                  <% if (v.activa) { %>
                  <i data-lucide="check-circle-2" style="width:16px;height:16px;color:#22c55e;flex-shrink:0;margin-top:2px;" title="Versión activa"></i>
                  <% } else { %>
                  <i data-lucide="circle" style="width:16px;height:16px;color:#cbd5e1;flex-shrink:0;margin-top:2px;" title="Versión anterior"></i>
                  <% } %>
                  <div style="flex:1;min-width:0;">
                    <div style="font-size:0.77rem;font-weight:<%= v.activa ? '600' : '400' %>;color:<%= v.activa ? '#1e293b' : '#94a3b8' %>;word-break:break-all;">
                      <%= v.nombre %>
                    </div>
                    <% if (user && (user.rol === 'admin' || user.rol === 'superusuario')) { %>
                    <div style="font-size:0.71rem;color:#64748b;margin-top:2px;">
                      Impresa <%= v.veces %> vez<%= v.veces !== 1 ? 'es' : '' %>
                      <% if (v.usuario) { %> · Último: <%= v.usuario %><% } %>
                    </div>
                    <% } %>
                  </div>
                </div>
                <% }); %>
                <% } %>

                <!-- Log detallado solo para admin/superusuario -->
                <% if (user && (user.rol === 'admin' || user.rol === 'superusuario') && historialImpresos.log && historialImpresos.log.length > 0) { %>
                <div style="margin-top:10px;border-top:1px solid #f1f5f9;padding-top:8px;">
                  <div style="font-size:0.72rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Registro de impresiones</div>
                  <div style="max-height:140px;overflow-y:auto;">
                    <% historialImpresos.log.forEach(log => { %>
                    <div style="display:flex;align-items:center;gap:8px;padding:4px 0;font-size:0.72rem;color:#64748b;border-bottom:1px solid #f8fafc;">
                      <span style="background:<%= log.tipo === 'guia' ? '#eff6ff' : '#f0fdf4' %>;color:<%= log.tipo === 'guia' ? '#1d4ed8' : '#15803d' %>;padding:1px 6px;border-radius:4px;font-weight:600;flex-shrink:0;font-size:0.68rem;">
                        <%= log.tipo === 'guia' ? 'Guía' : 'Etiqueta' %>
                      </span>
                      <span><%= log.usuario_nombre %></span>
                      <span style="margin-left:auto;white-space:nowrap;">
                        <%= new Date(log.fecha).toLocaleDateString('es-MX', {timeZone:'America/Mexico_City',day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %>
                      </span>
                      <% if (log.tuvo_cambios) { %>
                      <span title="Se detectaron cambios" style="color:#f59e0b;">✦</span>
                      <% } %>
                    </div>
                    <% }); %>
                  </div>
                </div>
                <% } %>
              </div>
            </div>
            <% } %>

            <!-- ACTUALIZAR ESTADO -->
            <% if (vistaPermisos.panelEstado) { %>
            <div class="action-card">
              <h3 class="action-title">
                <i data-lucide="refresh-cw" style="width: 20px; height: 20px; color: #3b82f6;"></i>
                Actualizar Estado
              </h3>
              
              <% if (envio.estado_actual === 'cancelado') { %>
                <!-- BLOQUEADO POR CANCELACIÓN -->
                <div class="alert-warning">
                  <i data-lucide="x-circle" style="width: 20px; height: 20px;"></i>
                  <div>
                    <strong>Envío cancelado</strong>
                    <p style="margin-top: 4px; font-size: 0.85rem; font-weight: 500;">No se pueden realizar más actualizaciones en envíos cancelados.</p>
                  </div>
                </div>
              <% } else if (envio.estado_actual === 'entregado') { %>
                <!-- BLOQUEADO POR ENTREGA -->
                <div class="alert-info">
                  <i data-lucide="check-circle" style="width: 20px; height: 20px;"></i>
                  <div>
                    <strong>Envío entregado</strong>
                    <p style="margin-top: 4px; font-size: 0.85rem; font-weight: 500;">El envío ya fue entregado exitosamente.</p>
                  </div>
                </div>
              <% } else { %>
                <!-- FORMULARIO ACTIVO -->
                <form id="formActualizarEstado">
                  <div class="form-group">
                    <label class="form-label">Nuevo Estado</label>
                    <select name="nuevo_estado" class="form-select" required>
                      <option value="">Seleccionar...</option>
                      <option value="creado">Creado</option>
                      <option value="pendiente">Pendiente</option>
                      <option value="en-transito">En Tránsito</option>
                      <option value="entregado">Entregado</option>
                      <option value="cancelado">Cancelado</option>
                    </select>
                  </div>
                  
                  <div class="form-group">
                    <label class="form-label">Ubicación</label>
                    <input type="text" name="ubicacion" class="form-input" placeholder="Ciudad, Estado" required>
                  </div>
                  
                  <% if (vistaPermisos.comentarioEstado) { %>
                  <div class="form-group">
                    <label class="form-label">Comentarios</label>
                    <textarea name="comentarios" class="form-textarea" placeholder="Información adicional..."></textarea>
                  </div>
                  <% } %>
                  
                  <button type="submit" class="btn btn-primary">
                    <i data-lucide="check" style="width: 18px; height: 18px;"></i>
                    Actualizar
                  </button>
                </form>
              <% } %>
            </div>
            <% } %>

            <!-- SUBIR EVIDENCIA -->
            <% if (vistaPermisos.panelEvidencia) { %>
            <div class="action-card">
              <h3 class="action-title">
                <i data-lucide="camera" style="width: 20px; height: 20px; color: #3b82f6;"></i>
                Subir Evidencia
              </h3>
              
              <% if (historial && historial.length > 0) { %>
                <form id="formSubirFoto" enctype="multipart/form-data">
                  
                  <!-- SELECTOR DE ESTADO -->
                  <div class="form-group">
                    <label class="form-label">Estado al que pertenece la evidencia</label>
                    <select name="historial_estado_id" id="historialEstadoSelect" class="form-select" required>
                      <option value="">Selecciona el estado...</option>
                      <% historial.forEach((item, index) => { %>
                        <option value="<%= item.id %>" <%= index === 0 ? 'selected' : '' %>>
                          <%= item.estado.replace('-', ' ').toUpperCase() %> 
                          - <%= new Date(item.fecha_hora).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', timeZone: 'America/Mexico_City' }) %>
                          <% if (item.ubicacion) { %> (<%= item.ubicacion %>)<% } %>
                        </option>
                      <% }); %>
                    </select>
                    <p class="form-help">
                      <i data-lucide="info" style="width: 12px; height: 12px; display: inline; vertical-align: middle;"></i>
                      Selecciona a qué actualización pertenecen las fotos
                    </p>
                  </div>
                  
                  <!-- UPLOAD DE ARCHIVOS -->
                  <div class="file-upload">
                    <input 
                      type="file" 
                      name="fotos" 
                      id="fotoInput" 
                      accept="image/*,application/pdf"
                      multiple
                    >
                    <label for="fotoInput" class="file-upload-label">
                      <i data-lucide="upload" style="width: 24px; height: 24px; color: #64748b;"></i>
                      <div>
                        <span style="color: #64748b; font-weight: 600; display: block;">Seleccionar archivos</span>
                        <span style="color: #94a3b8; font-size: 0.8rem;">Máximo 5 archivos (JPG, PNG, PDF)</span>
                      </div>
                    </label>
                  </div>
                  
                  <div id="previewContainer" class="preview-container" style="display: none;"></div>
                  
                  <% if (vistaPermisos.comentarioEvidencia) { %>
                  <div class="form-group">
                    <label class="form-label">Comentario general (opcional)</label>
                    <textarea name="comentario" class="form-textarea" placeholder="Comentario sobre las evidencias..." rows="3"></textarea>
                  </div>
                  <% } %>
                  
                  <div id="uploadStatus" class="upload-status" style="display: none;"></div>
                  
                  <button type="submit" class="btn btn-primary" id="btnSubirFoto" disabled>
                    <i data-lucide="upload" style="width: 18px; height: 18px;"></i>
                    <span id="btnSubirTexto">Subir Evidencias</span>
                  </button>
                </form>
              <% } else { %>
                <div class="alert-info">
                  <i data-lucide="info" style="width: 20px; height: 20px;"></i>
                  <div>
                    <strong>Sin actualizaciones</strong>
                    <p style="margin-top: 4px; font-size: 0.85rem; font-weight: 500;">Primero debes actualizar el estado del envío para poder subir evidencias.</p>
                  </div>
                </div>
              <% } %>
            </div>
            <% } %>

            <!-- ACCIONES RÁPIDAS -->
            <% if (vistaPermisos.accionesRapidas) { %>
            <div class="action-card">
              <h3 class="action-title">
                <i data-lucide="zap" style="width: 20px; height: 20px; color: #3b82f6;"></i>
                Acciones Rápidas
              </h3>
              
              <div class="quick-actions">
                <a href="/envios/<%= envio.id %>/etiqueta" target="_blank" class="btn btn-secondary">
                  <i data-lucide="printer" style="width: 18px; height: 18px;"></i>
                  Imprimir Etiqueta
                </a>
                
                <a href="/tracking/<%= envio.numero_tracking %>" target="_blank" class="btn btn-secondary">
                  <i data-lucide="external-link" style="width: 18px; height: 18px;"></i>
                  Ver Tracking Público
                </a>
                
                <button onclick="copiarTracking()" class="btn btn-secondary">
                  <i data-lucide="copy" style="width: 18px; height: 18px;"></i>
                  Copiar Tracking
                </button>

                <% if (tienePictogramas) { %>
                <a href="/envios/<%= envio.id %>/pictograma-carta" target="_blank" class="btn btn-secondary" style="background:#f0fdf4;color:#16a34a;border-color:#86efac;">
                  <i data-lucide="image" style="width: 18px; height: 18px;"></i>
                  Imprimir Pictograma
                </a>
                <% } %>

                <% if (user && user.rol === 'admin') { %>
                <button onclick="abrirModalEliminarEnvioDetalle()" class="btn" style="background:#fef2f2;color:#ef4444;border-color:#fca5a5;">
                  <i data-lucide="trash-2" style="width:18px;height:18px;"></i>
                  Eliminar Envío
                </button>
                <% } %>
              </div>
            </div>
            <% } %>
          </div>

        </div>
      </div>
    </main>
    
  </div>
  
  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    lucide.createIcons();

    // ── Búsqueda global ──────────────────────────────────
    (function() {
      var si = document.getElementById('searchInput');
      if (!si) return;
      var t;
      si.addEventListener('input', function() {
        clearTimeout(t);
        var v = this.value.trim();
        if (v) t = setTimeout(function() {
          window.location.href = '/envios?buscar=' + encodeURIComponent(v);
        }, 500);
      });
      si.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && this.value.trim()) {
          clearTimeout(t);
          window.location.href = '/envios?buscar=' + encodeURIComponent(this.value.trim());
        }
      });
    })();

    // User Profile Dropdown
    const userProfileBtn = document.getElementById('userProfileBtn');
    const userDropdown = document.getElementById('userDropdown');
    
    if (userProfileBtn && userDropdown) {
      userProfileBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        userProfileBtn.classList.toggle('open');
        userDropdown.classList.toggle('show');
        lucide.createIcons();
      });
      
      document.addEventListener('click', function(e) {
        if (!userProfileBtn.contains(e.target)) {
          userProfileBtn.classList.remove('open');
          userDropdown.classList.remove('show');
        }
      });
      
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          userProfileBtn.classList.remove('open');
          userDropdown.classList.remove('show');
        }
      });
    }
    
    // Actualizar Estado
    document.getElementById('formActualizarEstado')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      
      try {
        const response = await fetch('/envios/<%= envio.id %>/actualizar-estado', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
          alert('Estado actualizado correctamente');
          window.location.reload();
        } else {
          alert('Error: ' + result.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error al actualizar el estado');
      }
    });
    
    // Preview de múltiples fotos
    const fotoInput = document.getElementById('fotoInput');
    const previewContainer = document.getElementById('previewContainer');
    const btnSubirFoto = document.getElementById('btnSubirFoto');
    let selectedFiles = [];
    
    if (fotoInput) {
      fotoInput.addEventListener('change', function(e) {
        const files = Array.from(e.target.files);
        
        // Validar máximo 5 archivos
        if (selectedFiles.length + files.length > 5) {
          alert('Máximo 5 archivos permitidos');
          return;
        }
        
        // Validar tamaño (5MB por archivo)
        for (const file of files) {
          if (file.size > 5 * 1024 * 1024) {
            alert(`El archivo ${file.name} excede el tamaño máximo de 5MB`);
            return;
          }
        }
        
        // Agregar archivos a la lista
        selectedFiles.push(...files);
        updatePreview();
        
        // Habilitar botón
        btnSubirFoto.disabled = selectedFiles.length === 0;
      });
    }
    
    function updatePreview() {
      previewContainer.innerHTML = '';
      
      if (selectedFiles.length === 0) {
        previewContainer.style.display = 'none';
        return;
      }
      
      previewContainer.style.display = 'grid';
      
      selectedFiles.forEach((file, index) => {
        const previewItem = document.createElement('div');
        previewItem.className = 'preview-item';
        
        if (file.type.startsWith('image/')) {
          // Preview de imagen
          const reader = new FileReader();
          reader.onload = function(e) {
            previewItem.innerHTML = `
              <img src="${e.target.result}" alt="Preview">
              <button type="button" class="preview-remove" onclick="removeFile(${index})">
                <i data-lucide="x"></i>
              </button>
            `;
            lucide.createIcons();
          };
          reader.readAsDataURL(file);
        } else if (file.type === 'application/pdf') {
          // Preview de PDF
          previewItem.classList.add('pdf');
          previewItem.innerHTML = `
            <i data-lucide="file-text"></i>
            <span>${file.name}</span>
            <button type="button" class="preview-remove" onclick="removeFile(${index})">
              <i data-lucide="x"></i>
            </button>
          `;
          lucide.createIcons();
        }
        
        previewContainer.appendChild(previewItem);
      });
      
      lucide.createIcons();
    }
    
    function removeFile(index) {
      selectedFiles.splice(index, 1);
      updatePreview();
      
      // Actualizar input file
      const dt = new DataTransfer();
      selectedFiles.forEach(file => dt.items.add(file));
      fotoInput.files = dt.files;
      
      // Deshabilitar botón si no hay archivos
      btnSubirFoto.disabled = selectedFiles.length === 0;
    }
    
    // Subir múltiples fotos
    document.getElementById('formSubirFoto')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const historialId = document.getElementById('historialEstadoSelect')?.value;
      if (!historialId) {
        alert('Selecciona el estado al que pertenecen las evidencias');
        return;
      }
      
      if (selectedFiles.length === 0) {
        alert('Selecciona al menos un archivo');
        return;
      }
      
      const formData = new FormData();
      formData.append('historial_estado_id', historialId);
      formData.append('comentario', document.querySelector('[name="comentario"]').value);
      
      // Agregar todos los archivos
      selectedFiles.forEach(file => {
        formData.append('fotos', file);
      });
      
      // Mostrar estado de carga
      const uploadStatus = document.getElementById('uploadStatus');
      uploadStatus.style.display = 'flex';
      uploadStatus.className = 'upload-status loading';
      uploadStatus.innerHTML = `
        <i data-lucide="loader" style="width: 16px; height: 16px; animation: spin 1s linear infinite;"></i>
        Subiendo ${selectedFiles.length} archivo(s)...
      `;
      lucide.createIcons();
      
      // Deshabilitar botón
      btnSubirFoto.disabled = true;
      document.getElementById('btnSubirTexto').textContent = 'Subiendo...';
      
      try {
        const response = await fetch('/envios/<%= envio.id %>/subir-fotos', {
          method: 'POST',
          body: formData
        });
        
        const result = await response.json();
        
        if (result.success) {
          uploadStatus.className = 'upload-status success';
          uploadStatus.innerHTML = `
            <i data-lucide="check-circle" style="width: 16px; height: 16px;"></i>
            ${result.uploaded} archivo(s) subido(s) correctamente
          `;
          lucide.createIcons();
          
          setTimeout(() => {
            window.location.reload();
          }, 1500);
        } else {
          uploadStatus.className = 'upload-status error';
          uploadStatus.innerHTML = `
            <i data-lucide="alert-circle" style="width: 16px; height: 16px;"></i>
            Error: ${result.message}
          `;
          lucide.createIcons();
          btnSubirFoto.disabled = false;
          document.getElementById('btnSubirTexto').textContent = 'Subir Evidencias';
        }
      } catch (error) {
        console.error('Error:', error);
        uploadStatus.className = 'upload-status error';
        uploadStatus.innerHTML = `
          <i data-lucide="alert-circle" style="width: 16px; height: 16px;"></i>
          Error al subir los archivos
        `;
        lucide.createIcons();
        btnSubirFoto.disabled = false;
        document.getElementById('btnSubirTexto').textContent = 'Subir Evidencias';
      }
    });
    
    // Copiar tracking
    function copiarTracking() {
      const tracking = '<%= envio.numero_tracking %>';
      navigator.clipboard.writeText(tracking).then(() => {
        alert('Número de tracking copiado: ' + tracking);
      });
    }
    
    // Modal de fotos
    function openPhotoModal(url) {
      window.open(url, '_blank');
    }
  </script>
  

<script>
// ============================================
// INICIALIZAR: Asignar eventos a botones
// ============================================
document.addEventListener('DOMContentLoaded', function() {
  // Seleccionar todos los botones de eliminar estado
  const botonesEliminar = document.querySelectorAll('.btn-eliminar-estado');
  
  // Asignar evento click a cada botón
  botonesEliminar.forEach(function(boton) {
    boton.addEventListener('click', function() {
      // Leer los atributos data-* del botón
      const estadoId = this.getAttribute('data-estado-id');
      const nombreEstado = this.getAttribute('data-estado-nombre');
      
      // Llamar a la función de confirmación
      confirmarEliminarEstado(estadoId, nombreEstado);
    });
  });
});

// ============================================
// FUNCIÓN: Confirmar eliminar estado
// ============================================
function confirmarEliminarEstado(estadoId, nombreEstado) {
  // Formatear el nombre del estado (reemplazar guiones por espacios)
  const estadoFormateado = nombreEstado.replace(/-/g, ' ');
  
  // Mostrar confirmación
  const confirmacion = confirm(
    `¿Estás seguro de eliminar el estado "${estadoFormateado}"?\n\n` +
    `Esta acción no se puede deshacer y eliminará:\n` +
    `• El estado del historial\n` +
    `• Las fotos asociadas (si las hay)\n` +
    `• Los comentarios del estado`
  );
  
  if (confirmacion) {
    eliminarEstado(estadoId);
  }
}

// ============================================
// FUNCIÓN: Eliminar estado (AJAX)
// ============================================
async function eliminarEstado(estadoId) {
  // Buscar el botón correspondiente
  const btnEliminar = document.querySelector(`.btn-eliminar-estado[data-estado-id="${estadoId}"]`);
  
  // Mostrar indicador de carga
  if (btnEliminar) {
    btnEliminar.disabled = true;
    btnEliminar.innerHTML = '<i data-lucide="loader"></i>';
    lucide.createIcons();
    
    // Animar el loader
    const loader = btnEliminar.querySelector('i');
    if (loader) {
      loader.style.animation = 'spin 1s linear infinite';
    }
  }
  
  try {
    const response = await fetch(`/historial/${estadoId}/eliminar`, {
      method: 'DELETE',
      headers: {
        'Content-Type': 'application/json'
      }
    });
    
    const data = await response.json();
    
    if (data.success) {
      // Mostrar mensaje de éxito
      alert('✅ Estado eliminado correctamente');
      
      // Recargar la página para actualizar el historial
      window.location.reload();
    } else {
      // Restaurar botón
      if (btnEliminar) {
        btnEliminar.disabled = false;
        btnEliminar.innerHTML = '<i data-lucide="trash-2"></i>';
        lucide.createIcons();
      }
      
      alert('❌ Error: ' + (data.message || 'No se pudo eliminar el estado'));
    }
  } catch (error) {
    console.error('Error al eliminar estado:', error);
    
    // Restaurar botón
    if (btnEliminar) {
      btnEliminar.disabled = false;
      btnEliminar.innerHTML = '<i data-lucide="trash-2"></i>';
      lucide.createIcons();
    }
    
    alert('❌ Error al eliminar el estado. Intenta de nuevo.');
  }
}
</script>

<!-- Animación del spinner -->
