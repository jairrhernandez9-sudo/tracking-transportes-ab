<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pictogramas - <%= envio.numero_tracking %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, sans-serif;
      background: #e5e7eb;
    }

    /* ── Barra de controles (solo pantalla) ── */
    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      background: #1f2937;
      color: white;
      padding: 10px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 100;
      gap: 12px;
    }
    .topbar-info { font-size: 13px; opacity: 0.8; }
    .topbar-tracking { font-weight: 900; font-size: 15px; letter-spacing: 1px; }
    .topbar-btns { display: flex; gap: 8px; align-items: center; }

    .btn-print {
      padding: 8px 18px;
      border: none;
      border-radius: 6px;
      font-weight: 800;
      font-size: 13px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }
    .btn-carta   { background: white; color: #1f2937; }
    .btn-termica { background: #2563eb; color: white; }
    .btn-print:hover { opacity: 0.88; }

    .mode-label {
      font-size: 11px;
      color: rgba(255,255,255,0.5);
      border-right: 1px solid rgba(255,255,255,0.15);
      padding-right: 12px;
      margin-right: 4px;
    }

    /* ── Página pantalla ── */
    @media screen {
      body { padding-top: 54px; }
      .page {
        margin: 20px auto;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
        background: white;
      }
    }

    /* ════════════════════════════
       MODO CARTA (letter)
    ════════════════════════════ */
    body.modo-carta .page {
      width: 21.59cm;
      height: 27.94cm;
      padding: 1cm;
      display: grid;
      gap: 0.8cm;
    }
    body.modo-carta .page.count-1 { grid-template-columns: 1fr;     grid-template-rows: 1fr; }
    body.modo-carta .page.count-2 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr; }
    body.modo-carta .page.count-3 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
    body.modo-carta .page.count-4 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }

    body.modo-carta .picto-card {
      border: 3px solid #000;
      border-radius: 8px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 16px;
      position: relative;
    }

    /* ════════════════════════════
       MODO TÉRMICA (4×6)
    ════════════════════════════ */
    body.modo-termica .page {
      width: 4in;
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 0;
    }

    body.modo-termica .picto-card {
      width: 4in;
      height: 6in;
      border: none;
      border-bottom: 2px dashed #ccc;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      page-break-after: always;
      break-after: page;
      flex-shrink: 0;
    }

    body.modo-termica .picto-card:last-child {
      border-bottom: none;
    }

    /* Imagen — tamaño vía JS */
    .picto-card img {
      width: auto;
      object-fit: contain;
      filter: grayscale(100%) contrast(1.3);
    }

    /* Tracking en esquina */
    .card-tracking {
      position: absolute;
      top: 8px;
      right: 10px;
      font-size: 8px;
      color: #9ca3af;
      letter-spacing: 0.5px;
    }

    body.modo-termica .card-tracking {
      font-size: 9px;
      color: #aaa;
    }

    /* ── Print ── */
    @media print {
      .topbar { display: none !important; }
      body    { background: white; padding-top: 0; }
    }

    body.modo-carta  .picto-card { position: relative; }
    body.modo-termica .picto-card { position: relative; }
  </style>
</head>
<body class="modo-carta">

<%
  const count = pictogramas.length;
  const countClass = 'count-' + Math.min(count, 4);
%>

  <!-- Barra de controles -->
  <div class="topbar">
    <div>
      <div class="topbar-tracking"><%= envio.numero_tracking %></div>
      <div class="topbar-info"><%= count %> pictograma<%= count !== 1 ? 's' : '' %></div>
    </div>
    <div class="topbar-btns">
      <span class="mode-label">Imprimir en:</span>
      <button class="btn-print btn-carta"   onclick="imprimir('carta')">🖨 Carta / Oficio</button>
      <button class="btn-print btn-termica" onclick="imprimir('termica')">🏷 Térmica 4×6"</button>
    </div>
  </div>

  <!-- Página -->
  <div class="page <%= countClass %>" id="pagina">
    <% pictogramas.forEach(function(p) { %>
    <div class="picto-card">
      <span class="card-tracking"><%= envio.numero_tracking %></span>
      <img src="<%= p.imagen_url %>" alt="<%= p.nombre %>" id="img-<%= p.id %>">
    </div>
    <% }); %>
  </div>

  <script>
    var count = <%= count %>;

    // Tamaños de imagen según modo y cantidad
    var sizes = {
      carta:   count === 1 ? 320 : count === 2 ? 260 : 180,
      termica: 280
    };

    function aplicarModo(modo) {
      document.body.className = 'modo-' + modo;

      var imgs = document.querySelectorAll('.picto-card img');
      imgs.forEach(function(img) {
        img.style.height = sizes[modo] + 'px';
      });

      // En carta, si son 3 el último ocupa las 2 columnas
      var cards = document.querySelectorAll('.picto-card');
      if (modo === 'carta' && count === 3) {
        cards[2].style.gridColumn = 'span 2';
      } else {
        cards.forEach(function(c) { c.style.gridColumn = ''; });
      }
    }

    var pageStyleEl = document.createElement('style');
    document.head.appendChild(pageStyleEl);

    function imprimir(modo) {
      aplicarModo(modo);
      // Inyectar @page con el tamaño correcto
      if (modo === 'termica') {
        pageStyleEl.textContent = '@page { size: 4in 6in; margin: 0; }';
      } else {
        pageStyleEl.textContent = '@page { size: letter; margin: 0.8cm; }';
      }
      setTimeout(function() { window.print(); }, 120);
    }

    // Inicializar en carta
    aplicarModo('carta');

    // Auto print si viene con ?print=1
    if (new URLSearchParams(window.location.search).get('print') === '1') {
      window.addEventListener('load', function() { imprimir('carta'); });
    }
  </script>

</body>
</html>
