<!-- ESTILOS PARA TABS Y TARJETAS -->
<!-- ============================================ -->
<style>

    /* ── Modal direcciones rediseñado ── */
    .modal-section-title {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .6px; color: #6b7280; margin: 14px 0 8px;
      padding-bottom: 4px; border-bottom: 1px solid #f3f4f6;
    }
    .dir-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 10px; margin-bottom: 4px;
    }
    .dir-grid:empty + .modal-section-title,
    .dir-section-empty { display: none; }
    .pin-btn {
      position: absolute; top: 8px; right: 8px;
      background: none; border: none; cursor: pointer;
      font-size: 15px; opacity: .4; transition: opacity .15s, transform .15s;
      padding: 2px;
    }
    .pin-btn:hover { opacity: 1; transform: scale(1.2); }
    .pin-btn.pinned { opacity: 1; }
    .tarjeta-direccion { position: relative; }
    /* Tabs activos */
.tab-direccion-origen.active,
.tab-direccion-destino.active {
  color: #1e40af !important;
  background: white !important;
  border-bottom-color: #3b82f6 !important;
}

.tab-direccion-destino.active {
  color: #dc2626 !important;
  border-bottom-color: #ef4444 !important;
}

/* Tarjeta de dirección */
.tarjeta-direccion {
  background: white;
  padding: 20px;
  border-radius: 12px;
  border: 2px solid #e5e7eb;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
}

.tarjeta-direccion:hover {
  border-color: #3b82f6;
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
  transform: translateY(-2px);
}

.tarjeta-direccion .badge-predeterminada {
  position: absolute;
  top: 12px;
  right: 12px;
  padding: 4px 10px;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: white;
  border-radius: 6px;
  font-size: 0.7rem;
  font-weight: 700;
}

.tarjeta-direccion .alias {
  font-size: 1.1rem;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
}

