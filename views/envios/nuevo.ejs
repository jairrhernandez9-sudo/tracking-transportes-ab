    </aside>
    
    <!-- MAIN CONTENT -->
    <main class="main-content">
      
      <!-- HEADER -->
      <header class="header">
        <div class="header-left">
          <a href="/envios" class="back-btn" title="Volver">
            <i data-lucide="arrow-left" style="width: 20px; height: 20px;"></i>
          </a>
          <div class="welcome">
            <h1>➕ Crear Nuevo Envío</h1>
            <p>Registra un nuevo envío en el sistema</p>
          </div>
        </div>
      </header>
      
      <div class="form-container">
        
        <!-- Mensaje de error -->
        <% if (error) { %>
          <div class="alert alert-error">
            <i data-lucide="alert-circle" style="width: 20px; height: 20px;"></i>
            <%= error %>
          </div>
        <% } %>
        
        <!-- Info Box -->
        <div class="info-box">
          <i data-lucide="info" style="width: 20px; height: 20px;"></i>
          <div class="info-text">
            <strong>Importante:</strong> El número de tracking se generará automáticamente al crear el envío. Selecciona las ubicaciones de la lista o escríbelas manualmente.
          </div>
        </div>
        
        <!-- FORMULARIO -->
        <form action="/envios/nuevo" method="POST">
          <div class="form-card">
            
            <!-- Sección 1: Información del Cliente -->
            <div class="form-section">
              <h2 class="section-title">
                <i data-lucide="user" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                Información del Cliente
              </h2>
              
              <div class="form-group">
                <label class="form-label required">Cliente</label>
                <select name="cliente_id" class="form-select" required>
                  <option value="">Selecciona un cliente...</option>
                  <%
                    // Mostrar prefijo solo cuando hay nombres duplicados
                    const _nombreCount = {};
                    clientes.forEach(c => { _nombreCount[c.nombre_empresa] = (_nombreCount[c.nombre_empresa] || 0) + 1; });
                    const clienteLabel = c => _nombreCount[c.nombre_empresa] > 1
                      ? c.nombre_empresa + ' (' + c.prefijo_tracking + ')'
                      : c.nombre_empresa;
                  %>
                  <% if (ultimoClienteId && clientes.find(c => c.id == ultimoClienteId)) { %>
                  <optgroup label="⭐ Cliente reciente">
                    <% const clienteReciente = clientes.find(c => c.id == ultimoClienteId); %>
                    <option value="<%= clienteReciente.id %>" selected><%= clienteLabel(clienteReciente) %></option>
                  </optgroup>
                  <optgroup label="Todos los clientes">
                    <% clientes.forEach(cliente => { %>
                      <option value="<%= cliente.id %>"><%= clienteLabel(cliente) %></option>
                    <% }); %>
                  </optgroup>
                  <% } else { %>
                    <% clientes.forEach(cliente => { %>
                      <option value="<%= cliente.id %>"><%= clienteLabel(cliente) %></option>
                    <% }); %>
                  <% } %>
                </select>
                <p class="form-help">Selecciona el cliente al que pertenece este envío</p>
              </div>
              
              <!-- REFERENCIAS DEL CLIENTE (múltiples) -->
              <div class="form-group">
                <label class="form-label">Referencias del Cliente</label>
                <div class="ref-tags-wrapper" id="refTagsWrapper" onclick="document.getElementById('refTagInput').focus()">
                  <div id="refTagsContainer"></div>
                  <input
                    type="text"
                    id="refTagInput"
                    class="ref-tag-input"
                    placeholder="Ej: PO-2024-001 y presiona Enter"
                    maxlength="100"
                    onkeydown="refTagKeydown(event)"
                  >
                </div>
                <input type="hidden" name="referencia_cliente" id="refTagHidden" value="">
                <p class="ref-add-hint">
                  <i data-lucide="corner-down-left" style="width:11px;height:11px;display:inline;vertical-align:middle;"></i>
                  Presiona <strong>Enter</strong> o <strong>,</strong> para agregar cada referencia
                </p>
              </div>

              <!-- ── GUÍA PARCIAL ── -->
              <div class="form-group" style="margin-top:4px;">
                <label class="parcial-toggle-row" id="parcialToggleRow" for="esParcialCheck">
                  <input type="checkbox" id="esParcialCheck" onchange="toggleParcial()">
                  <div class="parcial-toggle-track" id="parcialTrack"></div>
                  <div>
                    <div class="parcial-toggle-label">
                      <i data-lucide="git-branch" style="width:14px;height:14px;display:inline;vertical-align:middle;margin-right:4px;"></i>
                      ¿Envío en partes?
                    </div>
                    <div class="parcial-toggle-sublabel">Activa si este pedido se enviará en múltiples guías</div>
                  </div>
                </label>

                <!-- Selector de tipo: Guía raíz o Complemento -->
                <div class="parcial-tipo-selector" id="parcialTipoSelector">
                  <div class="parcial-tipo-btn selected" id="btnTipoRaiz" onclick="seleccionarTipo('raiz')">
                    <div class="ptb-icon">📦</div>
                    <div class="ptb-title">Primera parte</div>
                    <div class="ptb-desc">Esta guía inicia el pedido parcial</div>
                  </div>
                  <div class="parcial-tipo-btn" id="btnTipoComplemento" onclick="seleccionarTipo('complemento')">
                    <div class="ptb-icon">➕</div>
                    <div class="ptb-title">Complemento</div>
                    <div class="ptb-desc">Continúa un pedido parcial existente</div>
                  </div>
                </div>

                <!-- Hidden fields -->
                <input type="hidden" name="es_parcial" id="hiddenEsParcial" value="0">
                <input type="hidden" name="es_complemento" id="hiddenEsComplemento" value="0">
                <input type="hidden" name="envio_relacionado_id" id="hiddenEnvioRelacionado" value="">

                <!-- Opciones complemento -->
                <div class="parcial-options" id="parcialOptions">
                  <div class="form-group" style="margin-bottom:10px;">
                    <label class="form-label" style="color:#92400e;">Guía raíz del pedido</label>
                    <select id="envioRelacionadoSelect" class="form-select" onchange="onGuiaOrigenChange()">
                      <option value="">Seleccionar guía raíz...</option>
                    </select>
                    <p class="form-help" style="color:#a16207;">
                      Selecciona la primera guía del pedido al que pertenece este complemento
                    </p>
                  </div>
                  <button type="button" class="items-pendientes-btn" id="btnCargarItems"
                          onclick="cargarItemsPendientes()" disabled>
                    <i data-lucide="package" style="width:14px;height:14px;"></i>
                    Cargar ítems de guía raíz
                  </button>
                  <p class="form-help" style="color:#a16207;margin-top:6px;display:none;" id="parcialHelp"></p>
                </div>
              </div>
            </div>
            
            <!-- Sección 2: Detalles del Envío -->
            <div class="form-section">
              <h2 class="section-title">
                <i data-lucide="package" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                Detalles del Envío
              </h2>
              
              <div class="form-group">
                <label class="form-label">
                  <i data-lucide="package" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:4px;"></i>
                  Detalle del Contenido
                </label>
                <div class="items-table-wrapper">
                  <table class="items-table">
                    <thead><tr>
                      <th class="td-cant c">Cant.</th>
                      <th class="td-tipo">Tipo</th>
                      <th>Descripción <span style="font-weight:400;opacity:.7;">(opcional)</span></th>
                      <th class="td-peso c">Peso kg</th>
                      <th class="td-del"></th>
                    </tr></thead>
                    <tbody id="itemsTbody"></tbody>
                  </table>
                </div>
                <button type="button" class="btn-add-item" onclick="agregarItem()">
                  <i data-lucide="plus-circle" style="width:16px;height:16px;"></i>
                  Agregar ítem
                </button>
                <div class="items-peso-total">
                  Peso total aprox.:&nbsp;<strong id="pesoTotal">0.00</strong>&nbsp;kg
                </div>
                <input type="hidden" name="peso" id="pesoHidden" value="0">
              </div>
              
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Fecha estimada de entrega</label>
                  <div class="fecha-row">
                    <div class="fecha-input-col">
                      <input
                        type="date"
                        name="fecha_estimada_entrega"
                        id="fechaEntrega"
                        class="form-input"
                      >
                    </div>
                    <div class="fecha-divider"></div>
                    <div class="quick-dates">
                      <button type="button" class="quick-date-btn" data-days="1" onclick="setQuickDate(1)">Mañana</button>
                      <button type="button" class="quick-date-btn" data-days="3" onclick="setQuickDate(3)">3 días</button>
                      <button type="button" class="quick-date-btn" data-days="7" onclick="setQuickDate(7)">1 semana</button>
                      <button type="button" class="quick-date-btn" data-days="14" onclick="setQuickDate(14)">2 semanas</button>
                      <button type="button" class="quick-date-btn hoy-btn" data-days="0" onclick="setQuickDate(0)">⚠ HOY</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Sección 3: Dirección de Origen -->
            <div class="form-section">
              <h2 class="section-title">
                <i data-lucide="map-pin" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                Dirección de Origen
              </h2>

              <div style="display:flex; gap:12px; align-items:center; margin-bottom:4px;">
                <button type="button" id="btnOrigen" onclick="abrirModalOrigen()"
                  style="flex:1; padding:12px 20px; background:linear-gradient(135deg,#3b82f6,#2563eb); color:white; border:none; border-radius:10px; font-size:0.9rem; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:8px; justify-content:center;">
                  <i data-lucide="warehouse" style="width:18px;height:18px;"></i>
                  Seleccionar Dirección Guardada
                </button>
                <button type="button" onclick="limpiarOrigen()"
                  style="padding:12px 16px; background:#f1f5f9; border:1.5px solid #e2e8f0; border-radius:10px; font-size:0.85rem; cursor:pointer; color:#64748b;">
                  <i data-lucide="x" style="width:15px;height:15px;"></i> Limpiar
                </button>
              </div>

              <div class="dir-grid">
                <div class="form-group" style="grid-column:1/-1;">
                  <label class="form-label required">Calle y Número</label>
                  <input type="text" name="origen_calle" class="form-input" required
                    placeholder="Ej: Av. Constitución 123">
                </div>
                <div class="form-group">
                  <label class="form-label required">Colonia</label>
                  <input type="text" name="origen_colonia" class="form-input" required
                    placeholder="Ej: Centro">
                </div>
                <div class="form-group">
                  <label class="form-label required">C.P.</label>
                  <input type="text" name="origen_cp" class="form-input" maxlength="5" pattern="[0-9]{5}" required
                    placeholder="64000">
                </div>
                <div class="form-group">
                  <label class="form-label required">Ciudad</label>
                  <input type="text" name="origen_ciudad" class="form-input" list="ciudades" required
                    placeholder="Escribe la ciudad">
                </div>
                <div class="form-group">
                  <label class="form-label required">Estado</label>
                  <select name="origen_estado" class="form-input" required>
                    <option value="">Selecciona un estado...</option>
                    <option value="Aguascalientes">Aguascalientes</option>
                    <option value="Baja California">Baja California</option>
                    <option value="Baja California Sur">Baja California Sur</option>
                    <option value="Campeche">Campeche</option>
                    <option value="Chiapas">Chiapas</option>
                    <option value="Chihuahua">Chihuahua</option>
                    <option value="Ciudad de México">Ciudad de México</option>
                    <option value="Coahuila">Coahuila</option>
                    <option value="Colima">Colima</option>
                    <option value="Durango">Durango</option>
                    <option value="Guanajuato">Guanajuato</option>
                    <option value="Guerrero">Guerrero</option>
                    <option value="Hidalgo">Hidalgo</option>
                    <option value="Jalisco">Jalisco</option>
                    <option value="México">México</option>
                    <option value="Michoacán">Michoacán</option>
                    <option value="Morelos">Morelos</option>
                    <option value="Nayarit">Nayarit</option>
                    <option value="Nuevo León">Nuevo León</option>
                    <option value="Oaxaca">Oaxaca</option>
                    <option value="Puebla">Puebla</option>
                    <option value="Querétaro">Querétaro</option>
                    <option value="Quintana Roo">Quintana Roo</option>
                    <option value="San Luis Potosí">San Luis Potosí</option>
                    <option value="Sinaloa">Sinaloa</option>
                    <option value="Sonora">Sonora</option>
                    <option value="Tabasco">Tabasco</option>
                    <option value="Tamaulipas">Tamaulipas</option>
                    <option value="Tlaxcala">Tlaxcala</option>
                    <option value="Veracruz">Veracruz</option>
                    <option value="Yucatán">Yucatán</option>
                    <option value="Zacatecas">Zacatecas</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">Referencia</label>
                  <input type="text" name="origen_referencia" class="form-input"
                    placeholder="Ej: Sucursal 30, Edificio azul, Entre calles X y Y">
                </div>
              </div>
            </div>

            <!-- Sección 4: Dirección de Destino -->
            <div class="form-section">
              <h2 class="section-title">
                <i data-lucide="map-pin-off" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                Dirección de Destino
              </h2>

              <div style="display:flex; gap:12px; align-items:center; margin-bottom:4px;">
                <button type="button" id="btnDestino" onclick="abrirModalDestino()"
                  style="flex:1; padding:12px 20px; background:linear-gradient(135deg,#3b82f6,#2563eb); color:white; border:none; border-radius:10px; font-size:0.9rem; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:8px; justify-content:center;">
                  <i data-lucide="map-pin" style="width:18px;height:18px;"></i>
                  Seleccionar Dirección Guardada
                </button>
                <button type="button" onclick="limpiarDestino()"
                  style="padding:12px 16px; background:#f1f5f9; border:1.5px solid #e2e8f0; border-radius:10px; font-size:0.85rem; cursor:pointer; color:#64748b;">
                  <i data-lucide="x" style="width:15px;height:15px;"></i> Limpiar
                </button>
              </div>

              <div class="dir-grid">
                <div class="form-group" style="grid-column:1/-1;">
                  <label class="form-label required">Calle y Número</label>
                  <input type="text" name="destino_calle" class="form-input" required
                    placeholder="Ej: Calle Morelos 456">
                </div>
                <div class="form-group">
                  <label class="form-label required">Colonia</label>
                  <input type="text" name="destino_colonia" class="form-input" required
                    placeholder="Ej: San Jerónimo">
                </div>
                <div class="form-group">
                  <label class="form-label required">C.P.</label>
                  <input type="text" name="destino_cp" class="form-input" maxlength="5" pattern="[0-9]{5}" required
                    placeholder="01000">
                </div>
                <div class="form-group">
                  <label class="form-label required">Ciudad</label>
                  <input type="text" name="destino_ciudad" class="form-input" list="ciudades" required
                    placeholder="Escribe la ciudad">
                </div>
                <div class="form-group">
                  <label class="form-label required">Estado</label>
                  <select name="destino_estado" class="form-input" required>
                    <option value="">Selecciona un estado...</option>
                    <option value="Aguascalientes">Aguascalientes</option>
                    <option value="Baja California">Baja California</option>
                    <option value="Baja California Sur">Baja California Sur</option>
                    <option value="Campeche">Campeche</option>
                    <option value="Chiapas">Chiapas</option>
                    <option value="Chihuahua">Chihuahua</option>
                    <option value="Ciudad de México">Ciudad de México</option>
                    <option value="Coahuila">Coahuila</option>
                    <option value="Colima">Colima</option>
                    <option value="Durango">Durango</option>
                    <option value="Guanajuato">Guanajuato</option>
                    <option value="Guerrero">Guerrero</option>
                    <option value="Hidalgo">Hidalgo</option>
                    <option value="Jalisco">Jalisco</option>
                    <option value="México">México</option>
                    <option value="Michoacán">Michoacán</option>
                    <option value="Morelos">Morelos</option>
                    <option value="Nayarit">Nayarit</option>
                    <option value="Nuevo León">Nuevo León</option>
                    <option value="Oaxaca">Oaxaca</option>
                    <option value="Puebla">Puebla</option>
                    <option value="Querétaro">Querétaro</option>
                    <option value="Quintana Roo">Quintana Roo</option>
                    <option value="San Luis Potosí">San Luis Potosí</option>
                    <option value="Sinaloa">Sinaloa</option>
                    <option value="Sonora">Sonora</option>
                    <option value="Tabasco">Tabasco</option>
                    <option value="Tamaulipas">Tamaulipas</option>
                    <option value="Tlaxcala">Tlaxcala</option>
