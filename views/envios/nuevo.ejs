  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    lucide.createIcons();

    // Función para establecer fechas rápidas
    function setQuickDate(days) {
      const today = new Date();
      today.setDate(today.getDate() + days);

      const year = today.getFullYear();
      const month = String(today.getMonth() + 1).padStart(2, '0');
      const day = String(today.getDate()).padStart(2, '0');

      document.getElementById('fechaEntrega').value = `${year}-${month}-${day}`;

      // Marcar botón activo
      document.querySelectorAll('.quick-date-btn').forEach(b => b.classList.remove('selected'));
      const active = document.querySelector(`.quick-date-btn[data-days="${days}"]`);
      if (active) active.classList.add('selected');
    }

    // Establecer fecha mínima y pre-seleccionar Mañana
    document.addEventListener('DOMContentLoaded', function() {
      const fechaInput = document.getElementById('fechaEntrega');
      if (fechaInput) {
        const today = new Date();
        const year = today.getFullYear();
        const month = String(today.getMonth() + 1).padStart(2, '0');
        const day = String(today.getDate()).padStart(2, '0');
        fechaInput.min = `${year}-${month}-${day}`;
      }
      setQuickDate(1); // Mañana por defecto
    });


        // ============================================
        // VARIABLES GLOBALES
        // ============================================
        let direccionesBodegas = [];
        let direccionesCliente = [];
        let origenSeleccionado = null;
        let destinoSeleccionado = null;

        // ============================================
        // ABRIR/CERRAR MODALES
        // ============================================
        function abrirModalOrigen() {
          document.getElementById('modalDireccionOrigen').classList.add('open');
          const b = document.getElementById('origenBuscador'); if (b) b.value = '';
          cargarDireccionesBodegas('origen');
          const clienteId = document.querySelector('[name="cliente_id"]')?.value;
          if (clienteId) cargarDireccionesClienteModal(clienteId, 'origen');
          cambiarTabOrigen('clientes');
          lucide.createIcons();
        }

        function cerrarModalOrigen() {
          document.getElementById('modalDireccionOrigen').classList.remove('open');
        }

        function abrirModalDestino() {
          document.getElementById('modalDireccionDestino').classList.add('open');
          const b = document.getElementById('destinoBuscador'); if (b) b.value = '';
          cargarDireccionesBodegas('destino');
          const clienteId = document.querySelector('[name="cliente_id"]')?.value;
          if (clienteId) cargarDireccionesClienteModal(clienteId, 'destino');
          cargarDireccionesUniversales();
          cambiarTabDestino('clientes');
          lucide.createIcons();
        }

        function cerrarModalDestino() {
          document.getElementById('modalDireccionDestino').classList.remove('open');
        }

        // Cerrar modales con ESC o click fuera
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            cerrarModalOrigen();
            cerrarModalDestino();
          }
        });

        document.getElementById('modalDireccionOrigen')?.addEventListener('click', function(e) {
          if (e.target === this) cerrarModalOrigen();
        });

        document.getElementById('modalDireccionDestino')?.addEventListener('click', function(e) {
          if (e.target === this) cerrarModalDestino();
        });

        // ============================================
        // CAMBIAR ENTRE TABS
        // ============================================
        function cambiarTabOrigen(tab) {
          // Actualizar botones de tabs
          document.querySelectorAll('.tab-direccion-origen').forEach(btn => {
            btn.classList.remove('active');
            if (btn.dataset.tab === tab) {
              btn.classList.add('active');
            }
          });
          
          // Mostrar/ocultar contenido
          document.querySelectorAll('.tab-content-origen').forEach(content => {
            content.style.display = 'none';
          });
          
          if (tab === 'bodegas') {
            document.getElementById('tabOrigenBodegas').style.display = 'grid';
          } else {
            document.getElementById('tabOrigenClientes').style.display = 'block';
          }
          
          lucide.createIcons();
        }

        function cambiarTabDestino(tab) {
          document.querySelectorAll('.tab-direccion-destino').forEach(btn => {
            btn.classList.remove('active');
            if (btn.dataset.tab === tab) btn.classList.add('active');
          });
          document.querySelectorAll('.tab-content-destino').forEach(content => {
            content.style.display = 'none';
          });
          if (tab === 'bodegas') {
            document.getElementById('tabDestinoBodegas').style.display = 'grid';
          } else if (tab === 'universales') {
            document.getElementById('tabDestinoUniversales').style.display = 'block';
          } else {
            document.getElementById('tabDestinoClientes').style.display = 'block';
          }
          lucide.createIcons();
        }

        // ============================================
        // UTILIDADES FAVORITOS Y RECIENTES (localStorage)
        // ============================================
        const LS_FAV  = 'dir_favoritas';
        const LS_REC  = 'dir_recientes';

        function getFavoritas() {
          try { return JSON.parse(localStorage.getItem(LS_FAV) || '[]'); } catch { return []; }
        }
        function toggleFavorita(key) {
          let favs = getFavoritas();
          if (favs.includes(key)) { favs = favs.filter(k => k !== key); }
          else { favs.push(key); }
          localStorage.setItem(LS_FAV, JSON.stringify(favs));
        }
        function esFavorita(key) { return getFavoritas().includes(key); }

        function getRecientes() {
          try { return JSON.parse(localStorage.getItem(LS_REC) || '[]'); } catch { return []; }
        }
        function agregarReciente(key) {
          let recs = getRecientes().filter(k => k !== key);
          recs.unshift(key);
          localStorage.setItem(LS_REC, JSON.stringify(recs.slice(0, 5)));
        }

        // ============================================
        // RENDER TARJETA DIRECCIÓN
        // ============================================
        function renderTarjeta(dir, tipo, tipoModal) {
          const key = `${tipo}-${dir.id}`;
          const fav = esFavorita(key);
          return `
            <div class="dir-card" onclick="seleccionarDireccion('${tipo}', ${dir.id}, '${tipoModal}')">
              <button class="pin-btn ${fav ? 'pinned' : ''}" title="${fav ? 'Quitar favorito' : 'Añadir a favoritos'}"
                onclick="event.stopPropagation(); toggleFavDir('${key}', '${tipoModal}')">
                ${fav ? '⭐' : '☆'}
              </button>
              <div class="dir-card-alias">${dir.es_predeterminada ? '⭐ ' : ''}${dir.alias}</div>
              <div class="dir-card-addr">${[dir.calle, dir.colonia, dir.ciudad, dir.estado].filter(Boolean).join(', ')}</div>
            </div>`;
        }

        function toggleFavDir(key, tipoModal) {
          toggleFavorita(key);
          renderModalSections(tipoModal);
          lucide.createIcons();
        }

        // ============================================
        // RENDER SECCIONES DEL MODAL
        // ============================================
        function renderModalSections(tipoModal) {
          const query   = document.getElementById(tipoModal + 'Buscador')?.value?.toLowerCase() || '';
          const favKeys = getFavoritas();
          const recKeys = getRecientes();

          // Bodegas
          const bodegas = (direccionesBodegas || []).filter(d =>
            !query || d.alias?.toLowerCase().includes(query) ||
            d.ciudad?.toLowerCase().includes(query) || d.calle?.toLowerCase().includes(query) ||
            d.estado?.toLowerCase().includes(query) || d.colonia?.toLowerCase().includes(query)
          );
          const bodFav  = bodegas.filter(d => favKeys.includes(`bodega-${d.id}`) || d.es_predeterminada);
          const bodRec  = bodegas.filter(d => recKeys.includes(`bodega-${d.id}`) && !bodFav.find(f => f.id === d.id));
          const bodTodos = bodegas.filter(d => !bodFav.find(f => f.id === d.id) && !bodRec.find(r => r.id === d.id));

          const prefix = tipoModal === 'origen' ? 'origen' : 'destino';

          // Render bodegas
          setGrid(`${prefix}FavoritosGrid`,  bodFav,  'bodega', tipoModal);
          setGrid(`${prefix}RecientesGrid`,  bodRec,  'bodega', tipoModal);
          setGrid(`${prefix}TodosGrid`,      bodTodos,'bodega', tipoModal);
          toggleSection(`${prefix}FavoritosSection`,  bodFav.length > 0);
          toggleSection(`${prefix}RecientesSection`,  bodRec.length > 0);
          toggleSection(`${prefix}TodosSection`,      bodTodos.length > 0);

          // Direcciones cliente
          const clDirs = (direccionesCliente || []).filter(d =>
            !query || d.alias?.toLowerCase().includes(query) ||
            d.ciudad?.toLowerCase().includes(query) || d.calle?.toLowerCase().includes(query) ||
            d.estado?.toLowerCase().includes(query) || d.colonia?.toLowerCase().includes(query)
          );
          const clFav   = clDirs.filter(d => favKeys.includes(`cliente-${d.id}`) || d.es_predeterminada);
          const clRec   = clDirs.filter(d => recKeys.includes(`cliente-${d.id}`) && !clFav.find(f => f.id === d.id));
          const clTodos = clDirs.filter(d => !clFav.find(f => f.id === d.id) && !clRec.find(r => r.id === d.id));

          setGrid(`${prefix}ClienteFavGrid`,   clFav,   'cliente', tipoModal);
          setGrid(`${prefix}ClienteRecGrid`,   clRec,   'cliente', tipoModal);
          setGrid(`${prefix}ClienteTodosGrid`, clTodos, 'cliente', tipoModal);
          toggleSection(`${prefix}ClienteFavSection`,   clFav.length > 0);
          toggleSection(`${prefix}ClienteRecSection`,   clRec.length > 0);
          toggleSection(`${prefix}ClienteTodosSection`, clTodos.length > 0);

          // Universales — solo en modal destino
          if (tipoModal === 'destino') {
            const univDirs = (direccionesUniversales || []).filter(d =>
              !query || d.alias?.toLowerCase().includes(query) ||
              d.ciudad?.toLowerCase().includes(query) || d.calle?.toLowerCase().includes(query) ||
              d.estado?.toLowerCase().includes(query) || d.colonia?.toLowerCase().includes(query)
            );
            setGrid('destinoUniversalesGrid', univDirs, 'universal', 'destino');
            toggleSection('destinoUniversalesTodosSection', univDirs.length > 0);
          }
        }

        function setGrid(id, dirs, tipo, tipoModal) {
          const el = document.getElementById(id);
          if (!el) return;
          el.innerHTML = dirs.map(d => renderTarjeta(d, tipo, tipoModal)).join('');
        }

        function toggleSection(id, visible) {
          const el = document.getElementById(id);
          if (el) el.style.display = visible ? '' : 'none';
        }

        function filtrarModal(tipoModal) {
          renderModalSections(tipoModal);
          lucide.createIcons();
        }

        let direccionesUniversales = [];

        // ============================================
        // CARGAR DIRECCIONES UNIVERSALES (destino)
        // ============================================
        async function cargarDireccionesUniversales() {
          try {
            const response = await fetch('/configuracion/api/direcciones?tipo=destino');
            const data = await response.json();
            direccionesUniversales = (data.success && data.direcciones) ? data.direcciones : [];
            renderModalSections('destino');
            lucide.createIcons();
          } catch (error) {
            console.error('Error al cargar direcciones universales:', error);
          }
        }

        // ============================================
        // CARGAR DIRECCIONES DE BODEGAS
        // ============================================
        async function cargarDireccionesBodegas(tipo) {
          try {
            const response = await fetch('/configuracion/api/direcciones');
            const data = await response.json();
            if (data.success && data.direcciones) {
              direccionesBodegas = data.direcciones;
              renderModalSections(tipo);
              lucide.createIcons();
            }
          } catch (error) {
            console.error('Error al cargar direcciones de bodegas:', error);
          }
        }

        // ============================================
        // CARGAR DIRECCIONES DEL CLIENTE
        // ============================================
        async function cargarDireccionesClienteModal(clienteId, tipo) {
          if (!clienteId) {
            direccionesCliente = [];
            renderModalSections(tipo);
            return;
          }
          try {
            const response = await fetch(`/direcciones/cliente/${clienteId}`);
            const data = await response.json();
            direccionesCliente = (data.success && data.direcciones) ? data.direcciones : [];
            renderModalSections(tipo);
            lucide.createIcons();
          } catch (error) {
            console.error('Error al cargar direcciones del cliente:', error);
            direccionesCliente = [];
          }
        }

        // ============================================
        // SELECCIONAR DIRECCIÓN
        // ============================================
        function seleccionarDireccion(tipoDireccion, direccionId, tipoModal) {
          // Buscar la dirección en el array correspondiente
          let direccion;
          if (tipoDireccion === 'bodega') {
            direccion = direccionesBodegas.find(d => d.id === direccionId);
          } else if (tipoDireccion === 'universal') {
            direccion = direccionesUniversales.find(d => d.id === direccionId);
          } else {
            direccion = direccionesCliente.find(d => d.id === direccionId);
          }
          
          if (!direccion) {
            alert('Error al seleccionar la dirección');
            return;
          }
          
          // Determinar prefijo de campos (origen_ o destino_)
          const prefijo = tipoModal === 'origen' ? 'origen' : 'destino';
          
          // Auto-llenar campos
          document.querySelector(`[name="${prefijo}_calle"]`).value = direccion.calle || '';
          document.querySelector(`[name="${prefijo}_colonia"]`).value = direccion.colonia || '';
          document.querySelector(`[name="${prefijo}_cp"]`).value = direccion.cp || '';
          document.querySelector(`[name="${prefijo}_ciudad"]`).value = direccion.ciudad || '';
          document.querySelector(`[name="${prefijo}_estado"]`).value = direccion.estado || '';
          document.querySelector(`[name="${prefijo}_referencia"]`).value = direccion.referencia || '';
          
          // Actualizar botón con la selección
          const boton = document.getElementById(`btn${tipoModal.charAt(0).toUpperCase() + tipoModal.slice(1)}`);
          boton.textContent = '✓ ' + direccion.alias;
          
          // Guardar selección y registrar en recientes
          const recKey = `${tipoDireccion}-${direccionId}`;
          agregarReciente(recKey);
          if (tipoModal === 'origen') {
            origenSeleccionado = { tipo: tipoDireccion, direccion };
          } else {
            destinoSeleccionado = { tipo: tipoDireccion, direccion };
          }
          
          // Cerrar modal
          if (tipoModal === 'origen') {
            cerrarModalOrigen();
          } else {
            cerrarModalDestino();
          }
          
          lucide.createIcons();
        }

        // ============================================
        // LIMPIAR SELECCIÓN
        // ============================================
        function limpiarOrigen() {
          document.querySelector('[name="origen_calle"]').value = '';
          document.querySelector('[name="origen_colonia"]').value = '';
          document.querySelector('[name="origen_cp"]').value = '';
          document.querySelector('[name="origen_ciudad"]').value = '';
          document.querySelector('[name="origen_estado"]').value = '';
          document.querySelector('[name="origen_referencia"]').value = '';
          
          document.getElementById('btnOrigen').innerHTML = '<i data-lucide="warehouse" style="width:18px;height:18px;"></i> Seleccionar Dirección Guardada';
          lucide.createIcons();
          
          origenSeleccionado = null;
          lucide.createIcons();
        }

        function limpiarDestino() {
          document.querySelector('[name="destino_calle"]').value = '';
          document.querySelector('[name="destino_colonia"]').value = '';
          document.querySelector('[name="destino_cp"]').value = '';
          document.querySelector('[name="destino_ciudad"]').value = '';
          document.querySelector('[name="destino_estado"]').value = '';
          document.querySelector('[name="destino_referencia"]').value = '';
          
          document.getElementById('btnDestino').innerHTML = '<i data-lucide="map-pin" style="width:18px;height:18px;"></i> Seleccionar Dirección Guardada';
          lucide.createIcons();
          
          destinoSeleccionado = null;
          lucide.createIcons();
        }

        // ============================================
        // DETECTAR CAMBIO DE CLIENTE
        // ============================================
        document.querySelector('[name="cliente_id"]')?.addEventListener('change', function() {
          const clienteId = this.value;
          direccionesCliente = [];
          const modalOrigenVisible  = document.getElementById('modalDireccionOrigen').classList.contains('open');
          const modalDestinoVisible = document.getElementById('modalDireccionDestino').classList.contains('open');
          if (modalOrigenVisible)  cargarDireccionesClienteModal(clienteId, 'origen');
          if (modalDestinoVisible) cargarDireccionesClienteModal(clienteId, 'destino');
        });



    // ══ Referencias múltiples ══════════════════════════════════════════
    const _refs = [];

    function refTagKeydown(e) {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        refTagAgregar();
      } else if (e.key === 'Backspace' && e.target.value === '' && _refs.length > 0) {
        refTagEliminar(_refs.length - 1);
      }
    }

    function refTagAgregar() {
      const input = document.getElementById('refTagInput');
      const val = input.value.trim().replace(/,+$/, '');
      if (!val) return;
      if (_refs.includes(val)) { input.value = ''; return; }
      _refs.push(val);
      refTagRender();
      input.value = '';
    }

    function refTagEliminar(idx) {
      _refs.splice(idx, 1);
      refTagRender();
    }

    function refTagRender() {
      const container = document.getElementById('refTagsContainer');
      const hidden    = document.getElementById('refTagHidden');
      container.innerHTML = _refs.map((r, i) => `
        <span class="ref-tag">
          ${r}
          <button type="button" class="ref-tag-del" onclick="refTagEliminar(${i})">×</button>
        </span>
      `).join('');
      hidden.value = _refs.join(', ');
    }
    // ══════════════════════════════════════════════════════════════════
    // ══ Parcial logic ══════════════════════════════════════════════════
    let _tipoParcial = 'raiz'; // 'raiz' o 'complemento'

    function toggleParcial() {
      const check  = document.getElementById('esParcialCheck');
      const row    = document.getElementById('parcialToggleRow');
      const tipoSel = document.getElementById('parcialTipoSelector');
      const opts   = document.getElementById('parcialOptions');
      const activo = check.checked;

      row.classList.toggle('active', activo);
      tipoSel.classList.toggle('visible', activo);

      if (!activo) {
        // Reset todo
        opts.classList.remove('visible');
        document.getElementById('hiddenEsParcial').value = '0';
        document.getElementById('hiddenEsComplemento').value = '0';
        document.getElementById('hiddenEnvioRelacionado').value = '';
        seleccionarTipo('raiz'); // reset visual
      } else {
        seleccionarTipo('raiz'); // default al activar
      }
    }

    function seleccionarTipo(tipo) {
      _tipoParcial = tipo;
      const btnRaiz = document.getElementById('btnTipoRaiz');
      const btnComp = document.getElementById('btnTipoComplemento');
      const opts    = document.getElementById('parcialOptions');

      btnRaiz.classList.toggle('selected', tipo === 'raiz');
      btnComp.classList.toggle('selected', tipo === 'complemento');

      if (tipo === 'raiz') {
        // Esta guía ES la raíz parcial — parte 1
        document.getElementById('hiddenEsParcial').value = '1';
        document.getElementById('hiddenEsComplemento').value = '0';
        document.getElementById('hiddenEnvioRelacionado').value = '';
        opts.classList.remove('visible');
      } else {
        // Es complemento — necesita seleccionar guía raíz
        document.getElementById('hiddenEsParcial').value = '0';
        document.getElementById('hiddenEsComplemento').value = '1';
        opts.classList.add('visible');
        cargarGuiasRaizPorCliente();
      }
    }

    async function cargarGuiasRaizPorCliente() {
      const clienteId = document.querySelector('[name="cliente_id"]')?.value;
      const sel = document.getElementById('envioRelacionadoSelect');
      sel.innerHTML = '<option value="">Cargando...</option>';
      if (!clienteId) {
        sel.innerHTML = '<option value="">Primero selecciona un cliente</option>';
        return;
      }
      try {
        const res  = await fetch(`/envios/parciales-por-cliente/${clienteId}`);
        const data = await res.json();
        sel.innerHTML = '<option value="">Seleccionar guía raíz...</option>';
        if (data.envios && data.envios.length > 0) {
          data.envios.forEach(e => {
            const opt = document.createElement('option');
            opt.value = e.id;
            opt.textContent = `${e.numero_tracking} — ${new Date(e.fecha_creacion).toLocaleDateString('es-MX')} — ${e.estado_actual.toUpperCase()}`;
            sel.appendChild(opt);
          });
        } else {
          sel.innerHTML = '<option value="">Sin guías parciales para este cliente</option>';
        }
      } catch(err) {
        sel.innerHTML = '<option value="">Error al cargar guías</option>';
      }
    }

    function onGuiaOrigenChange() {
      const sel = document.getElementById('envioRelacionadoSelect');
      const btn = document.getElementById('btnCargarItems');
      document.getElementById('hiddenEnvioRelacionado').value = sel.value;
      btn.disabled = !sel.value;
    }

    async function cargarItemsPendientes() {
      const sel = document.getElementById('envioRelacionadoSelect');
      if (!sel.value) return;
      const btn  = document.getElementById('btnCargarItems');
      const help = document.getElementById('parcialHelp');
      btn.disabled = true;
      btn.innerHTML = '<i data-lucide="loader" style="width:14px;height:14px;"></i> Cargando...';
      try {
        const res  = await fetch(`/envios/${sel.value}/items-json`);
        const data = await res.json();
        if (data.items && data.items.length > 0) {
          document.getElementById('itemsTbody').innerHTML = '';
          data.items.forEach(it => agregarItem(it.cantidad, it.tipo, it.descripcion, it.peso));
          help.style.display = 'block';
          help.textContent = `✅ Se cargaron ${data.items.length} ítem(s) de la guía raíz. Ajusta las cantidades según lo que va en este complemento.`;
        } else {
          help.style.display = 'block';
          help.textContent = 'La guía raíz no tiene ítems registrados.';
        }
      } catch(err) {
        help.style.display = 'block';
        help.textContent = 'Error al cargar ítems.';
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="package" style="width:14px;height:14px;"></i> Cargar ítems de guía raíz';
        if (typeof lucide !== 'undefined') lucide.createIcons();
      }
    }

    // Re-cargar guías cuando cambie el cliente (si ya está en modo complemento)
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelector('[name="cliente_id"]')?.addEventListener('change', () => {
        if (_tipoParcial === 'complemento' && document.getElementById('esParcialCheck').checked) {
          cargarGuiasRaizPorCliente();
        }
      });
    });
    // ══════════════════════════════════════════════════════════════════
    // ══ Items table functions ══════════════════════════════════════════
    const TIPOS_COMUNES = ['BULTOS','TARIMA','BOTES','CAJA','PALLET','PROTEGIDO',
      'GUACAL','EMPLEADO','SACO','TAMBOR','ROLLO','TUBO','PIEZAS','KIT','SOBRE'];

    function crearFilaItem(cant, tipo, desc, peso) {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td class="td-cant">
          <input type="number" name="item_cant[]" value="${cant||1}" min="1" step="1"
            style="text-align:center;" oninput="actualizarPesoTotal()">
        </td>
        <td class="td-tipo">
          <input type="text" name="item_tipo[]" value="${tipo||''}"
            placeholder="Ej: BULTOS" list="tiposComunes" oninput="actualizarPesoTotal()">
        </td>
        <td>
          <input type="text" name="item_desc[]" value="${desc||''}"
            placeholder="Descripción adicional...">
        </td>
        <td class="td-peso">
          <input type="number" name="item_peso[]" value="${peso!=null&&peso!==''?peso:''}"
            min="0" step="0.01" placeholder="0.00"
            style="text-align:right;" oninput="actualizarPesoTotal()">
        </td>
        <td class="td-del">
          <button type="button" class="btn-del-item"
            onclick="this.closest('tr').remove();actualizarPesoTotal();" title="Eliminar">
            <i data-lucide="trash-2" style="width:15px;height:15px;"></i>
          </button>
        </td>`;
      return tr;
    }

    function agregarItem(cant, tipo, desc, peso) {
      const tbody = document.getElementById('itemsTbody');
      tbody.appendChild(crearFilaItem(cant||1, tipo||'', desc||'', peso!=null?peso:''));
      if (typeof lucide !== 'undefined') lucide.createIcons();
      actualizarPesoTotal();
    }

    function actualizarPesoTotal() {
      const total = [...document.querySelectorAll('#itemsTbody [name="item_peso[]"]')]
        .reduce((s, el) => s + (parseFloat(el.value)||0), 0);
      const elT = document.getElementById('pesoTotal');
      const elH = document.getElementById('pesoHidden');
      if (elT) elT.textContent = total.toFixed(2);
      if (elH) elH.value = total.toFixed(2);
    }

    // Datalist con tipos comunes
    (() => {
      const dl = document.createElement('datalist');
      dl.id = 'tiposComunes';
      TIPOS_COMUNES.forEach(t => { const o = document.createElement('option'); o.value = t; dl.appendChild(o); });
      document.body.appendChild(dl);
    })();
    // ══════════════════════════════════════════════════════════════════

    document.addEventListener('DOMContentLoaded', () => { agregarItem(); });

  </script>
  <script src="/js/notifications.js"></script>
  <script src="/js/sidebar.js"></script>
</body>
</html>