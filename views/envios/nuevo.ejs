        // ============================================
        // RENDER SECCIONES DEL MODAL
        // ============================================
        function renderModalSections(tipoModal) {
          const query   = document.getElementById(tipoModal + 'Buscador')?.value?.toLowerCase() || '';
          const favKeys = getFavoritas();
          const recKeys = getRecientes();

          // Bodegas
          const bodegas = (direccionesBodegas || []).filter(d =>
            !query || d.alias.toLowerCase().includes(query) ||
            d.ciudad?.toLowerCase().includes(query) || d.calle?.toLowerCase().includes(query)
          );
          const bodFav  = bodegas.filter(d => favKeys.includes(`bodega-${d.id}`) || d.es_predeterminada);
          const bodRec  = bodegas.filter(d => recKeys.includes(`bodega-${d.id}`) && !bodFav.find(f => f.id === d.id));
          const bodTodos = bodegas.filter(d => !bodFav.find(f => f.id === d.id) && !bodRec.find(r => r.id === d.id));

          const prefix = tipoModal === 'origen' ? 'origen' : 'destino';

          // Render bodegas
          setGrid(`${prefix}FavoritosGrid`,  bodFav,  'bodega', tipoModal);
          setGrid(`${prefix}RecientesGrid`,  bodRec,  'bodega', tipoModal);
          setGrid(`${prefix}TodosGrid`,      bodTodos,'bodega', tipoModal);
          toggleSection(`${prefix}FavoritosSection`,  bodFav.length > 0);
          toggleSection(`${prefix}RecientesSection`,  bodRec.length > 0);
          toggleSection(`${prefix}TodosSection`,      bodTodos.length > 0);

          // Direcciones cliente
          const clDirs = (direccionesCliente || []).filter(d =>
            !query || d.alias.toLowerCase().includes(query) ||
            d.ciudad?.toLowerCase().includes(query) || d.calle?.toLowerCase().includes(query)
          );
