              ${dir.es_predeterminada ? '<span class="badge-predeterminada">⭐ PREDETERMINADA</span>' : ''}
              <button class="pin-btn ${fav ? 'pinned' : ''}" title="${fav ? 'Quitar favorito' : 'Añadir a favoritos'}"
                onclick="event.stopPropagation(); toggleFavDir('${key}', '${tipoModal}')">
