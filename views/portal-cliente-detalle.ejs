<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Portal de Seguimiento</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #f1f5f9; min-height: 100vh; color: #1e293b; }

    /* ── HEADER ── */
    .portal-header {
      background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
      padding: 0 32px; display: flex; align-items: center; justify-content: space-between;
      height: 64px; box-shadow: 0 2px 12px rgba(0,0,0,.25);
      position: sticky; top: 0; z-index: 100;
    }
    .portal-brand { display: flex; align-items: center; gap: 12px; }
    .portal-brand-icon {
      width: 36px; height: 36px; background: #f59e0b;
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
    }
    .portal-brand-name { color: #fff; font-size: 16px; font-weight: 700; }
    .portal-brand-sub  { color: #94a3b8; font-size: 12px; }
    .btn-back {
      display: flex; align-items: center; gap: 6px;
      padding: 8px 16px; background: rgba(255,255,255,.1);
      color: #e2e8f0; border: 1px solid rgba(255,255,255,.15);
      border-radius: 8px; font-size: 13px; font-weight: 600;
      text-decoration: none; transition: all .15s;
    }
    .btn-back:hover { background: rgba(255,255,255,.18); color: #fff; }
    .btn-logout {
      display: flex; align-items: center; gap: 6px;
      padding: 8px 14px; background: rgba(255,255,255,.08);
      color: #cbd5e1; border: 1px solid rgba(255,255,255,.12);
      border-radius: 8px; font-size: 12px; font-weight: 600;
      text-decoration: none; transition: all .15s;
    }
    .btn-logout:hover { background: rgba(255,255,255,.15); color: #fff; }
    .header-right { display: flex; align-items: center; gap: 10px; }

    /* ── MAIN ── */
    .main { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }

    /* ── TRACKING HERO ── */
    .tracking-hero {
      background: #fff; border-radius: 16px; padding: 28px 32px;
      margin-bottom: 24px; box-shadow: 0 1px 4px rgba(0,0,0,.06);
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
    }
    .tracking-number {
      font-size: 28px; font-weight: 900; color: #1e293b; letter-spacing: .5px;
    }
    .tracking-ref { font-size: 13px; color: #64748b; margin-top: 4px; }

    /* Estado badge */
    .estado-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px; border-radius: 30px;
      font-size: 14px; font-weight: 700; letter-spacing: .3px;
    }
    .estado-creado       { background: #f1f5f9; color: #475569; }
    .estado-en-transito  { background: #dbeafe; color: #1d4ed8; }
    .estado-entregado    { background: #dcfce7; color: #15803d; }
    .estado-cancelado    { background: #fee2e2; color: #dc2626; }
    .estado-en-bodega    { background: #fef9c3; color: #854d0e; }
    .estado-retrasado    { background: #ffedd5; color: #c2410c; }

    /* ── GRID ── */
    .detail-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
      margin-bottom: 24px;
    }
    @media (max-width: 768px) { .detail-grid { grid-template-columns: 1fr; } }

    .info-card {
      background: #fff; border-radius: 14px; padding: 24px;
      box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }
    .info-card-title {
      font-size: 12px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .6px; color: #94a3b8; margin-bottom: 16px;
      padding-bottom: 10px; border-bottom: 1px solid #f1f5f9;
      display: flex; align-items: center; gap: 8px;
    }
    .info-row { display: flex; flex-direction: column; gap: 3px; margin-bottom: 14px; }
    .info-row:last-child { margin-bottom: 0; }
    .info-label { font-size: 11px; color: #94a3b8; font-weight: 600; text-transform: uppercase; letter-spacing: .4px; }
    .info-value { font-size: 14px; color: #1e293b; font-weight: 500; }
    .info-value.mono { font-family: 'Courier New', monospace; font-weight: 700; color: #2563eb; }

    /* ── ITEMS ── */
    .items-card {
      background: #fff; border-radius: 14px; padding: 24px;
      box-shadow: 0 1px 4px rgba(0,0,0,.06); margin-bottom: 24px;
    }
    .items-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px;
      margin-top: 16px;
    }
    .item-chip {
      background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 10px;
      padding: 12px 16px; display: flex; align-items: center; gap: 10px;
    }
    .item-chip-icon {
      width: 36px; height: 36px; background: #dbeafe; border-radius: 8px;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .item-chip-name { font-size: 13px; font-weight: 600; color: #1e293b; }
    .item-chip-qty  { font-size: 12px; color: #64748b; }

    /* ── HISTORIAL ── */
    .historial-card {
      background: #fff; border-radius: 14px; padding: 24px;
      box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }
    .timeline { position: relative; padding-left: 32px; margin-top: 20px; }
    .timeline::before {
      content: ''; position: absolute; left: 10px; top: 0; bottom: 0;
      width: 2px; background: #e2e8f0;
    }
    .timeline-item { position: relative; margin-bottom: 28px; }
    .timeline-item:last-child { margin-bottom: 0; }
    .timeline-dot {
      position: absolute; left: -27px; top: 3px;
      width: 18px; height: 18px; border-radius: 50%;
      border: 3px solid #fff; box-shadow: 0 0 0 2px #e2e8f0;
      background: #94a3b8;
    }
    .timeline-dot.creado       { background: #64748b; box-shadow: 0 0 0 2px #64748b33; }
    .timeline-dot.en-transito  { background: #3b82f6; box-shadow: 0 0 0 2px #3b82f633; }
    .timeline-dot.entregado    { background: #22c55e; box-shadow: 0 0 0 2px #22c55e33; }
    .timeline-dot.cancelado    { background: #ef4444; box-shadow: 0 0 0 2px #ef444433; }
    .timeline-dot.en-bodega    { background: #eab308; box-shadow: 0 0 0 2px #eab30833; }
    .timeline-dot.retrasado    { background: #f97316; box-shadow: 0 0 0 2px #f9731633; }
    .timeline-dot.active       { width: 22px; height: 22px; left: -29px; top: 1px; }

    .timeline-header { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
    .timeline-estado {
      font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .4px;
      padding: 3px 10px; border-radius: 20px;
    }
    .timeline-fecha { font-size: 12px; color: #94a3b8; }
    .timeline-nota  { font-size: 13px; color: #475569; line-height: 1.5; }
    .timeline-usuario { font-size: 11px; color: #cbd5e1; margin-top: 4px; }

    /* Fotos */
    .fotos-grid {
      display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;
    }
    .foto-thumb {
      width: 72px; height: 72px; object-fit: cover;
      border-radius: 8px; border: 2px solid #e2e8f0; cursor: pointer;
      transition: transform .15s;
    }
    .foto-thumb:hover { transform: scale(1.05); }

    /* Parcial badge */
    .badge-parte {
      display: inline-flex; align-items: center; gap: 3px;
      background: #fef3c7; color: #92400e; border: 1px solid #fcd34d;
      border-radius: 6px; padding: 2px 8px; font-size: 11px; font-weight: 700;
    }
    .badge-parte.complemento { background: #f0fdf4; color: #166534; border-color: #86efac; }

    @media (max-width: 768px) {
      .portal-header { padding: 0 16px; }
      .main { padding: 20px 16px; }
      .tracking-hero { padding: 20px 16px; }
      .tracking-number { font-size: 20px; }
    }

    @media (max-width: 480px) {
      .portal-brand-sub { display: none; }
      .btn-back span, .btn-logout span { display: none; }
    }

    /* Lightbox */
    .lightbox {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.85); z-index: 9999;
      align-items: center; justify-content: center;
    }
    .lightbox.open { display: flex; }
    .lightbox img { max-width: 90vw; max-height: 90vh; border-radius: 12px; }
    .lightbox-close {
      position: fixed; top: 20px; right: 24px;
      background: rgba(255,255,255,.15); border: none; color: #fff;
      width: 40px; height: 40px; border-radius: 10px; cursor: pointer;
      font-size: 20px; display: flex; align-items: center; justify-content: center;
    }
  </style>
</head>
<body>

<!-- ══ HEADER ══ -->
<header class="portal-header">
  <div class="portal-brand">
    <div class="portal-brand-icon">
      <i data-lucide="truck" style="width:18px;height:18px;color:#1e293b;"></i>
    </div>
    <div>
      <div class="portal-brand-name">Portal de Seguimiento</div>
      <div class="portal-brand-sub">Transportes AB</div>
    </div>
  </div>

  <div class="header-right">
    <a href="/portal-cliente" class="btn-back">
      <i data-lucide="arrow-left" style="width:14px;height:14px;"></i>
      Mis Envíos
    </a>
    <a href="/auth/logout" class="btn-logout">
      <i data-lucide="log-out" style="width:14px;height:14px;"></i>
      Salir
    </a>
  </div>
</header>

<!-- ══ MAIN ══ -->
<main class="main">

  <!-- Hero tracking -->
  <div class="tracking-hero">
    <div>
      <div class="tracking-number">
        <%= envio.numero_tracking %>
        <% if (envio.es_parcial) { %>
          <span class="badge-parte" style="font-size:13px;vertical-align:middle;">PARTE 1</span>
        <% } else if (envio.es_complemento) { %>
          <span class="badge-parte complemento" style="font-size:13px;vertical-align:middle;">PARTE <%= envio.numero_parte || '?' %></span>
        <% } %>
      </div>
      <div class="tracking-ref">
        <% if (envio.referencia_cliente) { %>
          Ref: <strong><%= envio.referencia_cliente %></strong>
        <% } else { %>
          Sin referencia
        <% } %>
      </div>
    </div>
    <span class="estado-badge estado-<%= envio.estado_actual %>">
      <i data-lucide="<%= envio.estado_actual === 'entregado' ? 'check-circle' : envio.estado_actual === 'cancelado' ? 'x-circle' : 'truck' %>" style="width:16px;height:16px;"></i>
      <%= envio.estado_actual.replace(/-/g,' ').toUpperCase() %>
    </span>
  </div>

  <!-- Grid de información -->
  <div class="detail-grid">

    <!-- Origen -->
    <div class="info-card">
      <div class="info-card-title">
        <i data-lucide="map-pin" style="width:14px;height:14px;color:#3b82f6;"></i>
        Origen
      </div>
      <div class="info-row">
        <span class="info-label">Dirección</span>
        <span class="info-value"><%= envio.origen_calle || envio.origen || '—' %></span>
      </div>
      <% if (envio.origen_colonia) { %>
      <div class="info-row">
        <span class="info-label">Colonia</span>
        <span class="info-value"><%= envio.origen_colonia %></span>
      </div>
      <% } %>
      <div class="info-row">
        <span class="info-label">Ciudad</span>
        <span class="info-value"><%= [envio.origen_ciudad, envio.origen_estado, envio.origen_cp].filter(Boolean).join(', ') || '—' %></span>
      </div>
    </div>

    <!-- Destino -->
    <div class="info-card">
      <div class="info-card-title">
        <i data-lucide="flag" style="width:14px;height:14px;color:#ef4444;"></i>
        Destino
      </div>
      <div class="info-row">
        <span class="info-label">Dirección</span>
        <span class="info-value"><%= envio.destino_calle || envio.destino || '—' %></span>
      </div>
      <% if (envio.destino_colonia) { %>
      <div class="info-row">
        <span class="info-label">Colonia</span>
        <span class="info-value"><%= envio.destino_colonia %></span>
      </div>
      <% } %>
      <div class="info-row">
        <span class="info-label">Ciudad</span>
        <span class="info-value"><%= [envio.destino_ciudad, envio.destino_estado, envio.destino_cp].filter(Boolean).join(', ') || '—' %></span>
      </div>
    </div>

    <!-- Fechas -->
    <div class="info-card">
      <div class="info-card-title">
        <i data-lucide="calendar" style="width:14px;height:14px;color:#8b5cf6;"></i>
        Fechas
      </div>
      <div class="info-row">
        <span class="info-label">Fecha de creación</span>
        <span class="info-value">
          <%= new Date(envio.fecha_creacion).toLocaleDateString('es-MX', {day:'2-digit', month:'long', year:'numeric'}) %>
        </span>
      </div>
      <div class="info-row">
        <span class="info-label">Entrega estimada</span>
        <span class="info-value">
          <% if (envio.fecha_estimada_entrega) { %>
            <%= new Date(envio.fecha_estimada_entrega).toLocaleDateString('es-MX', {day:'2-digit', month:'long', year:'numeric'}) %>
          <% } else { %>
            <span style="color:#d1d5db;">No especificada</span>
          <% } %>
        </span>
      </div>
    </div>

    <!-- Detalles del envío -->
    <div class="info-card">
      <div class="info-card-title">
        <i data-lucide="package" style="width:14px;height:14px;color:#f59e0b;"></i>
        Detalles del Envío
      </div>
      <% if (envio.descripcion) { %>
      <div class="info-row">
        <span class="info-label">Descripción</span>
        <span class="info-value"><%= envio.descripcion %></span>
      </div>
      <% } %>
      <% if (envio.peso) { %>
      <div class="info-row">
        <span class="info-label">Peso</span>
        <span class="info-value"><%= envio.peso %> kg</span>
      </div>
      <% } %>
      <div class="info-row">
        <span class="info-label">Número de tracking</span>
        <span class="info-value mono"><%= envio.numero_tracking %></span>
      </div>
    </div>

  </div>

  <!-- Items del envío -->
  <% if (items && items.length > 0) { %>
  <div class="items-card">
    <div class="info-card-title">
      <i data-lucide="layers" style="width:14px;height:14px;color:#06b6d4;"></i>
      Contenido del Envío
    </div>
    <div class="items-grid">
      <% items.forEach(item => { %>
      <div class="item-chip">
        <div class="item-chip-icon">
          <i data-lucide="package" style="width:18px;height:18px;color:#3b82f6;"></i>
        </div>
        <div style="flex:1;">
          <div class="item-chip-name"><%= item.tipo || 'Artículo' %></div>
          <% if (item.descripcion) { %>
            <div class="item-chip-qty" style="color:#475569;"><%= item.descripcion %></div>
          <% } %>
          <div style="display:flex;gap:10px;margin-top:3px;flex-wrap:wrap;">
            <span class="item-chip-qty">Cantidad: <strong><%= item.cantidad %></strong></span>
            <% if (item.peso) { %>
              <span class="item-chip-qty">Peso: <strong><%= item.peso %> kg</strong></span>
            <% } %>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Guías del pedido parcial -->
  <% if (typeof guiasRelacionadas !== "undefined" && guiasRelacionadas && guiasRelacionadas.length > 0) { %>
  <div class="items-card" style="margin-bottom:24px;">
    <div class="info-card-title">
      <i data-lucide="git-branch" style="width:14px;height:14px;color:#f59e0b;"></i>
      Guías del mismo pedido
    </div>

    <!-- Esta guía -->
    <div style="margin-top:14px;margin-bottom:10px;">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#94a3b8;margin-bottom:8px;">
        Esta guía
      </div>
      <div style="display:flex;align-items:center;gap:10px;background:#eff6ff;border:2px solid #bfdbfe;border-radius:10px;padding:12px 16px;">
        <% if (envio.es_parcial && !envio.es_complemento) { %>
          <span style="background:#fef3c7;color:#92400e;border:1.5px solid #fcd34d;border-radius:6px;padding:2px 8px;font-size:11px;font-weight:700;">PARTE 1 — RAÍZ</span>
        <% } else { %>
          <span style="background:#f0fdf4;color:#166534;border:1.5px solid #86efac;border-radius:6px;padding:2px 8px;font-size:11px;font-weight:700;">PARTE <%= envio.numero_parte %></span>
        <% } %>
        <span style="font-weight:700;color:#1e3a8a;font-family:'Courier New',monospace;"><%= envio.numero_tracking %></span>
        <span class="estado-badge estado-<%= envio.estado_actual %>" style="padding:2px 10px;font-size:11px;margin-left:auto;">
          <%= envio.estado_actual.replace(/-/g,' ').toUpperCase() %>
        </span>
      </div>
    </div>

    <!-- Guías relacionadas -->
    <div>
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#94a3b8;margin-bottom:8px;">
        <%= envio.es_complemento ? 'Raíz y otras partes' : 'Complementos' %>
      </div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <% guiasRelacionadas.forEach(g => { %>
        <a href="/portal-cliente/envio/<%= g.id %>"
           style="display:flex;align-items:center;gap:10px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:10px;padding:12px 16px;text-decoration:none;transition:border-color .15s;"
           onmouseover="this.style.borderColor='#93c5fd'" onmouseout="this.style.borderColor='#e2e8f0'">
          <% if (g.es_parcial && !g.es_complemento) { %>
            <span style="background:#fef3c7;color:#92400e;border:1.5px solid #fcd34d;border-radius:6px;padding:2px 8px;font-size:11px;font-weight:700;white-space:nowrap;">PARTE 1 — RAÍZ</span>
          <% } else { %>
            <span style="background:#f0fdf4;color:#166534;border:1.5px solid #86efac;border-radius:6px;padding:2px 8px;font-size:11px;font-weight:700;white-space:nowrap;">PARTE <%= g.numero_parte %></span>
          <% } %>
          <span style="font-weight:700;color:#2563eb;font-family:'Courier New',monospace;"><%= g.numero_tracking %></span>
          <span class="estado-badge estado-<%= g.estado_actual %>" style="padding:2px 10px;font-size:11px;margin-left:auto;">
            <%= g.estado_actual.replace(/-/g,' ').toUpperCase() %>
          </span>
          <i data-lucide="chevron-right" style="width:14px;height:14px;color:#94a3b8;flex-shrink:0;"></i>
        </a>
        <% }); %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Historial de estados -->
  <div class="historial-card">
    <div class="info-card-title">
      <i data-lucide="clock" style="width:14px;height:14px;color:#10b981;"></i>
      Historial de Seguimiento
    </div>

    <% if (!historial || historial.length === 0) { %>
      <div style="text-align:center;padding:40px;color:#94a3b8;">
        <i data-lucide="inbox" style="width:40px;height:40px;margin-bottom:12px;display:block;margin-left:auto;margin-right:auto;"></i>
        <p>Sin movimientos registrados aún</p>
      </div>
    <% } else { %>
    <div class="timeline">
      <% historial.slice().reverse().forEach((h, idx) => {
           const estadoClass = (h.estado || '').toLowerCase().replace(/\s+/g,'-');
           const esUltimo = idx === 0;
      %>
      <div class="timeline-item">
        <div class="timeline-dot <%= estadoClass %> <%= esUltimo ? 'active' : '' %>"></div>
        <div class="timeline-header">
          <span class="timeline-estado estado-badge estado-<%= estadoClass %>" style="padding:2px 10px;font-size:11px;">
            <%= (h.estado || '').replace(/-/g,' ').toUpperCase() %>
          </span>
          <span class="timeline-fecha">
            <%= new Date(h.fecha_hora).toLocaleDateString('es-MX', {day:'2-digit', month:'short', year:'numeric'}) %>
            <%= new Date(h.fecha_hora).toLocaleTimeString('es-MX', {hour:'2-digit', minute:'2-digit'}) %>
          </span>
        </div>
        <% if (h.notas) { %>
          <div class="timeline-nota"><%= h.notas %></div>
        <% } %>
        <% if (h.usuario_nombre) { %>
          <div class="timeline-usuario">Actualizado por <%= h.usuario_nombre %></div>
        <% } %>
        <% if (h.fotos && h.fotos.length > 0) { %>
        <div class="fotos-grid">
          <% h.fotos.forEach(foto => { %>
            <img src="/<%= foto.ruta_archivo %>" alt="Evidencia" class="foto-thumb"
                 onclick="abrirLightbox(this.src)">
          <% }); %>
        </div>
        <% } %>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>

</main>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" onclick="cerrarLightbox()">
  <button class="lightbox-close" onclick="cerrarLightbox()">✕</button>
  <img id="lightboxImg" src="" alt="Foto evidencia">
</div>

<script>
  lucide.createIcons();

  function abrirLightbox(src) {
    document.getElementById('lightboxImg').src = src;
    document.getElementById('lightbox').classList.add('open');
  }
  function cerrarLightbox() {
    document.getElementById('lightbox').classList.remove('open');
  }
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') cerrarLightbox();
  });
</script>
</body>
</html>
