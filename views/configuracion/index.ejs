                              <span style="font-size:7pt;font-weight:bold;text-transform:uppercase;background:#e8e8e8;border-bottom:1px solid #000;padding:2px 4px;display:block;">Destinatario: (Destino)</span>
                              <div style="font-size:7.5pt;line-height:1.45;padding:4px 5px;min-height:48px;"><strong>Ciudad Destino</strong><br>Calle y número, Col. Centro<br>Ciudad, Estado CP 00000</div>
                            </td>
                          </tr>
                        </table>

                        <!-- Tabla de carga -->
                        <table style="border-collapse:collapse;width:100%;border-top:none;">
                          <thead>
                            <tr>
                              <th style="background:#e0e0e0;font-size:7pt;font-weight:bold;text-align:center;padding:4px 3px;border:1px solid #000;width:5%;">CANT.</th>
                              <th style="background:#e0e0e0;font-size:7pt;font-weight:bold;text-align:center;padding:4px 3px;border:1px solid #000;width:12%;">EMBALAJE</th>
                              <th style="background:#e0e0e0;font-size:7pt;font-weight:bold;text-align:center;padding:4px 3px;border:1px solid #000;">DESCRIPCIÓN SEGÚN REMITENTE</th>
                              <th style="background:#e0e0e0;font-size:7pt;font-weight:bold;text-align:center;padding:4px 3px;border:1px solid #000;width:11%;">PESO Kgs.</th>
                              <th style="background:#e0e0e0;font-size:7pt;font-weight:bold;text-align:center;padding:4px 3px;border:1px solid #000;width:13%;">VOLUMEN Mts.³</th>
                              <th style="background:#e0e0e0;font-size:7pt;font-weight:bold;text-align:center;padding:4px 3px;border:1px solid #000;width:12%;">SERVICIOS</th>
                            </tr>
                          </thead>
                          <tbody>
                            <tr><td style="border:1px solid #000;padding:5px 4px;font-size:7.5pt;text-align:center;min-height:26px;">1</td><td style="border:1px solid #000;padding:5px 4px;font-size:7.5pt;">CAJA</td><td style="border:1px solid #000;padding:5px 4px;font-size:7.5pt;">Mercancía de ejemplo</td><td style="border:1px solid #000;padding:5px 4px;font-size:7.5pt;text-align:center;">5.000</td><td style="border:1px solid #000;padding:5px 4px;"></td><td style="border:1px solid #000;padding:5px 4px;"></td></tr>
                            <tr><td style="border:1px solid #000;padding:5px 4px;min-height:26px;">&nbsp;</td><td style="border:1px solid #000;padding:5px 4px;"></td><td style="border:1px solid #000;padding:5px 4px;"></td><td style="border:1px solid #000;padding:5px 4px;"></td><td style="border:1px solid #000;padding:5px 4px;"></td><td style="border:1px solid #000;padding:5px 4px;"></td></tr>
                            <tr><td style="border:1px solid #000;padding:5px 4px;font-size:7.5pt;text-align:center;min-height:26px;"></td><td style="border:1px solid #000;padding:5px 4px;"></td><td style="border:1px solid #000;padding:5px 4px;"></td><td style="border:1px solid #000;padding:5px 4px;font-size:7.5pt;text-align:center;font-weight:bold;">5.00</td><td style="border:1px solid #000;padding:5px 4px;"></td><td style="border:1px solid #000;padding:5px 4px;"></td></tr>
                          </tbody>
                        </table>

                        <!-- dato oculto para JS -->
                        <span id="gprev-aviso-text" data-aviso="<%= gpAviso %>" style="display:none;"></span>

                        <!-- Mensaje cláusula 1 + aviso privacidad -->
                        <%
                          const gpMsg1Completo = [gpMsg1, gpAviso ? 'Conoce nuestro aviso de Privacidad en: ' + gpAviso : ''].filter(Boolean).join(' ');
                        %>
                        <div id="gprev-msg1-row" style="border:1px solid #000;border-top:none;padding:5px 7px;font-size:7.5pt;min-height:22px;color:#222;font-style:italic;text-align:center;<%= gpMsg1Completo ? '' : 'display:none;' %>"><span id="gprev-msg1"><%= gpMsg1Completo %></span></div>
                        <!-- Mensaje cláusula 2 -->
                        <div id="gprev-msg2" style="border:1px solid #000;border-top:none;padding:5px 7px;font-size:7.5pt;min-height:22px;color:#222;font-style:italic;text-align:center;<%= gpMsg2 ? '' : 'display:none;' %>"><%= gpMsg2 %></div>

                        <!-- Bloque inferior -->
                        <table style="border-collapse:collapse;width:100%;border-top:none;">
                          <tr>
                            <td style="width:28%;border:1px solid #000;border-top:none;padding:0;" rowspan="2">
                              <span style="font-size:6.5pt;font-weight:bold;text-transform:uppercase;background:#ececec;border-bottom:1px solid #000;padding:2px 4px;display:block;">Observaciones del cliente:</span>
                              <div style="padding:4px 5px;min-height:52px;">&nbsp;</div>
                            </td>
                            <td style="width:36%;border:1px solid #000;border-top:none;border-left:none;padding:0;">
                              <span style="font-size:6.5pt;font-weight:bold;text-transform:uppercase;background:#ececec;border-bottom:1px solid #000;padding:2px 4px;display:block;">Condiciones de pago:</span>
                              <div style="padding:4px 5px;"><span style="font-size:14pt;font-weight:bold;">CRÉDITO</span></div>
                            </td>
                            <td style="width:36%;border:1px solid #000;border-top:none;border-left:none;padding:0;">
                              <span style="font-size:6.5pt;font-weight:bold;text-transform:uppercase;background:#ececec;border-bottom:1px solid #000;padding:2px 4px;display:block;">Fecha de emisión:</span>
                              <div style="font-size:7.5pt;padding:4px 5px;">01/01/2025<br>Hora: 10:00 Hrs.<br>Documento: -</div>
                            </td>
                          </tr>
                          <tr>
                            <td style="border:1px solid #000;border-top:1px solid #000;border-left:none;padding:0;">
                              <span style="font-size:6.5pt;font-weight:bold;text-transform:uppercase;background:#ececec;border-bottom:1px solid #000;padding:2px 4px;display:block;">Fecha estimada de entrega:</span>
                              <div style="padding:4px 5px;"><span style="font-size:14pt;font-weight:bold;">15/01/2025</span></div>
                            </td>
                            <td style="border:1px solid #000;border-top:1px solid #000;border-left:none;padding:0;">
                              <span style="font-size:6.5pt;font-weight:bold;text-transform:uppercase;background:#ececec;border-bottom:1px solid #000;padding:2px 4px;display:block;">Referencia del cliente:</span>
                              <div style="font-size:7.5pt;padding:4px 5px;">REF-001</div>
                            </td>
                          </tr>
                        </table>

                        <!-- Operador -->
                        <table style="border-collapse:collapse;width:100%;border-top:none;">
                          <tr>
                            <td style="border:1px solid #000;border-top:none;padding:0;">
                              <span style="font-size:6.5pt;font-weight:bold;text-transform:uppercase;background:#ececec;border-bottom:1px solid #000;padding:2px 4px;display:block;">Operador que entregó:</span>
                              <div style="padding:4px 5px;min-height:36px;">&nbsp;</div>
                            </td>
                          </tr>
                        </table>

                        <!-- Recibido por -->
                        <table style="border-collapse:collapse;width:100%;border-top:none;">
                          <tr>
                            <td style="border:1px solid #000;border-top:none;padding:0;">
                              <span style="font-size:6.5pt;font-weight:bold;text-transform:uppercase;background:#ececec;border-bottom:1px solid #000;padding:2px 4px;display:block;">Recibido por: (Nombre, firma y sello)</span>
                              <div style="padding:4px 5px;min-height:48px;">&nbsp;</div>
                            </td>
                          </tr>
                        </table>

                        <!-- Condiciones -->
                        <div id="gprev-msg3" style="border:1px solid #000;border-top:none;padding:5px 7px;font-size:7.5pt;min-height:22px;color:#222;font-style:italic;text-align:center;<%= gpMsg3 ? '' : 'display:none;' %>"><%= gpMsg3 %></div>

                        <!-- Pie -->
                        <div style="font-size:6.5pt;border:1px solid #000;border-top:none;padding:3px 6px;line-height:1.5;">
                          <strong>TRACKING:</strong> ABC-000001 &nbsp;&nbsp; <strong>ORIGEN:</strong> <%= gpDir || 'Origen' %> &nbsp;&nbsp; <strong>DESTINO:</strong> Ciudad Destino
                        </div>
                        <!-- Mensaje final del documento -->
                        <div id="gprev-msg4" style="border:1px solid #000;border-top:none;padding:5px 7px;font-size:7.5pt;min-height:22px;color:#222;font-style:italic;text-align:center;<%= gpMsg4 ? '' : 'display:none;' %>"><%= gpMsg4 %></div>

                      </div><!-- /mini-guía -->
                    </div><!-- /preview bg -->
              </div><!-- /guia-subtab-textos -->

              <!-- Sub-tab: Tamaño de Textos -->
              <div id="guia-subtab-tamanos" style="display: none;">
                <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Tamaño de fuente (pt)</p>
                <p style="font-size: 0.83rem; color: #64748b; margin-bottom: 20px;">
                  Ajusta el tamaño de los textos principales de la guía. Deja en blanco para usar el tamaño por defecto del sistema.
                </p>

                <% const guiaSizes = guiaTplActivo || {};
                   const guiaSizeItems = [
                     { key: 'size_guia_titulo',     label: 'Título principal (GUÍA EXPEDIDA)',   def: 13, min:  9, max: 18 },
                     { key: 'size_guia_servicio',   label: 'Subtítulo / descripción servicio',   def:  8, min:  6, max: 12 },
                     { key: 'size_tracking_big',    label: 'Número de tracking (header)',        def: 13, min:  9, max: 18 },
                     { key: 'size_company_name',    label: 'Nombre de empresa (header)',         def:  9, min:  7, max: 14 },
                     { key: 'size_seccion_label',   label: 'Etiquetas de sección (Remitente, Facturar…)', def: 7, min: 5, max: 10 },
                     { key: 'size_seccion_content', label: 'Contenido de secciones (texto)',     def:  8, min:  6, max: 12 },
                     { key: 'size_cargo_th',        label: 'Encabezados de tabla de carga',      def:  7, min:  5, max: 10 },
                     { key: 'size_cargo_td',        label: 'Filas / celdas de tabla de carga',   def:  8, min:  6, max: 11 },
                     { key: 'size_msg_row',         label: 'Mensajes / cláusulas personalizables', def: 8, min: 6, max: 12 },
                     { key: 'size_footer_content',  label: 'Contenido footer (condiciones, fechas)', def: 8, min: 6, max: 12 },
                     { key: 'size_pago_big',        label: 'Valores grandes (pago / fecha entrega)', def: 16, min: 10, max: 24 },
                                        ];
                %>

                <div style="display: flex; flex-direction: column; gap: 20px;">
                  <% guiaSizeItems.forEach(function(s) {
                       const val = guiaSizes[s.key] ? parseInt(guiaSizes[s.key]) : s.def;
                  %>
                  <div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                      <label style="font-size: 0.85rem; font-weight: 700; color: #374151;"><%= s.label %></label>
                      <div style="display: flex; align-items: center; gap: 6px;">
                        <span id="glbl-<%= s.key %>" style="font-size: 0.9rem; font-weight: 800; color: #2563eb; min-width: 28px; text-align: right;"><%= val %></span>
                        <span style="font-size: 0.75rem; color: #94a3b8;"><%= s.unit || 'pt' %></span>
                      </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 10px;">
                      <span style="font-size: 0.7rem; color: #94a3b8;"><%= s.min %></span>
                      <input type="range" name="<%= s.key %>" id="grange-<%= s.key %>"
                        min="<%= s.min %>" max="<%= s.max %>" step="1"
                        value="<%= val %>"
                        oninput="document.getElementById('glbl-<%= s.key %>').textContent=this.value; document.getElementById('gnum-<%= s.key %>').value=this.value;"
                        style="flex: 1; accent-color: #2563eb; height: 4px; cursor: pointer;">
                      <span style="font-size: 0.7rem; color: #94a3b8;"><%= s.max %></span>
                      <input type="number" id="gnum-<%= s.key %>"
                        min="<%= s.min %>" max="<%= s.max %>"
                        value="<%= val %>"
                        oninput="var v=Math.min(<%= s.max %>,Math.max(<%= s.min %>,parseInt(this.value)||<%= s.def %>)); document.getElementById('grange-<%= s.key %>').value=v; document.getElementById('glbl-<%= s.key %>').textContent=v;"
                        onchange="document.getElementById('grange-<%= s.key %>').value=this.value;"
                        style="width: 52px; padding: 4px 6px; border: 1.5px solid #e2e8f0; border-radius: 6px; font-size: 0.85rem; text-align: center;">
                    </div>
                    <div style="margin-top: 4px; font-size: 0.72rem; color: #94a3b8;">Default del sistema: <strong><%= s.def %><%= s.unit || 'pt' %></strong></div>
                  </div>
                  <% }); %>
                </div>

                <div style="margin-top: 20px; padding: 12px 14px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; font-size: 0.78rem; color: #1e40af;">
                  💡 Los cambios aplican a todos los envíos que usen este template. Si restauras el tamaño al valor default, borra el campo y guarda.
                </div>
              </div><!-- /guia-subtab-tamanos -->

              <div style="margin-top: 24px; padding-top: 20px; border-top: 2px solid #f1f5f9;">
                <button type="submit" class="btn-primary">
                  <i data-lucide="save" style="width: 18px; height: 18px;"></i>
                  Guardar configuración de guía
                </button>
              </div>
            </div>
          </form>
          <% } else if (!guiaTplActivo) { %>
          <div class="config-card" style="text-align: center; padding: 48px; color: #94a3b8;">
            <i data-lucide="file-text" style="width: 48px; height: 48px; margin-bottom: 12px;"></i>
            <p style="font-weight: 700; font-size: 1rem;">No hay templates de guía</p>
            <% if (isAdminOrSuper) { %>
            <p style="font-size: 0.85rem; margin-top: 6px;">Crea el primer template con el botón de arriba.</p>
            <% } %>
          </div>
          <% } %>

          <!-- Modal: Crear nuevo template de guía -->
          <% if (isAdminOrSuper) { %>
          <div id="modal-nuevo-guia-tpl" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">
            <div style="background:white; border-radius:16px; padding:32px; width:520px; max-width:95vw; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                <h3 style="font-size:1.1rem; font-weight:800; color:#1e293b;">Crear nuevo Template de Guía</h3>
                <button type="button" onclick="cerrarModalNuevoGuiaTpl()" style="background:none;border:none;cursor:pointer;font-size:1.4rem;color:#94a3b8;">&times;</button>
              </div>
              <form action="/configuracion/guia/templates/nuevo" method="POST">
                <div style="margin-bottom: 16px;">
                  <label style="display:block; font-size:0.85rem; font-weight:700; color:#374151; margin-bottom:6px;">Nombre del template *</label>
                  <input type="text" name="nombre" required placeholder="Ej: Estándar, Exportación..."
                    style="width:100%; padding:10px 12px; border:2px solid #e2e8f0; border-radius:8px; font-size:0.9rem; font-weight:600;">
                </div>
                <p style="font-size:0.8rem; color:#64748b; margin-bottom:16px;">El template se creará con todos los elementos activados. Podrás editarlo después.</p>
                <div style="display:flex; gap:10px; justify-content:flex-end;">
                  <button type="button" onclick="cerrarModalNuevoGuiaTpl()"
                    style="padding:10px 20px; background:#f1f5f9; color:#374151; border:none; border-radius:8px; font-weight:600; cursor:pointer;">
                    Cancelar
                  </button>
                  <button type="submit"
                    style="padding:10px 20px; background:#2563eb; color:white; border:none; border-radius:8px; font-weight:700; cursor:pointer;">
                    Crear Template
                  </button>
                </div>
              </form>
            </div>
          </div>
          <% } %>

          </div><!-- /imp-panel-guia -->

          <!-- Panel: Pictogramas -->
          <div id="imp-panel-pictogramas" style="display:none">

          <div class="config-card">
            <div class="card-header">
              <div>
                <h2 class="card-title">
                  <i data-lucide="image" style="width:24px;height:24px;color:#3b82f6;"></i>
                  Pictogramas
                </h2>
                <p class="card-description">Símbolos de manejo de carga. Se asignan a cada envío al crearlo y se muestran en la etiqueta e impresión carta.</p>
              </div>
              <% if (isAdminOrSuper) { %>
              <button type="button" onclick="document.getElementById('modal-subir-picto').style.display='flex'"
                style="padding:8px 18px;background:#2563eb;color:white;border:none;border-radius:8px;font-weight:700;font-size:0.88rem;cursor:pointer;display:flex;align-items:center;gap:6px;white-space:nowrap;">
                <i data-lucide="upload" style="width:15px;height:15px;"></i>
                + Subir Pictograma
              </button>
              <% } %>
            </div>

            <% if (pictogramas.length === 0) { %>
            <div style="border:2px dashed #e2e8f0;border-radius:10px;padding:48px;text-align:center;color:#94a3b8;">
              <i data-lucide="image-off" style="width:40px;height:40px;margin-bottom:12px;display:block;margin-left:auto;margin-right:auto;"></i>
              <p style="font-weight:700;font-size:1rem;margin-bottom:4px;">No hay pictogramas todavía</p>
              <% if (isAdminOrSuper) { %>
              <p style="font-size:0.85rem;">Sube el primer pictograma con el botón de arriba.</p>
              <% } %>
            </div>
            <% } else { %>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:16px;margin-top:8px;">
              <% pictogramas.forEach(p => { %>
              <div style="border:2px solid <%= p.activo ? '#e2e8f0' : '#fecaca' %>;border-radius:12px;padding:16px;text-align:center;background:<%= p.activo ? 'white' : '#fff5f5' %>;">
                <img src="<%= p.imagen_url %>" alt="<%= p.nombre %>"
                  style="width:80px;height:80px;object-fit:contain;margin-bottom:10px;filter:grayscale(100%) contrast(1.3);">
                <p style="font-size:0.85rem;font-weight:700;color:#1e293b;margin-bottom:4px;line-height:1.2;"><%= p.nombre %></p>
                <% if (!p.activo) { %>
                <span style="font-size:0.72rem;color:#dc2626;font-weight:700;display:block;margin-bottom:8px;">INACTIVO</span>
                <% } %>
                <% if (isAdminOrSuper) { %>
                <div style="display:flex;gap:6px;justify-content:center;margin-top:8px;">
                  <form action="/pictogramas/<%= p.id %>/toggle-activo" method="POST" style="margin:0;">
                    <button type="submit"
                      style="padding:5px 10px;border:none;border-radius:6px;font-size:0.75rem;font-weight:700;cursor:pointer;background:<%= p.activo ? '#f1f5f9' : '#dcfce7' %>;color:<%= p.activo ? '#64748b' : '#166534' %>;">
                      <%= p.activo ? 'Desactivar' : 'Activar' %>
                    </button>
                  </form>
                  <% if (isAdmin) { %>
                  <form action="/pictogramas/<%= p.id %>/eliminar" method="POST" style="margin:0;"
                    onsubmit="return confirm('¿Eliminar «<%= p.nombre %>»? Se desasignará de todos los envíos.')">
                    <button type="submit"
                      style="padding:5px 10px;border:none;border-radius:6px;font-size:0.75rem;font-weight:700;cursor:pointer;background:#fee2e2;color:#dc2626;">
                      Eliminar
                    </button>
                  </form>
                  <% } %>
                </div>
                <% } %>
              </div>
              <% }) %>
            </div>
            <% } %>
          </div>

          <!-- Modal: Subir pictograma -->
          <% if (isAdminOrSuper) { %>
          <div id="modal-subir-picto" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center;">
            <div style="background:white;border-radius:16px;padding:32px;width:460px;max-width:95vw;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
                <h3 style="font-size:1.1rem;font-weight:800;color:#1e293b;">Subir Pictograma</h3>
                <button type="button" onclick="document.getElementById('modal-subir-picto').style.display='none'"
                  style="background:none;border:none;cursor:pointer;font-size:1.4rem;color:#94a3b8;">&times;</button>
              </div>
              <form action="/pictogramas/subir" method="POST" enctype="multipart/form-data">
                <div style="margin-bottom:16px;">
                  <label style="display:block;font-size:0.85rem;font-weight:700;color:#374151;margin-bottom:6px;">Nombre *</label>
                  <input type="text" name="nombre" required placeholder="Ej: Frágil, Este lado arriba, Mantener seco..."
                    style="width:100%;padding:10px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.9rem;">
                </div>
                <div style="margin-bottom:20px;">
                  <label style="display:block;font-size:0.85rem;font-weight:700;color:#374151;margin-bottom:6px;">Imagen *</label>
                  <input type="file" name="imagen" accept="image/*" required
                    style="width:100%;padding:8px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.85rem;">
                  <p style="font-size:0.78rem;color:#94a3b8;margin-top:4px;">PNG, JPG, SVG, WEBP — máx. 5 MB.</p>
                  <div style="margin-top:8px;padding:10px 12px;background:#fffbeb;border:1px solid #fcd34d;border-radius:8px;font-size:0.78rem;color:#92400e;line-height:1.5;">
                    💡 <strong>Recomendación:</strong> Usa imágenes cuadradas de <strong>200 × 200 px</strong> mínimo (idealmente 400 × 400 px) en fondo transparente o blanco, en blanco y negro para mejor contraste al imprimir. Formatos vectoriales (SVG) o PNG con alta resolución dan mejores resultados en la etiqueta térmica.
                  </div>
                </div>
                <div style="display:flex;gap:10px;justify-content:flex-end;">
                  <button type="button" onclick="document.getElementById('modal-subir-picto').style.display='none'"
                    style="padding:10px 20px;background:#f1f5f9;color:#374151;border:none;border-radius:8px;font-weight:600;cursor:pointer;">
                    Cancelar
                  </button>
                  <button type="submit"
                    style="padding:10px 20px;background:#2563eb;color:white;border:none;border-radius:8px;font-weight:700;cursor:pointer;">
                    Subir
                  </button>
                </div>
              </form>
            </div>
          </div>
          <% } %>

