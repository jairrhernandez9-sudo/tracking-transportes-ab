        <!-- SECCIONES INFORMATIVAS -->
        <div style="background: #fce7f3; border-left: 4px solid #ec4899; padding: 16px 20px; border-radius: 8px; margin: 24px 0;">
        <strong style="color: #9f1239; display: block; margin-bottom: 8px;">📄 Secciones Informativas</strong>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
