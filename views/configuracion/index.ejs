  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    lucide.createIcons();

    // ── Búsqueda global ──────────────────────────────────
    (function() {
      var si = document.getElementById('searchInput');
      if (!si) return;
      var t;
      si.addEventListener('input', function() {
        clearTimeout(t);
        var v = this.value.trim();
        if (v) t = setTimeout(function() {
          window.location.href = '/envios?buscar=' + encodeURIComponent(v);
        }, 500);
      });
      si.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && this.value.trim()) {
          clearTimeout(t);
          window.location.href = '/envios?buscar=' + encodeURIComponent(this.value.trim());
        }
      });
    })();

    // User Profile Dropdown
    const userProfileBtn = document.getElementById('userProfileBtn');
    const userDropdown = document.getElementById('userDropdown');
    
    if (userProfileBtn && userDropdown) {
      userProfileBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        userProfileBtn.classList.toggle('open');
        userDropdown.classList.toggle('show');
        lucide.createIcons();
      });
      
      document.addEventListener('click', function(e) {
        if (!userProfileBtn.contains(e.target)) {
          userProfileBtn.classList.remove('open');
          userDropdown.classList.remove('show');
        }
      });
      
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          userProfileBtn.classList.remove('open');
          userDropdown.classList.remove('show');
        }
      });
    }
    
    // Tabs
    function openTab(event, tabName) {
      const tabContents = document.querySelectorAll('.tab-content');
      tabContents.forEach(tab => tab.classList.remove('active'));

      const tabBtns = document.querySelectorAll('.tab-btn');
      tabBtns.forEach(btn => btn.classList.remove('active'));

      document.getElementById(tabName).classList.add('active');
      event.currentTarget.classList.add('active');

      lucide.createIcons();
    }

    // Activar el tab correcto al cargar la página
    document.addEventListener('DOMContentLoaded', function() {
      const tabInicial = '<%= tabInicial %>';
      const tabEl = document.getElementById(tabInicial);
      if (tabEl) {
        tabEl.classList.add('active');
        const tabBtn = document.querySelector(`[onclick="openTab(event, '${tabInicial}')"]`);
        if (tabBtn) tabBtn.classList.add('active');
      } else {
        // Fallback: activar el primero visible
        const primerTab = document.querySelector('.tab-content');
        const primerBtn = document.querySelector('.tab-btn');
        if (primerTab) primerTab.classList.add('active');
        if (primerBtn) primerBtn.classList.add('active');
      }
      lucide.createIcons();
    });
  </script>

