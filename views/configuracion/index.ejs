        <input type="checkbox" name="mostrar_ubicaciones_tracking" <%= config.tracking.mostrar_ubicaciones_tracking ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
