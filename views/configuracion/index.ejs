                       onmouseout="this.style.borderColor='#e5e7eb'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.04)'">
                    <div style="display: flex; justify-content: space-between; align-items: start;">
                      <div style="flex: 1;">
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                          <h3 style="font-size: 1.25rem; font-weight: 700; color: #1f2937; margin: 0;">
                            <%= dir.alias %>
                          </h3>
                          <span style="padding: 3px 10px; background: #ede9fe; color: #6d28d9; border-radius: 6px; font-size: 0.72rem; font-weight: 700;">UNIVERSAL</span>
                        </div>
                        <div style="color: #4b5563; line-height: 1.6;">
                          <p style="margin: 0 0 4px 0; font-weight: 500;">📍 <%= dir.calle %>, <%= dir.colonia %></p>
                          <p style="margin: 0 0 4px 0;">🏙️ <%= dir.ciudad %>, <%= dir.estado %>, <%= dir.cp %></p>
                          <% if (dir.referencia) { %>
                            <p style="margin: 8px 0 0 0; padding: 8px 12px; background: #f9fafb; border-radius: 6px; font-size: 0.875rem;">
                              ℹ️ <strong>Ref:</strong> <%= dir.referencia %>
                            </p>
                          <% } %>
                        </div>
                      </div>
                      <div style="display: flex; gap: 8px; flex-shrink: 0;">
                        <button
                          class="btn-editar-direccion"
                          data-id="<%= dir.id %>"
                          data-alias="<%= dir.alias %>"
                          data-tipo="<%= dir.tipo || 'destino' %>"
                          data-calle="<%= dir.calle %>"
                          data-colonia="<%= dir.colonia %>"
                          data-ciudad="<%= dir.ciudad %>"
                          data-estado="<%= dir.estado %>"
                          data-cp="<%= dir.cp %>"
                          data-referencia="<%= dir.referencia || '' %>"
                          data-predeterminada="<%= dir.es_predeterminada ? 'true' : 'false' %>"
                          style="padding: 8px 12px; background: #8b5cf6; color: white; border: none; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.875rem;"
                          onmouseover="this.style.background='#7c3aed'"
                          onmouseout="this.style.background='#8b5cf6'"
                        >
                          <i data-lucide="edit-2" style="width: 16px; height: 16px;"></i> Editar
                        </button>
                        <form action="/configuracion/direcciones/<%= dir.id %>/eliminar" method="POST" style="margin: 0;" onsubmit="return confirm('¿Eliminar esta dirección universal?')">
                          <button type="submit" style="padding: 8px 12px; background: #ef4444; color: white; border: none; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.875rem;" onmouseover="this.style.background='#dc2626'" onmouseout="this.style.background='#ef4444'">
                            <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i> Eliminar
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div style="background: #f9fafb; padding: 40px; border-radius: 12px; text-align: center; border: 2px dashed #d1d5db;">
                <i data-lucide="map-pin-off" style="width: 56px; height: 56px; color: #9ca3af; margin: 0 auto 12px; display: block;"></i>
                <h3 style="font-size: 1.1rem; font-weight: 700; color: #4b5563; margin-bottom: 6px;">No hay destinos universales</h3>
                <p style="color: #6b7280; margin-bottom: 20px; font-size: 0.9rem;">Agrega ubicaciones de destino disponibles para todos los clientes</p>
                <button onclick="modalNuevaDireccionDestino()" style="padding: 10px 22px; background: #8b5cf6; color: white; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
                  <i data-lucide="plus" style="width: 16px; height: 16px;"></i> Agregar Primer Destino Universal
                </button>
              </div>
            <% } %>
          </div><!-- /config-card Destinos Universales -->

        </div><!-- /tab direcciones -->
        
        <!-- TAB: TARIFAS -->
        <div id="tarifas" class="tab-content">
          <form action="/configuracion/tarifas" method="POST">
            <div class="config-card" style="max-width: 800px;">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="dollar-sign" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Configuración de Tarifas
                </h2>
                <p class="card-description">Define los precios base de tus servicios</p>
              </div>
              
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Tarifa base por envío</label>
                  <input 
                    type="number" 
                    name="tarifa_base" 
                    class="form-input" 
                    value="<%= config.tarifas.tarifa_base || 0 %>"
                    step="0.01"
                    min="0"
                  >
                  <p class="form-help">Precio mínimo por envío (MXN)</p>
                </div>
                
                <div class="form-group">
                  <label class="form-label">Costo por kilómetro</label>
                  <input 
                    type="number" 
                    name="tarifa_por_km" 
                    class="form-input" 
                    value="<%= config.tarifas.tarifa_por_km || 0 %>"
                    step="0.01"
                    min="0"
                  >
                  <p class="form-help">Precio por km adicional (MXN)</p>
                </div>
              </div>
              
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Costo de seguro</label>
                  <input 
                    type="number" 
                    name="tarifa_seguro" 
                    class="form-input" 
                    value="<%= config.tarifas.tarifa_seguro || 0 %>"
                    step="0.01"
                    min="0"
                  >
                  <p class="form-help">Seguro opcional (MXN)</p>
                </div>
                
                <div class="form-group">
                  <label class="form-label">Porcentaje de IVA</label>
                  <input 
                    type="number" 
                    name="iva_porcentaje" 
                    class="form-input" 
                    value="<%= config.tarifas.iva_porcentaje || 16 %>"
                    step="0.01"
                    min="0"
                    max="100"
                  >
                  <p class="form-help">IVA aplicable (%)</p>
                </div>
              </div>
              
              <div class="info-box">
                <i data-lucide="info" style="width: 20px; height: 20px;"></i>
                <div class="info-text">
                  <strong>Ejemplo de cálculo:</strong> Para un envío de 50 km:<br>
                  Tarifa base (<%= config.tarifas.tarifa_base || 0 %> MXN) + (50 km × <%= config.tarifas.tarifa_por_km || 0 %> MXN) + Seguro (<%= config.tarifas.tarifa_seguro || 0 %> MXN) + IVA (<%= config.tarifas.iva_porcentaje || 16 %>%)
                </div>
              </div>
            </div>
            
            <!-- Función de crédito -->
            <div class="config-card" style="max-width: 800px; margin-top: 20px;">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="credit-card" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Función de pago por crédito
                </h2>
                <p class="card-description">Controla si el sistema permite asignar crédito a los clientes</p>
              </div>

              <div class="switch-group">
                <div class="switch-label">
                  <div class="switch-title">Crédito</div>
                  <div class="switch-description">Esta función habilita la opción de Crédito para todos los clientes. Si se desactiva, todos los envíos se registrarán como Pago en una Sola Exhibición (PUE / Contado).</div>
                </div>
                <label class="switch">
                  <input type="checkbox" name="credito_habilitado" <%= (config.tarifas.credito_habilitado !== false) ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>
            </div>

            <button type="submit" class="btn-primary">
              <i data-lucide="save" style="width: 18px; height: 18px;"></i>
              Guardar tarifas
            </button>
          </form>
        </div>
        
        <!-- TAB: NOTIFICACIONES (solo admin) -->
        <% if (esAdmin) { %>
        <div id="notificaciones" class="tab-content">
          <form action="/configuracion/notificaciones" method="POST">
            <div class="config-card" style="max-width: 800px;">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="bell" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Sistema de Notificaciones
                </h2>
                <p class="card-description">Configura cómo y cuándo enviar notificaciones</p>
              </div>
              
              <div class="switch-group">
                <div class="switch-label">
                  <div class="switch-title">Notificaciones por Email</div>
                  <div class="switch-description">Enviar notificaciones vía correo electrónico</div>
                </div>
                <label class="switch">
                  <input type="checkbox" name="notif_email_activo" <%= config.notificaciones.notif_email_activo ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>
              
              <div class="switch-group">
                <div class="switch-label">
                  <div class="switch-title">Notificaciones por SMS</div>
                  <div class="switch-description">Enviar notificaciones vía mensajes de texto</div>
                </div>
                <label class="switch">
                  <input type="checkbox" name="notif_sms_activo" <%= config.notificaciones.notif_sms_activo ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>
              
              <div style="margin: 30px 0; border-top: 2px solid #f1f5f9; padding-top: 20px;">
                <h3 style="font-weight: 800; color: #0f172a; margin-bottom: 15px; font-size: 1rem;">Eventos a Notificar</h3>
              </div>
              
              <div class="switch-group">
                <div class="switch-label">
                  <div class="switch-title">Envío Creado</div>
                  <div class="switch-description">Notificar cuando se registra un nuevo envío</div>
                </div>
                <label class="switch">
                  <input type="checkbox" name="notif_envio_creado" <%= config.notificaciones.notif_envio_creado ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>
              
              <div class="switch-group">
                <div class="switch-label">
                  <div class="switch-title">Envío Entregado</div>
                  <div class="switch-description">Notificar cuando un envío es entregado</div>
                </div>
                <label class="switch">
                  <input type="checkbox" name="notif_envio_entregado" <%= config.notificaciones.notif_envio_entregado ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>
              
              <div class="switch-group">
                <div class="switch-label">
                  <div class="switch-title">Envío Retrasado</div>
                  <div class="switch-description">Notificar cuando un envío supera el tiempo esperado</div>
                </div>
                <label class="switch">
                  <input type="checkbox" name="notif_envio_retrasado" <%= config.notificaciones.notif_envio_retrasado ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
              </div>
            </div>
            
            <button type="submit" class="btn-primary">
              <i data-lucide="save" style="width: 18px; height: 18px;"></i>
              Guardar configuración
            </button>
          </form>
        </div>
        <% } /* fin if esAdmin - tab notificaciones */ %>

        <!-- TAB: ALERTAS -->
        <div id="alertas" class="tab-content">
          <form action="/configuracion/alertas" method="POST">
            <div class="config-card" style="max-width: 800px;">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="alert-triangle" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Alertas Automáticas
                </h2>
                <p class="card-description">Configura los tiempos para alertas del sistema</p>
              </div>
              
              <div class="form-row">
