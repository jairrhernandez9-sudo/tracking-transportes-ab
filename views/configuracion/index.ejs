              </form>
            </div>
          </div>
          <% } %>

        </div><!-- /tab guia -->
        <% } %>

        <!-- ============================================ -->
        <!-- TAB: PÁGINA DE INICIO                        -->
        <!-- ============================================ -->
        <div id="pagina-inicio" class="tab-content">
          <form action="/configuracion/pagina-inicio" method="POST">
            <div class="config-card">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="home" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Página de inicio
                </h2>
                <p class="card-description">Elige a qué página ir al iniciar sesión</p>
              </div>

              <div style="max-width: 520px; margin-top: 8px;">
                <p style="font-size: 0.875rem; color: #64748b; margin-bottom: 20px;">
                  Selecciona la página que se abrirá automáticamente cada vez que inicies sesión en el sistema.
                </p>

                <%
                  const opcionesPagina = [
                    { valor: '/dashboard',          icono: 'layout-dashboard', label: 'Dashboard',           desc: 'Resumen general del sistema' },
                    { valor: '/envios',              icono: 'package',          label: 'Envíos',              desc: 'Lista de todos los envíos' },
                    { valor: '/envios-retrasados',   icono: 'alert-triangle',   label: 'Envíos Retrasados',   desc: 'Envíos con retraso o alertas' },
                    { valor: '/historial',           icono: 'history',          label: 'Historial',           desc: 'Historial de estados y eventos' },
                  ];
                %>

                <div style="display: flex; flex-direction: column; gap: 10px;">
                  <% opcionesPagina.forEach(function(op) { %>
                    <label style="display: flex; align-items: center; gap: 14px; padding: 14px 16px; border: 2px solid <%= paginaInicio === op.valor ? '#3b82f6' : '#e2e8f0' %>; border-radius: 12px; cursor: pointer; background: <%= paginaInicio === op.valor ? '#eff6ff' : '#fff' %>; transition: all .15s;"
                           onmouseover="if('<%= paginaInicio %>'!=='<%= op.valor %>'){this.style.borderColor='#93c5fd';this.style.background='#f8fafc'}"
                           onmouseout="if('<%= paginaInicio %>'!=='<%= op.valor %>'){this.style.borderColor='#e2e8f0';this.style.background='#fff'}">
                      <input type="radio" name="pagina_inicio" value="<%= op.valor %>"
                             <%= paginaInicio === op.valor ? 'checked' : '' %>
                             style="accent-color: #3b82f6; width: 18px; height: 18px; flex-shrink: 0;">
                      <i data-lucide="<%= op.icono %>" style="width: 20px; height: 20px; color: <%= paginaInicio === op.valor ? '#3b82f6' : '#94a3b8' %>; flex-shrink: 0;"></i>
