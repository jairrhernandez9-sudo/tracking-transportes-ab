                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                          <h3 style="font-size: 1.25rem; font-weight: 700; color: #1f2937; margin: 0;">
                            <%= dir.alias %>
                          </h3>
                          <% if (dir.es_predeterminada) { %>
                            <span style="padding: 4px 12px; background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); color: white; border-radius: 6px; font-size: 0.75rem; font-weight: 700; display: flex; align-items: center; gap: 4px;">
                              <i data-lucide="star" style="width: 12px; height: 12px;"></i>
                              PREDETERMINADA
                            </span>
                          <% } %>
                        </div>
                        
                        <div style="color: #4b5563; line-height: 1.6;">
                          <p style="margin: 0 0 4px 0; font-weight: 500;">
                            📍 <%= dir.calle %>, <%= dir.colonia %>
                          </p>
                          <p style="margin: 0 0 4px 0;">
                            🏙️ <%= dir.ciudad %>, <%= dir.estado %>, <%= dir.cp %>
                          </p>
                          <% if (dir.referencia) { %>
                            <p style="margin: 8px 0 0 0; padding: 8px 12px; background: #f9fafb; border-radius: 6px; font-size: 0.875rem;">
                              ℹ️ <strong>Ref:</strong> <%= dir.referencia %>
                            </p>
                          <% } %>
                        </div>
                      </div>
                      
                      <!-- Botones de acción -->
                      <div style="display: flex; gap: 8px; flex-shrink: 0;">
