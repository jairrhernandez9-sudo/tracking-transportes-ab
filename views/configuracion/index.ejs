                              <% if (gpTel) { %><div style="font-size:7.5pt;font-weight:bold;margin-top:2px;">Tel: +<%= gpTel.replace(/\D/g,'') %><% if(gpTelAd){ %> &nbsp;|&nbsp; +<%= gpTelAd.replace(/\D/g,'') %><% } %></div><% } %>
                            </td>
