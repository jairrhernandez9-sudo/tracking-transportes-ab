                            <button 
                              type="submit"
                              title="Marcar como predeterminada"
                              style="padding: 8px 12px; background: #fbbf24; color: white; border: none; border-radius: 8px; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.875rem;"
                              onmouseover="this.style.background='#f59e0b'"
                              onmouseout="this.style.background='#fbbf24'"
                            >
                              <i data-lucide="star" style="width: 16px; height: 16px;"></i>
                              Predeterminada
                            </button>
                          </form>
                        <% } %>
                        
                        <button 
                          class="btn-editar-direccion"
                          data-id="<%= dir.id %>"
                          data-alias="<%= dir.alias %>"
                          data-calle="<%= dir.calle %>"
                          data-colonia="<%= dir.colonia %>"
                          data-ciudad="<%= dir.ciudad %>"
                          data-estado="<%= dir.estado %>"
                          data-cp="<%= dir.cp %>"
                          data-referencia="<%= dir.referencia || '' %>"
                          data-tipo="<%= dir.tipo || 'origen' %>"
                          data-predeterminada="<%= dir.es_predeterminada ? 'true' : 'false' %>"
                          style="padding: 8px 12px; background: #3b82f6; color: white; border: none; border-radius: 8px; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.875rem;"
                          onmouseover="this.style.background='#2563eb'"
                          onmouseout="this.style.background='#3b82f6'"
                        >
                          <i data-lucide="edit-2" style="width: 16px; height: 16px;"></i>
                          Editar
                        </button>
                        
                        <form action="/configuracion/direcciones/<%= dir.id %>/eliminar" method="POST" style="margin: 0;" onsubmit="return confirm('¿Eliminar esta dirección?')">
                          <button 
                            type="submit"
                            style="padding: 8px 12px; background: #ef4444; color: white; border: none; border-radius: 8px; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.875rem;"
                            onmouseover="this.style.background='#dc2626'"
                            onmouseout="this.style.background='#ef4444'"
                          >
                            <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i>
                            Eliminar
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div style="background: #f9fafb; padding: 48px; border-radius: 12px; text-align: center; border: 2px dashed #d1d5db;">
                <i data-lucide="map-pin" style="width: 64px; height: 64px; color: #9ca3af; margin: 0 auto 16px; display: block;"></i>
                <h3 style="font-size: 1.25rem; font-weight: 700; color: #4b5563; margin-bottom: 8px;">
                  No hay direcciones registradas
                </h3>
                <p style="color: #6b7280; margin-bottom: 24px;">
                  Agrega las ubicaciones desde donde tu empresa envía paquetes
                </p>
                <button 
                  onclick="modalNuevaDireccion()"
                  style="padding: 12px 24px; background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;"
                >
                  <i data-lucide="plus" style="width: 18px; height: 18px;"></i>
                  Agregar Primera Dirección
                </button>
              </div>
            <% } %>
          </div><!-- /config-card Bodegas -->

          <!-- ── DESTINOS UNIVERSALES ── -->
