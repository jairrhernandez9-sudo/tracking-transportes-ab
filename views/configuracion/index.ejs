        <!-- ============================================ -->
        <!-- TAB: ETIQUETA -->
        <!-- ============================================ -->
        <div id="etiqueta" class="tab-content">

          <%
            // Lista de elementos de la etiqueta con sus claves y etiquetas
            const etqElementos = [
              { key: 'logo',                 icon: '🖼️',  label: 'Logo',                   desc: 'Imagen del logo en la cabecera',         grupo: 'empresa' },
              { key: 'eslogan',              icon: '✍️',  label: 'Eslogan / Tagline',       desc: 'Frase debajo del nombre de empresa',     grupo: 'empresa' },
              { key: 'telefono',             icon: '📞', label: 'Teléfono principal',       desc: 'Aparece en la barra de contacto',        grupo: 'empresa' },
              { key: 'telefono_adicional',   icon: '📱', label: 'Teléfono adicional',       desc: 'WhatsApp / número secundario',           grupo: 'empresa' },
              { key: 'email',                icon: '✉️',  label: 'Email corporativo',        desc: 'Correo en barra de contacto',            grupo: 'empresa' },
              { key: 'sitio_web',            icon: '🌐', label: 'Sitio web',                desc: 'URL en barra de contacto',               grupo: 'empresa' },
              { key: 'rfc',                  icon: '🪪', label: 'RFC',                       desc: 'Aparece en el pie de la etiqueta',       grupo: 'empresa' },
              { key: 'direccion_fiscal',     icon: '📍', label: 'Dirección fiscal',         desc: 'Aparece en el pie de la etiqueta',       grupo: 'empresa' },
              { key: 'barcode',              icon: '▤',  label: 'Código de barras',         desc: 'Barcode del número de tracking',         grupo: 'envio' },
              { key: 'qr',                   icon: '◼',  label: 'Código QR',                desc: 'QR para rastreo en línea',               grupo: 'envio' },
              { key: 'ruta',                 icon: '→',  label: 'Ruta Origen / Destino',   desc: 'Barra con ciudades de salida y llegada', grupo: 'envio' },
              { key: 'descripcion',          icon: '📝', label: 'Descripción del paquete', desc: 'Contenido declarado en el pie',          grupo: 'envio' }
            ];
            // Template seleccionado actualmente (el que venía en ?template_id= o el primero)
            const tplId = parseInt(query.template_id) || (etiquetaTemplates.length > 0 ? etiquetaTemplates[0].id : null);
            const tplActivo = etiquetaTemplates.find(t => t.id === tplId) || etiquetaTemplates[0] || null;
            const isAdmin = user.rol === 'admin';
            const isAdminOrSuper = user.rol === 'admin' || user.rol === 'superusuario';
          %>

          <!-- ── Selector de template ── -->
          <div class="config-card" style="margin-bottom: 20px;">
            <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
              <label style="font-size: 0.9rem; font-weight: 700; color: #374151; white-space: nowrap;">
                <i data-lucide="layers" style="width:16px;height:16px;vertical-align:-3px;color:#3b82f6;"></i>
                Template de impresión de Cliente:
              </label>

              <% if (etiquetaTemplates.length > 0) { %>
              <select id="tpl-selector" onchange="cambiarTemplate(this.value)"
                style="padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; font-weight: 600; color: #374151; background: white; cursor: pointer; min-width: 220px;">
                <% etiquetaTemplates.forEach(t => { %>
                  <option value="<%= t.id %>" <%= t.id === tplId ? 'selected' : '' %>><%= t.nombre %></option>
                <% }) %>
              </select>
              <% } else { %>
              <span style="color:#94a3b8; font-size:0.88rem;">No hay templates creados aún</span>
              <% } %>

              <% if (isAdminOrSuper) { %>
              <button type="button" onclick="abrirModalNuevoTemplate()"
                style="padding: 8px 18px; background: #2563eb; color: white; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: pointer; display: flex; align-items: center; gap: 6px;">
                <i data-lucide="plus" style="width:15px;height:15px;"></i>
                Crear nuevo Template
              </button>
              <% } %>

              <% if (tplActivo) { %>
                <% if (isAdmin) { %>
                <form action="/configuracion/etiqueta/templates/<%= tplActivo.id %>/eliminar" method="POST"
                  onsubmit="return confirm('¿Eliminar el template «<%= tplActivo.nombre %>»? Se desasignará de todos los clientes.')"
                  style="margin: 0;">
                  <button type="submit"
                    style="padding: 8px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: pointer;">
                    <i data-lucide="trash-2" style="width:15px;height:15px;"></i>
                  </button>
                </form>
                <% } else if (isAdminOrSuper) { %>
                <button type="button" disabled title="Solo el administrador puede eliminar templates"
                  style="padding: 8px 12px; background: #f1f5f9; color: #cbd5e1; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: not-allowed;">
                  <i data-lucide="trash-2" style="width:15px;height:15px;"></i>
                </button>
                <% } %>
              <% } %>
            </div>

            <% if (etiquetaTemplates.length > 0) { %>
            <p style="font-size: 0.8rem; color: #64748b; margin-top: 10px;">
              El template se puede asignar o editar en la sección de <a href="/clientes" style="color:#2563eb;">Clientes</a>.
            </p>
            <% } %>
          </div>

          <!-- ── Formulario del template seleccionado ── -->
          <% if (tplActivo && isAdminOrSuper) { %>
          <form action="/configuracion/etiqueta/templates/<%= tplActivo.id %>/guardar" method="POST">
            <div class="config-card">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="tag" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Elementos de la Etiqueta Térmica
                </h2>
                <p class="card-description">
                  Controla qué información aparece en cada etiqueta de envío.
                  Si el campo está vacío en la pestaña Empresa, no se mostrará aunque el toggle esté activo.
                </p>
              </div>

              <!-- Nombre del template -->
              <div style="margin-bottom: 20px; padding-bottom: 20px; border-bottom: 2px solid #f1f5f9; display: flex; align-items: center; gap: 12px;">
                <label style="font-size: 0.85rem; font-weight: 700; color: #374151; white-space: nowrap;">Nombre del template:</label>
                <input type="text" name="nombre" value="<%= tplActivo.nombre %>"
                  style="flex: 1; max-width: 320px; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; font-weight: 600;" required>
              </div>

              <!-- Cabecera de columnas -->
              <div style="display: grid; grid-template-columns: 1fr 100px 100px; gap: 0; margin-bottom: 8px; padding: 0 0 8px 0; border-bottom: 2px solid #f1f5f9;">
                <div style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;"></div>
                <div style="text-align: center; font-size: 0.75rem; font-weight: 800; color: #3b82f6; text-transform: uppercase; letter-spacing: 0.5px;">Por defecto</div>
                <div style="text-align: center; font-size: 0.75rem; font-weight: 800; color: #ec4899; text-transform: uppercase; letter-spacing: 0.5px;">Obligatorio</div>
              </div>

              <!-- GRUPO EMPRESA -->
              <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin: 12px 0 8px;">Datos de la empresa</p>
              <% etqElementos.filter(e => e.grupo === 'empresa').forEach(el => { %>
              <div style="display: grid; grid-template-columns: 1fr 100px 100px; align-items: center; padding: 10px 0; border-bottom: 1px solid #f8fafc;">
                <div>
                  <div style="font-size: 0.9rem; font-weight: 600; color: #1e293b;"><%= el.icon %> <%= el.label %></div>
                  <div style="font-size: 0.78rem; color: #64748b;"><%= el.desc %></div>
                </div>
                <!-- Por defecto (azul) -->
                <div style="text-align: center;">
                  <label class="switch">
                    <input type="checkbox" name="mostrar_<%= el.key %>" <%= tplActivo['mostrar_' + el.key] ? 'checked' : '' %>>
                    <span class="slider"></span>
                  </label>
                </div>
                <!-- Obligatorio (rosa) -->
                <div style="text-align: center;">
                  <label class="switch switch-pink">
                    <input type="checkbox" name="obligatorio_<%= el.key %>" <%= tplActivo['obligatorio_' + el.key] ? 'checked' : '' %>>
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
              <% }) %>

              <!-- GRUPO ENVÍO -->
              <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin: 20px 0 8px;">Elementos del envío</p>
              <% etqElementos.filter(e => e.grupo === 'envio').forEach(el => { %>
              <div style="display: grid; grid-template-columns: 1fr 100px 100px; align-items: center; padding: 10px 0; border-bottom: 1px solid #f8fafc;">
                <div>
                  <div style="font-size: 0.9rem; font-weight: 600; color: #1e293b;"><%= el.icon %> <%= el.label %></div>
                  <div style="font-size: 0.78rem; color: #64748b;"><%= el.desc %></div>
                </div>
                <div style="text-align: center;">
                  <label class="switch">
                    <input type="checkbox" name="mostrar_<%= el.key %>" <%= tplActivo['mostrar_' + el.key] ? 'checked' : '' %>>
                    <span class="slider"></span>
                  </label>
                </div>
                <div style="text-align: center;">
                  <label class="switch switch-pink">
                    <input type="checkbox" name="obligatorio_<%= el.key %>" <%= tplActivo['obligatorio_' + el.key] ? 'checked' : '' %>>
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
              <% }) %>

              <!-- Nota + guardar -->
              <div class="info-box" style="margin-top: 20px;">
                <i data-lucide="info" style="width: 20px; height: 20px;"></i>
                <div class="info-text">
                  Los campos vacíos no se imprimen aunque el toggle esté activo.
                  Cuando el campo <strong>Obligatorio</strong> está activado, esa función siempre podrá ser imprimible;
                  si está desactivada por defecto siempre estará apagada y no podrá ser visible en la impresión.
                </div>
              </div>

              <div style="margin-top: 20px; padding-top: 20px; border-top: 2px solid #f1f5f9;">
                <button type="submit" class="btn-primary">
                  <i data-lucide="save" style="width: 18px; height: 18px;"></i>
                  Guardar configuración de etiqueta
                </button>
              </div>
            </div>
          </form>
          <% } else if (!tplActivo) { %>
          <div class="config-card" style="text-align: center; padding: 48px; color: #94a3b8;">
            <i data-lucide="tag" style="width: 48px; height: 48px; margin-bottom: 12px;"></i>
            <p style="font-weight: 700; font-size: 1rem;">No hay templates de etiqueta</p>
            <% if (isAdminOrSuper) { %>
            <p style="font-size: 0.85rem; margin-top: 6px;">Crea el primer template con el botón de arriba.</p>
            <% } %>
          </div>
          <% } %>

          <!-- ── Modal: Crear nuevo template ── -->
          <% if (isAdminOrSuper) { %>
          <div id="modal-nuevo-tpl" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">
            <div style="background:white; border-radius:16px; padding:32px; width:520px; max-width:95vw; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                <h3 style="font-size:1.1rem; font-weight:800; color:#1e293b;">Crear nuevo Template</h3>
                <button type="button" onclick="cerrarModalNuevoTemplate()" style="background:none;border:none;cursor:pointer;font-size:1.4rem;color:#94a3b8;">&times;</button>
              </div>
              <form action="/configuracion/etiqueta/templates/nuevo" method="POST">
                <div style="margin-bottom: 16px;">
                  <label style="display:block; font-size:0.85rem; font-weight:700; color:#374151; margin-bottom:6px;">Nombre del template *</label>
                  <input type="text" name="nombre" required placeholder="Ej: Planta Norte, Almacen 1..."
                    style="width:100%; padding:10px 12px; border:2px solid #e2e8f0; border-radius:8px; font-size:0.9rem; font-weight:600;">
                </div>
                <p style="font-size:0.8rem; color:#64748b; margin-bottom:16px;">El template se creará con todos los elementos activados por defecto. Podrás editarlo después.</p>
                <div style="display:flex; gap:10px; justify-content:flex-end;">
                  <button type="button" onclick="cerrarModalNuevoTemplate()"
                    style="padding:10px 20px; background:#f1f5f9; color:#374151; border:none; border-radius:8px; font-weight:600; cursor:pointer;">
                    Cancelar
                  </button>
                  <button type="submit"
                    style="padding:10px 20px; background:#2563eb; color:white; border:none; border-radius:8px; font-weight:700; cursor:pointer;">
                    Crear Template
                  </button>
                </div>
              </form>
            </div>
          </div>
          <% } %>

        </div><!-- /tab etiqueta -->

        <!-- ============================================ -->
        <!-- TAB: GUÍA EXPEDIDA                           -->
        <!-- ============================================ -->
        <% if (!esOperador) { %>
        <div id="guia" class="tab-content">

          <%
            const guiaElementos = [
              // Encabezado
              { key: 'logo',                  icon: '🖼️',  label: 'Logo empresa',             desc: 'Imagen del logo en el encabezado',           grupo: 'encabezado' },
              { key: 'rfc',                   icon: '🪪',  label: 'RFC',                       desc: 'RFC de la empresa en encabezado',            grupo: 'encabezado' },
              { key: 'telefono',              icon: '📞', label: 'Teléfonos',                  desc: 'Tel. principal y adicional en encabezado',   grupo: 'encabezado' },
              { key: 'sitio_web',             icon: '🌐', label: 'Sitio web / Privacidad',     desc: 'URL en cláusula de seguro',                  grupo: 'encabezado' },
              { key: 'barcode',               icon: '▤',  label: 'Código de barras',           desc: 'Barcode del número de tracking',             grupo: 'encabezado' },
              // Secciones principales
              { key: 'seccion_remitente',     icon: '📦', label: 'Sección Remitente',          desc: 'Bloque de origen del envío',                 grupo: 'secciones' },
              { key: 'seccion_facturar',      icon: '🧾', label: 'Sección Facturar a',         desc: 'Bloque del cliente / facturación',           grupo: 'secciones' },
              { key: 'seccion_destinatario',  icon: '📍', label: 'Sección Destinatario',       desc: 'Bloque de destino del envío',                grupo: 'secciones' },
              { key: 'clausula_seguro',       icon: '🛡️', label: 'Cláusula de seguro',         desc: 'Texto de seguro y tipo de servicio',         grupo: 'secciones' },
              // Condiciones / fechas
              { key: 'retorno_documentos',    icon: '↩️', label: 'Retorno de documentos',      desc: 'Campo para retorno de documentos',           grupo: 'condiciones' },
              { key: 'condiciones_pago',      icon: '💳', label: 'Condiciones de pago',        desc: 'CRÉDITO / CONTADO, etc.',                   grupo: 'condiciones' },
              { key: 'fecha_emision',         icon: '📅', label: 'Fecha de emisión',           desc: 'Fecha, hora y nombre del documento',         grupo: 'condiciones' },
              { key: 'observaciones',         icon: '📝', label: 'Observaciones del cliente',  desc: 'Campo libre de observaciones',               grupo: 'condiciones' },
              { key: 'fecha_entrega',         icon: '🗓️', label: 'Fecha estimada de entrega',  desc: 'Fecha estimada capturada en el envío',       grupo: 'condiciones' },
              { key: 'referencia_cliente',    icon: '🔖', label: 'Referencia del cliente',     desc: 'Número de referencia del cliente',           grupo: 'condiciones' },
              // Entrega
              { key: 'recibido_por',          icon: '✍️',  label: 'Sección Recibido por',       desc: 'Firma de recibido e incidencias',            grupo: 'entrega' },
              { key: 'operador',              icon: '🚛', label: 'Operador que entregó',       desc: 'Nombre del operador y comentarios',          grupo: 'entrega' },
              { key: 'firma_final',           icon: '📋', label: 'Tabla de firma final',       desc: 'Acepta condiciones del contrato',            grupo: 'entrega' },
              // Pie
              { key: 'pie_datos',             icon: '📊', label: 'Datos de mercancía / estado', desc: 'Estado, tracking, origen, destino al pie', grupo: 'pie' },
              { key: 'disclaimer',            icon: '⚠️', label: 'Aviso fiscal',               desc: '"No es comprobante fiscal"',                grupo: 'pie' },
              // Columnas tabla
              { key: 'col_volumen',           icon: '📐', label: 'Columna Volumen',            desc: 'Columna Volumen Mts.³ en tabla de carga',    grupo: 'tabla' },
              { key: 'col_peso_facturado',    icon: '⚖️', label: 'Columna Peso Facturado',     desc: 'Columna Peso Facturado Kgs.',                grupo: 'tabla' },
              { key: 'col_servicios',         icon: '🔧', label: 'Columna Servicios',          desc: 'Columna Servicios en tabla de carga',        grupo: 'tabla' },
              { key: 'col_importe',           icon: '💰', label: 'Columna Importe',            desc: 'Columna Importe en tabla de carga',          grupo: 'tabla' },
            ];
            const guiaTplId = parseInt(query.guia_template_id) || (guiaTemplates.length > 0 ? guiaTemplates[0].id : null);
            const guiaTplActivo = guiaTemplates.find(t => t.id === guiaTplId) || guiaTemplates[0] || null;
          %>

          <!-- Selector de template -->
          <div class="config-card" style="margin-bottom: 20px;">
            <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
              <label style="font-size: 0.9rem; font-weight: 700; color: #374151; white-space: nowrap;">
                <i data-lucide="file-text" style="width:16px;height:16px;vertical-align:-3px;color:#3b82f6;"></i>
                Template de Guía Expedida:
              </label>

              <% if (guiaTemplates.length > 0) { %>
              <select id="guia-tpl-selector" onchange="cambiarGuiaTemplate(this.value)"
                style="padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; font-weight: 600; color: #374151; background: white; cursor: pointer; min-width: 220px;">
                <% guiaTemplates.forEach(t => { %>
                  <option value="<%= t.id %>" <%= t.id === guiaTplId ? 'selected' : '' %>><%= t.nombre %></option>
                <% }) %>
              </select>
              <% } else { %>
              <span style="color:#94a3b8; font-size:0.88rem;">No hay templates creados aún</span>
              <% } %>

              <% if (isAdminOrSuper) { %>
              <button type="button" onclick="abrirModalNuevoGuiaTpl()"
                style="padding: 8px 18px; background: #2563eb; color: white; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: pointer; display: flex; align-items: center; gap: 6px;">
                <i data-lucide="plus" style="width:15px;height:15px;"></i>
                Crear nuevo Template
              </button>
              <% } %>

              <% if (guiaTplActivo) { %>
                <% if (isAdmin) { %>
                <form action="/configuracion/guia/templates/<%= guiaTplActivo.id %>/eliminar" method="POST"
