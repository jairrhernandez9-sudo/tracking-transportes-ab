        <input type="checkbox" name="mostrar_seccion_features" <%= config.tracking.mostrar_seccion_features ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Sección de Estadísticas</div>
        <div class="switch-description">Mostrar números y logros de la empresa</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_seccion_stats" <%= config.tracking.mostrar_seccion_stats ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Sección "¿Cómo funciona?"</div>
        <div class="switch-description">Mostrar pasos del proceso de tracking</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_seccion_como_funciona" <%= config.tracking.mostrar_seccion_como_funciona ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Sección de Contacto/CTA</div>
        <div class="switch-description">Mostrar llamada a la acción y datos de contacto</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_seccion_cta" <%= config.tracking.mostrar_seccion_cta ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <!-- INFO BOX -->
        <div class="info-box" style="margin-top: 24px;">
        <i data-lucide="shield" style="width: 20px; height: 20px;"></i>
        <div class="info-text">
        <strong>Privacidad y Control:</strong> Estas opciones te permiten controlar exactamente qué información ven tus clientes en el tracking público. Desactiva las opciones que contengan información sensible o que prefieras mantener privada.
        </div>
        </div>

        <% } /* fin if esAdmin - secciones extra de tracking */ %>
        </div><!-- /config-card tracking -->

        <button type="submit" class="btn-primary">
        <i data-lucide="save" style="width: 18px; height: 18px;"></i>
        Guardar configuración de tracking
        </button>
        </form>
        </div>

        <!-- ============================================ -->
        <!-- TAB: IMPRIMIBLES (Etiqueta + Guía + Pictogramas) -->
        <!-- ============================================ -->
        <% if (!esOperador) { %>
        <% const impSubInicial = ['etiqueta','guia','pictogramas'].includes(tabInicial) ? tabInicial : 'etiqueta'; %>
        <div id="imprimibles" class="tab-content">

          <!-- Sub-tabs de Imprimibles -->
          <div style="display:flex;gap:4px;margin-bottom:24px;border-bottom:2px solid #e2e8f0;padding-bottom:0;">
            <button id="imp-btn-etiqueta" onclick="switchImpSubtab('etiqueta')"
              style="padding:8px 18px;border:none;background:none;cursor:pointer;font-size:0.92rem;font-weight:600;border-bottom:3px solid transparent;margin-bottom:-2px;color:#64748b;border-radius:4px 4px 0 0;transition:all .15s;">
              <i data-lucide="tag" style="width:15px;height:15px;vertical-align:middle;margin-right:5px;"></i>Etiqueta
            </button>
            <button id="imp-btn-guia" onclick="switchImpSubtab('guia')"
              style="padding:8px 18px;border:none;background:none;cursor:pointer;font-size:0.92rem;font-weight:600;border-bottom:3px solid transparent;margin-bottom:-2px;color:#64748b;border-radius:4px 4px 0 0;transition:all .15s;">
              <i data-lucide="file-text" style="width:15px;height:15px;vertical-align:middle;margin-right:5px;"></i>Guía Expedida
            </button>
            <button id="imp-btn-pictogramas" onclick="switchImpSubtab('pictogramas')"
              style="padding:8px 18px;border:none;background:none;cursor:pointer;font-size:0.92rem;font-weight:600;border-bottom:3px solid transparent;margin-bottom:-2px;color:#64748b;border-radius:4px 4px 0 0;transition:all .15s;">
              <i data-lucide="image" style="width:15px;height:15px;vertical-align:middle;margin-right:5px;"></i>Pictogramas
            </button>
          </div>

          <!-- Panel: Etiqueta -->
          <div id="imp-panel-etiqueta">

          <%
            // Lista de elementos de la etiqueta con sus claves y etiquetas
            const etqElementos = [
              { key: 'logo',                 icon: '🖼️',  label: 'Logo',                   desc: 'Imagen del logo en la cabecera',         grupo: 'empresa' },
              { key: 'eslogan',              icon: '✍️',  label: 'Eslogan / Tagline',       desc: 'Frase debajo del nombre de empresa',     grupo: 'empresa' },
              { key: 'telefono',             icon: '📞', label: 'Teléfono principal',       desc: 'Aparece en la barra de contacto',        grupo: 'empresa' },
              { key: 'telefono_adicional',   icon: '📱', label: 'Teléfono adicional',       desc: 'WhatsApp / número secundario',           grupo: 'empresa' },
              { key: 'email',                icon: '✉️',  label: 'Email corporativo',        desc: 'Correo en barra de contacto',            grupo: 'empresa' },
              { key: 'sitio_web',            icon: '🌐', label: 'Sitio web',                desc: 'URL en barra de contacto',               grupo: 'empresa' },
              { key: 'rfc',                  icon: '🪪', label: 'RFC',                       desc: 'Aparece en el pie de la etiqueta',       grupo: 'empresa' },
              { key: 'direccion_fiscal',     icon: '📍', label: 'Dirección fiscal',         desc: 'Aparece en el pie de la etiqueta',       grupo: 'empresa' },
              { key: 'barcode',              icon: '▤',  label: 'Código de barras',         desc: 'Barcode del número de tracking',         grupo: 'envio' },
              { key: 'qr',                   icon: '◼',  label: 'Código QR',                desc: 'QR para rastreo en línea',               grupo: 'envio' },
              { key: 'ruta',                 icon: '→',  label: 'Ruta Origen / Destino',   desc: 'Barra con ciudades de salida y llegada', grupo: 'envio' },
              { key: 'alias_ruta',           icon: '🏷', label: 'Alias de sucursal',        desc: 'Muestra el alias de la dirección en vez de la ciudad', grupo: 'envio' },
              { key: 'peso_total',           icon: '⚖️', label: 'Peso total de guía',       desc: 'Peso total del envío (suma todos los ítems)', grupo: 'envio' },
              { key: 'peso_item',            icon: '📦', label: 'Peso por ítem',            desc: 'Peso individual del ítem etiquetado',    grupo: 'envio' },
              { key: 'descripcion',          icon: '📝', label: 'Descripción del paquete', desc: 'Contenido declarado en el pie',          grupo: 'envio' },
              { key: 'dest_nombre',          icon: '🏢', label: 'Nombre destinatario',     desc: 'Nombre/empresa en ENTREGAR A',           grupo: 'envio' },
              { key: 'dest_direccion',       icon: '📍', label: 'Dirección destinatario',  desc: 'Dirección completa en ENTREGAR A',        grupo: 'envio' },
              { key: 'dest_referencia',      icon: '🔖', label: 'Referencia destino',      desc: 'Ref. de entrega en ENTREGAR A',           grupo: 'envio' },
              { key: 'dest_contacto',        icon: '👤', label: 'Contacto destinatario',   desc: 'Nombre del contacto en ENTREGAR A',      grupo: 'envio' },
              { key: 'dest_telefono',        icon: '📞', label: 'Teléfono destinatario',   desc: 'Tel. del destinatario en ENTREGAR A',    grupo: 'envio' }
            ];
            // Template seleccionado actualmente (tpl tras guardar, template_id al navegar, o el primero)
            const tplId = parseInt(query.tpl) || parseInt(query.template_id) || (etiquetaTemplates.length > 0 ? etiquetaTemplates[0].id : null);
            const tplActivo = etiquetaTemplates.find(t => t.id === tplId) || etiquetaTemplates[0] || null;
            const isAdmin = user.rol === 'admin';
            const isAdminOrSuper = user.rol === 'admin' || user.rol === 'superusuario';
          %>

          <!-- ── Selector de template ── -->
          <div class="config-card" style="margin-bottom: 20px;">
            <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
              <label style="font-size: 0.9rem; font-weight: 700; color: #374151; white-space: nowrap;">
                <i data-lucide="layers" style="width:16px;height:16px;vertical-align:-3px;color:#3b82f6;"></i>
                Template de impresión de Cliente:
              </label>

              <% if (etiquetaTemplates.length > 0) { %>
              <select id="tpl-selector" onchange="cambiarTemplate(this.value)"
                style="padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; font-weight: 600; color: #374151; background: white; cursor: pointer; min-width: 220px;">
                <% etiquetaTemplates.forEach(t => { %>
                  <option value="<%= t.id %>" <%= t.id === tplId ? 'selected' : '' %>><%= t.nombre %></option>
                <% }) %>
              </select>
              <% } else { %>
              <span style="color:#94a3b8; font-size:0.88rem;">No hay templates creados aún</span>
              <% } %>

              <% if (isAdminOrSuper) { %>
              <button type="button" onclick="abrirModalNuevoTemplate()"
                style="padding: 8px 18px; background: #2563eb; color: white; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: pointer; display: flex; align-items: center; gap: 6px;">
                <i data-lucide="plus" style="width:15px;height:15px;"></i>
                Crear nuevo Template
              </button>
              <% } %>

              <% if (tplActivo) { %>
                <% if (isAdmin) { %>
                <form action="/configuracion/etiqueta/templates/<%= tplActivo.id %>/eliminar" method="POST"
                  onsubmit="return confirm('¿Eliminar el template «<%= tplActivo.nombre %>»? Se desasignará de todos los clientes.')"
                  style="margin: 0;">
                  <button type="submit"
                    style="padding: 8px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: pointer;">
                    <i data-lucide="trash-2" style="width:15px;height:15px;"></i>
                  </button>
                </form>
                <% } else if (isAdminOrSuper) { %>
                <button type="button" disabled title="Solo el administrador puede eliminar templates"
                  style="padding: 8px 12px; background: #f1f5f9; color: #cbd5e1; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: not-allowed;">
                  <i data-lucide="trash-2" style="width:15px;height:15px;"></i>
                </button>
                <% } %>
              <% } %>
            </div>

            <% if (etiquetaTemplates.length > 0) { %>
            <p style="font-size: 0.8rem; color: #64748b; margin-top: 10px;">
              El template se puede asignar o editar en la sección de <a href="/clientes" style="color:#2563eb;">Clientes</a>.
            </p>
            <% } %>
          </div>

          <!-- ── Formulario del template seleccionado ── -->
          <% if (tplActivo && isAdminOrSuper) { %>
          <form action="/configuracion/etiqueta/templates/<%= tplActivo.id %>/guardar" method="POST">
            <div class="config-card">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="tag" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Elementos de la Etiqueta Térmica
                </h2>
                <p class="card-description">
                  Controla qué información aparece en cada etiqueta de envío.
                  Si el campo está vacío en la pestaña Empresa, no se mostrará aunque el toggle esté activo.
                </p>
              </div>

              <!-- Nombre del template -->
              <div style="margin-bottom: 20px; padding-bottom: 20px; border-bottom: 2px solid #f1f5f9; display: flex; align-items: center; gap: 12px;">
                <label style="font-size: 0.85rem; font-weight: 700; color: #374151; white-space: nowrap;">Nombre del template:</label>
                <input type="text" name="nombre" value="<%= tplActivo.nombre %>"
                  style="flex: 1; max-width: 320px; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; font-weight: 600;" required>
              </div>

              <!-- Sub-tabs -->
              <div style="display: flex; gap: 4px; margin-bottom: 20px; background: #f1f5f9; border-radius: 10px; padding: 4px; width: fit-content;">
                <button type="button" id="etq-subtab-btn-elementos" onclick="switchEtqSubtab('elementos')"
                  style="padding: 7px 18px; border: none; border-radius: 7px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all .15s; background: #2563eb; color: white; box-shadow: 0 1px 4px rgba(37,99,235,.25);">
                  Elementos
                </button>
                <button type="button" id="etq-subtab-btn-textos" onclick="switchEtqSubtab('textos')"
                  style="padding: 7px 18px; border: none; border-radius: 7px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all .15s; background: transparent; color: #64748b;">
                  Textos editables
                </button>
                <button type="button" id="etq-subtab-btn-tamanos" onclick="switchEtqSubtab('tamanos')"
                  style="padding: 7px 18px; border: none; border-radius: 7px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all .15s; background: transparent; color: #64748b;">
                  Tamaño de Textos
                </button>
              </div>

              <!-- Sub-tab: Elementos (toggles) -->
              <div id="etq-subtab-elementos">
                <div style="display: flex; gap: 28px; align-items: flex-start;">

                  <!-- ── Columna izquierda: toggles ── -->
                  <div style="flex: 1; min-width: 0;">

                    <!-- Cabecera de columnas -->
                    <div style="display: grid; grid-template-columns: 1fr 100px 100px; gap: 0; margin-bottom: 8px; padding: 0 0 8px 0; border-bottom: 2px solid #f1f5f9;">
                      <div style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;"></div>
                      <div style="text-align: center; font-size: 0.75rem; font-weight: 800; color: #3b82f6; text-transform: uppercase; letter-spacing: 0.5px;">Por defecto</div>
                      <div style="text-align: center; font-size: 0.75rem; font-weight: 800; color: #ec4899; text-transform: uppercase; letter-spacing: 0.5px;">Obligatorio</div>
                    </div>

                    <!-- GRUPO EMPRESA -->
                    <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin: 12px 0 8px;">Datos de la empresa</p>
                    <% etqElementos.filter(e => e.grupo === 'empresa').forEach(el => { %>
                    <div style="display: grid; grid-template-columns: 1fr 100px 100px; align-items: center; padding: 10px 0; border-bottom: 1px solid #f8fafc;">
                      <div>
                        <div style="font-size: 0.9rem; font-weight: 600; color: #1e293b;"><%= el.icon %> <%= el.label %></div>
                        <div style="font-size: 0.78rem; color: #64748b;"><%= el.desc %></div>
                      </div>
                      <div style="text-align: center;">
                        <label class="switch">
                          <input type="checkbox" name="mostrar_<%= el.key %>" onchange="syncEtqPreview()" <%= tplActivo['mostrar_' + el.key] ? 'checked' : '' %>>
                          <span class="slider"></span>
                        </label>
                      </div>
                      <div style="text-align: center;">
                        <label class="switch switch-pink">
                          <input type="checkbox" name="obligatorio_<%= el.key %>" <%= tplActivo['obligatorio_' + el.key] ? 'checked' : '' %>>
                          <span class="slider"></span>
                        </label>
                      </div>
                    </div>
                    <% }) %>

                    <!-- GRUPO ENVÍO -->
                    <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin: 20px 0 8px;">Elementos del envío</p>
                    <% etqElementos.filter(e => e.grupo === 'envio').forEach(el => { %>
                    <div style="display: grid; grid-template-columns: 1fr 100px 100px; align-items: center; padding: 10px 0; border-bottom: 1px solid #f8fafc;">
                      <div>
                        <div style="font-size: 0.9rem; font-weight: 600; color: #1e293b;"><%= el.icon %> <%= el.label %></div>
                        <div style="font-size: 0.78rem; color: #64748b;"><%= el.desc %></div>
                      </div>
                      <div style="text-align: center;">
                        <label class="switch">
                          <input type="checkbox" name="mostrar_<%= el.key %>" onchange="syncEtqPreview()" <%= tplActivo['mostrar_' + el.key] ? 'checked' : '' %>>
                          <span class="slider"></span>
                        </label>
                      </div>
                      <div style="text-align: center;">
                        <label class="switch switch-pink">
                          <input type="checkbox" name="obligatorio_<%= el.key %>" <%= tplActivo['obligatorio_' + el.key] ? 'checked' : '' %>>
                          <span class="slider"></span>
                        </label>
                      </div>
                    </div>
                    <% }) %>

                    <div class="info-box" style="margin-top: 20px;">
                      <i data-lucide="info" style="width: 20px; height: 20px;"></i>
                      <div class="info-text">
                        Los campos vacíos no se imprimen aunque el toggle esté activo.
                        <strong>Obligatorio</strong> significa que el toggle en la etiqueta estará fijo y no podrá desactivarse.
                        <strong>Por defecto</strong> define el estado inicial al abrir la etiqueta.
                      </div>
                    </div>
                  </div><!-- /col-izquierda -->

                  <!-- ── Columna derecha: mini preview ── -->
                  <div style="flex-shrink: 0; position: sticky; top: 80px;">
                    <div style="font-size: 0.7rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px; text-align: center; display: flex; align-items: center; justify-content: center; gap: 6px;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                      Vista previa
