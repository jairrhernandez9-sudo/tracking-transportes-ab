              { key: 'remitente_telefono',       icon: ' ↳', label: 'Teléfono',                   desc: 'Teléfono del remitente',                     grupo: 'secciones', sub: true },
              { key: 'seccion_facturar',         icon: '🧾', label: 'Sección Facturar a',         desc: 'Bloque del cliente / facturación',           grupo: 'secciones' },
              { key: 'facturar_nombre',          icon: ' ↳', label: 'Nombre/Empresa',             desc: 'Nombre o razón social del cliente',          grupo: 'secciones', sub: true },
              { key: 'facturar_direccion',       icon: ' ↳', label: 'Dirección',                  desc: 'Dirección del cliente',                      grupo: 'secciones', sub: true },
              { key: 'facturar_contacto',        icon: ' ↳', label: 'Contacto (Attn)',            desc: 'Nombre del contacto',                        grupo: 'secciones', sub: true },
              { key: 'facturar_telefono',        icon: ' ↳', label: 'Teléfono',                   desc: 'Teléfono del cliente',                       grupo: 'secciones', sub: true },
              { key: 'facturar_email',           icon: ' ↳', label: 'Email',                      desc: 'Correo electrónico del cliente',             grupo: 'secciones', sub: true },
              { key: 'facturar_rfc',             icon: ' ↳', label: 'RFC',                        desc: 'RFC del cliente',                            grupo: 'secciones', sub: true },
              { key: 'seccion_destinatario',     icon: '📍', label: 'Sección Destinatario',       desc: 'Bloque de destino del envío',                grupo: 'secciones' },
              { key: 'destinatario_nombre',      icon: ' ↳', label: 'Nombre',                     desc: 'Nombre/ciudad destino',                      grupo: 'secciones', sub: true },
              { key: 'destinatario_direccion',   icon: ' ↳', label: 'Dirección',                  desc: 'Dirección completa del destino',             grupo: 'secciones', sub: true },
              { key: 'clausula_seguro',          icon: '🛡️', label: 'Cláusula de seguro',         desc: 'Texto de seguro y tipo de servicio',         grupo: 'secciones' },
              // Condiciones / fechas
              { key: 'retorno_documentos',    icon: '↩️', label: 'Retorno de documentos',      desc: 'Campo para retorno de documentos',           grupo: 'condiciones' },
              { key: 'condiciones_pago',      icon: '💳', label: 'Condiciones de pago',        desc: 'CRÉDITO / CONTADO, etc.',                   grupo: 'condiciones' },
              { key: 'fecha_emision',         icon: '📅', label: 'Fecha de emisión',           desc: 'Fecha, hora y nombre del documento',         grupo: 'condiciones' },
              { key: 'observaciones',         icon: '📝', label: 'Observaciones del cliente',  desc: 'Campo libre de observaciones',               grupo: 'condiciones' },
              { key: 'fecha_entrega',         icon: '🗓️', label: 'Fecha estimada de entrega',  desc: 'Fecha estimada capturada en el envío',       grupo: 'condiciones' },
              { key: 'referencia_cliente',    icon: '🔖', label: 'Referencia del cliente',     desc: 'Número de referencia del cliente',           grupo: 'condiciones' },
              // Entrega
              { key: 'recibido_por',          icon: '✍️',  label: 'Sección Recibido por',       desc: 'Firma de recibido e incidencias',            grupo: 'entrega' },
              { key: 'obs_recibido',          icon: '📝', label: ' ↳ Columna Observaciones',   desc: 'Columna lateral de obs. en Recibido por',    grupo: 'entrega', sub: true },
              { key: 'operador',              icon: '🚛', label: 'Operador que entregó',       desc: 'Nombre del operador y comentarios',          grupo: 'entrega' },
              { key: 'obs_operador',          icon: '📝', label: ' ↳ Columna Observaciones',   desc: 'Columna lateral de obs. en Operador',        grupo: 'entrega', sub: true },
              { key: 'firma_final',           icon: '📋', label: 'Tabla de firma final',       desc: 'Acepta condiciones del contrato',            grupo: 'entrega' },
              // Pie
              { key: 'pie_datos',             icon: '📊', label: 'Datos de mercancía / estado', desc: 'Estado, tracking, origen, destino al pie', grupo: 'pie' },
              { key: 'disclaimer',            icon: '⚠️', label: 'Aviso fiscal',               desc: '"No es comprobante fiscal"',                grupo: 'pie' },
              // Columnas tabla
              { key: 'col_volumen',           icon: '📐', label: 'Columna Volumen',            desc: 'Columna Volumen Mts.³ en tabla de carga',    grupo: 'tabla' },
              { key: 'col_peso_facturado',    icon: '⚖️', label: 'Columna Peso Facturado',     desc: 'Columna Peso Facturado Kgs.',                grupo: 'tabla' },
              { key: 'col_servicios',         icon: '🔧', label: 'Columna Servicios',          desc: 'Columna Servicios en tabla de carga',        grupo: 'tabla' },
              { key: 'col_importe',           icon: '💰', label: 'Columna Importe',            desc: 'Columna Importe en tabla de carga',          grupo: 'tabla' },
            ];
            const guiaTplId = parseInt(query.tpl) || parseInt(query.guia_template_id) || (guiaTemplates.length > 0 ? guiaTemplates[0].id : null);
            const guiaTplActivo = guiaTemplates.find(t => t.id === guiaTplId) || guiaTemplates[0] || null;
          %>


          <!-- Selector de template -->
          <div class="config-card" style="margin-bottom: 20px;">
            <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
              <label style="font-size: 0.9rem; font-weight: 700; color: #374151; white-space: nowrap;">
                <i data-lucide="file-text" style="width:16px;height:16px;vertical-align:-3px;color:#3b82f6;"></i>
                Template de Guía Expedida:
              </label>

              <% if (guiaTemplates.length > 0) { %>
              <select id="guia-tpl-selector" onchange="cambiarGuiaTemplate(this.value)"
                style="padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; font-weight: 600; color: #374151; background: white; cursor: pointer; min-width: 220px;">
                <% guiaTemplates.forEach(t => { %>
                  <option value="<%= t.id %>" <%= t.id === guiaTplId ? 'selected' : '' %>><%= t.nombre %></option>
                <% }) %>
              </select>
              <% } else { %>
              <span style="color:#94a3b8; font-size:0.88rem;">No hay templates creados aún</span>
              <% } %>

              <% if (isAdminOrSuper) { %>
              <button type="button" onclick="abrirModalNuevoGuiaTpl()"
                style="padding: 8px 18px; background: #2563eb; color: white; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: pointer; display: flex; align-items: center; gap: 6px;">
                <i data-lucide="plus" style="width:15px;height:15px;"></i>
                Crear nuevo Template
              </button>
              <% } %>

              <% if (guiaTplActivo) { %>
                <% if (isAdmin) { %>
                <form action="/configuracion/guia/templates/<%= guiaTplActivo.id %>/eliminar" method="POST"
                  onsubmit="return confirm('¿Eliminar el template «<%= guiaTplActivo.nombre %>»?')"
                  style="margin: 0;">
                  <button type="submit"
                    style="padding: 8px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: pointer;">
                    <i data-lucide="trash-2" style="width:15px;height:15px;"></i>
                  </button>
                </form>
                <% } else if (isAdminOrSuper) { %>
                <button type="button" disabled title="Solo el administrador puede eliminar templates"
                  style="padding: 8px 12px; background: #f1f5f9; color: #cbd5e1; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: not-allowed;">
                  <i data-lucide="trash-2" style="width:15px;height:15px;"></i>
                </button>
                <% } %>
              <% } %>
            </div>
            <% if (guiaTemplates.length > 0) { %>
            <p style="font-size: 0.8rem; color: #64748b; margin-top: 10px;">
              El template se puede asignar en la sección de <a href="/clientes" style="color:#2563eb;">Clientes</a>.
            </p>
            <% } %>
          </div>

          <!-- Formulario del template seleccionado -->
          <% if (guiaTplActivo && isAdminOrSuper) { %>
          <form action="/configuracion/guia/templates/<%= guiaTplActivo.id %>/guardar" method="POST">
            <div class="config-card">
              <div class="card-header">
                <h2 class="card-title">
                  <i data-lucide="file-text" style="width: 24px; height: 24px; color: #3b82f6;"></i>
                  Elementos de la Guía Expedida
                </h2>
                <p class="card-description">Controla qué secciones y columnas aparecen en la guía de envío.</p>
              </div>

              <!-- Nombre del template -->
              <div style="margin-bottom: 20px; padding-bottom: 20px; border-bottom: 2px solid #f1f5f9; display: flex; align-items: center; gap: 12px;">
                <label style="font-size: 0.85rem; font-weight: 700; color: #374151; white-space: nowrap;">Nombre del template:</label>
                <input type="text" name="nombre" value="<%= guiaTplActivo.nombre %>"
                  style="flex: 1; max-width: 320px; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; font-weight: 600;" required>
              </div>

              <!-- Sub-tabs -->
              <div style="display: flex; gap: 4px; margin-bottom: 20px; background: #f1f5f9; border-radius: 10px; padding: 4px; width: fit-content;">
                <button type="button" id="guia-subtab-btn-elementos" onclick="switchGuiaSubtab('elementos')"
                  style="padding: 7px 18px; border: none; border-radius: 7px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all .15s; background: #2563eb; color: white; box-shadow: 0 1px 4px rgba(37,99,235,.25);">
                  Secciones y columnas
                </button>
                <button type="button" id="guia-subtab-btn-textos" onclick="switchGuiaSubtab('textos')"
                  style="padding: 7px 18px; border: none; border-radius: 7px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all .15s; background: transparent; color: #64748b;">
                  Textos editables
                </button>
                <button type="button" id="guia-subtab-btn-tamanos" onclick="switchGuiaSubtab('tamanos')"
                  style="padding: 7px 18px; border: none; border-radius: 7px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all .15s; background: transparent; color: #64748b;">
                  Tamaño de Textos
                </button>
              </div>

              <!-- Sub-tab: Secciones y columnas (toggles) -->
              <div id="guia-subtab-elementos">
                <!-- Cabecera de columnas -->
                <div style="display: grid; grid-template-columns: 1fr 100px 100px; gap: 0; margin-bottom: 8px; padding: 0 0 8px 0; border-bottom: 2px solid #f1f5f9;">
                  <div></div>
                  <div style="text-align: center; font-size: 0.75rem; font-weight: 800; color: #3b82f6; text-transform: uppercase; letter-spacing: 0.5px;">Por defecto</div>
                  <div style="text-align: center; font-size: 0.75rem; font-weight: 800; color: #ec4899; text-transform: uppercase; letter-spacing: 0.5px;">Obligatorio</div>
                </div>

                <% const guiaGrupos = [
                  { id: 'encabezado', label: 'Encabezado' },
                  { id: 'secciones',  label: 'Secciones principales' },
                  { id: 'condiciones', label: 'Condiciones / Fechas' },
                  { id: 'entrega',    label: 'Entrega / Firma' },
                  { id: 'pie',        label: 'Pie del documento' },
                  { id: 'tabla',      label: 'Columnas de la tabla de carga' },
                ]; %>

                <% guiaGrupos.forEach(function(gr) { %>
                <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin: 20px 0 8px;"><%= gr.label %></p>
                <% guiaElementos.filter(e => e.grupo === gr.id).forEach(function(el) { %>
                <div style="display: grid; grid-template-columns: 1fr 100px 100px; align-items: center; padding: 10px 0; border-bottom: 1px solid #f8fafc;<%= el.sub ? ' padding-left: 24px; background: #fafbfc;' : '' %>">
                  <div>
                    <div style="font-size: <%= el.sub ? '0.82rem' : '0.9rem' %>; font-weight: <%= el.sub ? '500' : '600' %>; color: <%= el.sub ? '#475569' : '#1e293b' %>;"><%= el.icon %> <%= el.label %></div>
                    <div style="font-size: 0.78rem; color: #64748b;"><%= el.desc %></div>
                  </div>
                  <div style="text-align: center;">
                    <label class="switch">
                      <input type="checkbox" name="mostrar_<%= el.key %>" <%= guiaTplActivo['mostrar_' + el.key] ? 'checked' : '' %>>
                      <span class="slider"></span>
                    </label>
                  </div>
                  <div style="text-align: center;">
                    <label class="switch switch-pink">
                      <input type="checkbox" name="obligatorio_<%= el.key %>" <%= guiaTplActivo['obligatorio_' + el.key] ? 'checked' : '' %>>
                      <span class="slider"></span>
                    </label>
                  </div>
                </div>
                <% }) %>
                <% }) %>

                <div class="info-box" style="margin-top: 20px;">
                  <i data-lucide="info" style="width: 20px; height: 20px;"></i>
                  <div class="info-text">
                    <strong>Obligatorio</strong> significa que el toggle en la guía estará fijo y no podrá desactivarse.
                    <strong>Por defecto</strong> define el estado inicial al abrir la guía.
                  </div>
                </div>
              </div>

              <!-- Sub-tab: Textos editables -->
              <div id="guia-subtab-textos" style="display: none;">

                <!-- Inputs: 2 columnas compactas arriba -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 2px solid #f1f5f9;">
                  <div>
                    <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Título y descripción</p>
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Descripción del servicio <span style="color:#94a3b8;font-weight:400;">(subtítulo)</span></label>
                        <input type="text" name="descripcion_servicio"
                          value="<%= guiaTplActivo.descripcion_servicio || '' %>"
                          placeholder="PAQUETERÍA, MENSAJERÍA Y CARGA CONSOLIDADA NACIONAL"
                          oninput="document.getElementById('gprev-descripcion').textContent = this.value || 'PAQUETERÍA, MENSAJERÍA Y CARGA CONSOLIDADA NACIONAL'"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Título principal <span style="color:#94a3b8;font-weight:400;">(ej: GUÍA EXPEDIDA, ENVÍO FORÁNEO)</span></label>
                        <input type="text" name="titulo_guia"
                          value="<%= guiaTplActivo.titulo_guia || '' %>"
                          placeholder="GUÍA EXPEDIDA"
                          oninput="document.getElementById('gprev-titulo').textContent = this.value || 'GUÍA EXPEDIDA'"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Encabezado columna descripción <span style="color:#94a3b8;font-weight:400;">(tabla de carga)</span></label>
                        <input type="text" name="etiqueta_col_descripcion"
                          value="<%= guiaTplActivo.etiqueta_col_descripcion || '' %>"
                          placeholder="DESCRIPCIÓN SEGÚN REMITENTE"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Etiqueta "Operador" <span style="color:#94a3b8;font-weight:400;">(sección de firma)</span></label>
                        <input type="text" name="etiqueta_operador"
                          value="<%= guiaTplActivo.etiqueta_operador || '' %>"
                          placeholder="Operador que entregó:"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Etiqueta "Observaciones" <span style="color:#94a3b8;font-weight:400;">(col. derecha del Operador)</span></label>
                        <input type="text" name="etiqueta_obs_operador"
                          value="<%= guiaTplActivo.etiqueta_obs_operador || '' %>"
                          placeholder="Observaciones:"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Etiqueta "Recibido por" <span style="color:#94a3b8;font-weight:400;">(título de sección)</span></label>
                        <input type="text" name="etiqueta_recibido_por"
                          value="<%= guiaTplActivo.etiqueta_recibido_por || '' %>"
                          placeholder="Recibido por: (Nombre, firma y sello)"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Etiqueta "Observaciones" <span style="color:#94a3b8;font-weight:400;">(col. derecha de Recibido por)</span></label>
                        <input type="text" name="etiqueta_obs_recibido"
                          value="<%= guiaTplActivo.etiqueta_obs_recibido || '' %>"
                          placeholder="Observaciones:"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                    </div>
                  </div>
                  <div>
                    <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Mensajes personalizables</p>
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Mensaje cláusula 1 <span style="color:#94a3b8;font-weight:400;">(después de tabla de carga)</span></label>
                        <input type="text" name="mensaje_1" value="<%= guiaTplActivo.mensaje_1 || '' %>" placeholder="[ MENSAJE PERSONALIZABLE ]"
                          oninput="gprevUpdateMsg1(this.value)"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Mensaje cláusula 2 <span style="color:#94a3b8;font-weight:400;">(después de Mensaje cláusula 1)</span></label>
                        <input type="text" name="mensaje_2" value="<%= guiaTplActivo.mensaje_2 || '' %>" placeholder="[ MENSAJE PERSONALIZABLE ]"
                          oninput="gprevUpdateMsg('gprev-msg2', this.value)"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Condiciones <span style="color:#94a3b8;font-weight:400;">(antes del pie de página)</span></label>
                        <input type="text" name="mensaje_3" value="<%= guiaTplActivo.mensaje_3 || '' %>" placeholder="[ MENSAJE PERSONALIZABLE ]"
                          oninput="gprevUpdateMsg('gprev-msg3', this.value)"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                      <div>
                        <label style="font-size: 0.82rem; font-weight: 700; color: #374151; display: block; margin-bottom: 4px;">Mensaje al final del documento <span style="color:#94a3b8;font-weight:400;">(después del disclaimer)</span></label>
                        <input type="text" name="mensaje_4" value="<%= guiaTplActivo.mensaje_4 || '' %>" placeholder="[ MENSAJE AL FINAL ]"
                          oninput="gprevUpdateMsg('gprev-msg4', this.value)"
                          style="width:100%;padding:8px 12px;border:2px solid #e2e8f0;border-radius:8px;font-size:0.88rem;">
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Preview: ancho completo abajo -->
                <p style="font-size: 0.75rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Vista previa de la guía</p>
                <div style="background: #c8cdd4; border-radius: 8px; padding: 16px; overflow-x: auto;">
                  <div style="zoom: 1; width: 810px; margin: 0 auto; font-family: Arial, Helvetica, sans-serif; font-size: 8pt; color: #000; background: white; padding: 5mm 6mm; box-shadow: 0 4px 20px rgba(0,0,0,.25);">

                        <%
                          const gpEmpresa  = (config.empresa && config.empresa.empresa_nombre) || 'TRANSPORTES';
                          const gpRfc      = (config.empresa && config.empresa.empresa_rfc) || '';
                          const gpTel      = (config.empresa && config.empresa.empresa_telefono) || '';
                          const gpTelAd    = (config.empresa && config.empresa.empresa_telefono_adicional) || '';
                          const gpDir      = (config.empresa && config.empresa.empresa_direccion) || '';
                          const gpLogo     = (config.empresa && config.empresa.empresa_logo_url) || '';
                          const gpAviso    = (config.empresa && config.empresa.empresa_aviso_privacidad) || '';
                          const gpDesc     = guiaTplActivo.descripcion_servicio || 'PAQUETERÍA, MENSAJERÍA Y CARGA CONSOLIDADA NACIONAL';
                          const gpTitulo   = guiaTplActivo.titulo_guia || 'GUÍA EXPEDIDA';
                          const gpMsg1     = guiaTplActivo.mensaje_1 || '';
                          const gpMsg2     = guiaTplActivo.mensaje_2 || '';
                          const gpMsg3     = guiaTplActivo.mensaje_3 || '';
                          const gpMsg4     = guiaTplActivo.mensaje_4 || '';
                        %>

                        <!-- Encabezado -->
                        <table style="border-collapse:collapse;width:100%;">
                          <tr>
                            <td style="width:24%;border:1px solid #000;padding:4px 6px;vertical-align:middle;">
                              <% if (gpLogo) { %><img src="<%= gpLogo %>" style="max-height:40px;max-width:100px;object-fit:contain;display:block;margin-bottom:2px;" alt=""><% } %>
                              <div style="font-size:9pt;font-weight:bold;"><%= gpEmpresa %></div>
                              <% if (gpRfc) { %><div style="font-size:7pt;color:#333;">RFC: <%= gpRfc %></div><% } %>
                            </td>
                            <td style="width:50%;border:1px solid #000;padding:4px 6px;text-align:center;vertical-align:middle;">
                              <div id="gprev-descripcion" style="font-size:8pt;color:#333;"><%= gpDesc %></div>
                              <div id="gprev-titulo" style="font-size:13pt;font-weight:bold;letter-spacing:.5px;margin:2px 0;"><%= gpTitulo %></div>
