    // Preview logo antes de subir
    function previewLogo(input) {
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
          const container = document.getElementById('logo-preview-container');
          container.innerHTML = '<img src="' + e.target.result + '" alt="Preview" style="max-height: 80px; max-width: 200px; object-fit: contain;">';
        };
        reader.readAsDataURL(input.files[0]);
      }
    }
    // Funciones para modal nueva dirección
    function modalNuevaDireccion() {
      document.getElementById('nuevaDirTipo').value = 'origen';
      document.getElementById('modalNuevaDireccion').querySelector('h2').textContent = 'Nueva Dirección de Origen';
      document.getElementById('modalNuevaDireccion').style.display = 'flex';
      lucide.createIcons();
    }

    function modalNuevaDireccionDestino() {
      document.getElementById('nuevaDirTipo').value = 'destino';
      document.getElementById('modalNuevaDireccion').querySelector('h2').textContent = 'Nueva Dirección Universal (Destino)';
      document.getElementById('modalNuevaDireccion').style.display = 'flex';
      lucide.createIcons();
    }

    function cerrarModalNuevaDireccion() {
      document.getElementById('modalNuevaDireccion').style.display = 'none';
    }
    
    // Funciones para modal editar dirección
    function modalEditarDireccion(id, alias, tipo, calle, colonia, ciudad, estado, cp, referencia, predeterminada) {
      document.getElementById('formEditarDireccion').action = '/configuracion/direcciones/' + id + '/editar';
      document.getElementById('edit_alias').value = alias;
      document.getElementById('edit_tipo').value = tipo || 'origen';
      document.getElementById('edit_calle').value = calle;
      document.getElementById('edit_colonia').value = colonia;
      document.getElementById('edit_ciudad').value = ciudad;
      document.getElementById('edit_estado').value = estado;
      document.getElementById('edit_cp').value = cp;
      document.getElementById('edit_referencia').value = referencia;
      document.getElementById('edit_predeterminada').checked = predeterminada === 'true' || predeterminada === true;

      document.getElementById('modalEditarDireccion').style.display = 'flex';
      lucide.createIcons();
    }

    // Event listener para botones de editar
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.btn-editar-direccion').forEach(function(btn) {
        btn.addEventListener('click', function() {
          modalEditarDireccion(
            this.dataset.id,
            this.dataset.alias,
            this.dataset.tipo,
            this.dataset.calle,
            this.dataset.colonia,
            this.dataset.ciudad,
            this.dataset.estado,
            this.dataset.cp,
            this.dataset.referencia,
            this.dataset.predeterminada
          );
        });
      });
    });
    
    function cerrarModalEditarDireccion() {
      document.getElementById('modalEditarDireccion').style.display = 'none';
    }
    
    // Cerrar con ESC
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        cerrarModalNuevaDireccion();
        cerrarModalEditarDireccion();
      }
    });
    
    // Cerrar haciendo clic fuera
    document.getElementById('modalNuevaDireccion').addEventListener('click', function(e) {
      if (e.target === this) cerrarModalNuevaDireccion();
    });
    
    document.getElementById('modalEditarDireccion').addEventListener('click', function(e) {
      if (e.target === this) cerrarModalEditarDireccion();
    });
  </script>
  <!-- Templates de etiqueta -->
  <script>
    function cambiarTemplate(id) {
      const url = new URL(window.location.href);
      url.searchParams.set('template_id', id);
      url.searchParams.set('tab', 'etiqueta');
      url.searchParams.delete('tpl');
      window.location.href = url.toString();
    }

    function abrirModalNuevoTemplate() {
      const m = document.getElementById('modal-nuevo-tpl');
      if (m) { m.style.display = 'flex'; }
    }
    function cerrarModalNuevoTemplate() {
      const m = document.getElementById('modal-nuevo-tpl');
      if (m) { m.style.display = 'none'; }
    }

    // Cerrar modal al clicar fuera
    document.addEventListener('click', function(e) {
      const m = document.getElementById('modal-nuevo-tpl');
      if (m && e.target === m) cerrarModalNuevoTemplate();
      const mg = document.getElementById('modal-nuevo-guia-tpl');
      if (mg && e.target === mg) cerrarModalNuevoGuiaTpl();
    });

    function cambiarGuiaTemplate(id) {
      const url = new URL(window.location.href);
      url.searchParams.set('guia_template_id', id);
      url.searchParams.set('tab', 'guia');
      url.searchParams.delete('tpl');
      window.location.href = url.toString();
    }
    function gprevUpdateMsg1(val) {
      const span = document.getElementById('gprev-msg1');
      const row  = document.getElementById('gprev-msg1-row');
      if (!span) return;
      const avisoEl = document.getElementById('gprev-aviso-text');
      const aviso = avisoEl ? avisoEl.dataset.aviso : '';
      const parts = [val, aviso ? 'Conoce nuestro aviso de Privacidad en: ' + aviso : ''].filter(Boolean);
      const full = parts.join(' ');
      span.textContent = full;
      if (row) row.style.display = full ? '' : 'none';
    }
    function gprevUpdateMsg(id, val) {
      const el = document.getElementById(id);
      if (!el) return;
      if (val) {
        el.textContent = val;
        el.style.display = '';
      } else {
        el.textContent = '';
        el.style.display = 'none';
      }
    }
    function switchEtqSubtab(tab) {
      const tabs = ['elementos', 'textos', 'tamanos'];
      tabs.forEach(function(t) {
        const el  = document.getElementById('etq-subtab-' + t);
        const btn = document.getElementById('etq-subtab-btn-' + t);
        if (!el || !btn) return;
        const active = t === tab;
        el.style.display     = active ? '' : 'none';
        btn.style.background = active ? '#2563eb' : 'transparent';
        btn.style.color      = active ? 'white'   : '#64748b';
        btn.style.boxShadow  = active ? '0 1px 4px rgba(37,99,235,.25)' : 'none';
      });
    }
    function switchImpSubtab(tab) {
      const panels = ['etiqueta', 'guia', 'pictogramas'];
      panels.forEach(function(t) {
        const el  = document.getElementById('imp-panel-' + t);
        const btn = document.getElementById('imp-btn-' + t);
        if (!el || !btn) return;
        const active = t === tab;
        el.style.display     = active ? '' : 'none';
        btn.style.borderBottomColor = active ? '#2563eb' : 'transparent';
        btn.style.color      = active ? '#2563eb' : '#64748b';
        btn.style.background = active ? '#eff6ff'  : 'none';
      });
    }
    function switchGuiaSubtab(tab) {
      const tabs = ['elementos', 'textos', 'tamanos'];
      tabs.forEach(function(t) {
        const el  = document.getElementById('guia-subtab-' + t);
        const btn = document.getElementById('guia-subtab-btn-' + t);
        if (!el || !btn) return;
        const active = t === tab;
        el.style.display     = active ? '' : 'none';
        btn.style.background = active ? '#2563eb' : 'transparent';
        btn.style.color      = active ? 'white'   : '#64748b';
        btn.style.boxShadow  = active ? '0 1px 4px rgba(37,99,235,.25)' : 'none';
      });
    }
    function abrirModalNuevoGuiaTpl() {
      const m = document.getElementById('modal-nuevo-guia-tpl');
      if (m) { m.style.display = 'flex'; }
    }
    function cerrarModalNuevoGuiaTpl() {
      const m = document.getElementById('modal-nuevo-guia-tpl');
      if (m) { m.style.display = 'none'; }
    }

    // ── Vista previa etiqueta térmica ──
    function syncEtqPreview() {
      var map = {
        logo:               'prev-logo',
        eslogan:            'prev-eslogan',
        telefono:           'prev-telefono',
        telefono_adicional: 'prev-telefono_adicional',
        email:              'prev-email',
        sitio_web:          'prev-sitio_web',
        rfc:                'prev-rfc',
        direccion_fiscal:   'prev-direccion_fiscal',
        barcode:            'prev-barcode',
        qr:                 'prev-qr',
        ruta:               'prev-ruta',
        descripcion:        'prev-descripcion',
        dest_nombre:        'prev-dest_nombre',
        dest_direccion:     'prev-dest_direccion',
        dest_referencia:    'prev-dest_referencia',
        dest_contacto:      'prev-dest_contacto',
        dest_telefono:      'prev-dest_telefono',
        peso_total:         'prev-peso_total',
        peso_item:          'prev-peso_item'
      };
      Object.keys(map).forEach(function(key) {
        var cb = document.querySelector('#etq-subtab-elementos input[name="mostrar_' + key + '"]');
        var el = document.getElementById(map[key]);
        if (cb && el) el.style.display = cb.checked ? '' : 'none';
      });
      // Barra de contacto: visible si al menos un dato de contacto está activo
      var contactKeys = ['telefono', 'telefono_adicional', 'email', 'sitio_web'];
      var showBar = contactKeys.some(function(k) {
        var cb = document.querySelector('#etq-subtab-elementos input[name="mostrar_' + k + '"]');
        return cb && cb.checked;
      });
      var bar = document.getElementById('prev-contacto-bar');
      if (bar) bar.style.display = showBar ? '' : 'none';
    }

    // ── Textos editables preview ──
    function syncEtqTextoPreview() {
      var map = {
        'texto_fecha_emision':    { id: 'pt-fecha-lbl',    def: 'Fecha emisión' },
        'texto_etiqueta':         { id: 'pt-etiqueta-lbl', def: 'Etiqueta' },
        'texto_entregar_a':       { id: 'pt-entregar-a',   def: 'Entregar a:' },
        'texto_peso':             { id: 'pt-det-peso-lbl',      def: 'Peso total' },
        'texto_peso_item':        { id: 'pt-det-peso-item-lbl', def: 'Peso' },
        'texto_entrega_estimada': { id: 'pt-det-fecha-lbl',def: 'Entrega estimada' },
        'texto_ref_cliente':      { id: 'pt-det-ref-lbl',  def: 'Ref. cliente' },
        'texto_descripcion':      { id: 'pt-desc-lbl',     def: 'Descripción / Contenido' }
      };
      Object.keys(map).forEach(function(name) {
        var input = document.querySelector('#etq-subtab-textos input[name="' + name + '"]');
        var el = document.getElementById(map[name].id);
        if (input && el) el.textContent = input.value.trim() || map[name].def;
      });
    }

    // ── Tamaños de texto preview ──
    function syncEtqSizePreview() {
      var keys = [
        'size_tracking','size_ruta_ciudad','size_empresa_nombre','size_eslogan',
        'size_tipo_servicio','size_dest_nombre','size_dest_direccion','size_dest_contacto',
        'size_detalle_valor','size_descripcion','size_barra_contacto',
        'size_ruta_etiqueta','size_detalle_etiqueta','size_cab_fecha','size_cab_num'
      ];
      keys.forEach(function(key) {
        var input = document.getElementById('range-' + key);
        if (!input) return;
        var val = input.value + 'px';
        document.querySelectorAll('#ps-preview [data-ps="' + key + '"]').forEach(function(el) {
          el.style.fontSize = val;
        });
      });
    }

    // Inicializar previews al cargar la página
    document.addEventListener('DOMContentLoaded', function() {
      syncEtqPreview();
      syncEtqTextoPreview();
      syncEtqSizePreview();
    });
  </script>
  <script src="/js/notifications.js"></script>
  <script src="/js/sidebar.js"></script>

  <!-- Datos para export bodegas -->
  <script>
    const _bodegasData = <%- JSON.stringify(direccionesOrigen || []) %>;

    function _bXmlEsc(str) {
      return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function imprimirBodegas() {
      document.body.classList.add('imprimiendo-bodegas');
      window.print();
      document.body.classList.remove('imprimiendo-bodegas');
    }
    function exportarPDFBodegas() { imprimirBodegas(); }

    function exportarCSVBodegas() {
      const rows = [['Alias','Calle','Colonia','Ciudad','Estado','CP','Referencia','Predeterminada']];
      _bodegasData.forEach(function(d) {
        rows.push([d.alias, d.calle, d.colonia, d.ciudad, d.estado, d.cp, d.referencia || '', d.es_predeterminada ? 'Sí' : 'No']);
      });
      const csv = rows.map(function(r) {
        return r.map(function(v) { return '"' + String(v).replace(/"/g,'""') + '"'; }).join(',');
      }).join('\n');
      const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url; a.download = 'bodegas.csv'; a.click();
      URL.revokeObjectURL(url);
    }

    function exportarExcelBodegas() {
      const fecha = new Date().toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' });
      const colDefs = [
        { label: 'Alias',          width: 130 },
        { label: 'Calle',          width: 180 },
        { label: 'Colonia',        width: 150 },
        { label: 'Ciudad',         width: 120 },
        { label: 'Estado',         width: 110 },
        { label: 'C.P.',           width: 65  },
        { label: 'Referencia',     width: 200 },
        { label: 'Predeterminada', width: 110 }
      ];
      const styles = `
 <Styles>
  <Style ss:ID="sb_title"><Font ss:Bold="1" ss:Size="13" ss:Color="#1E3A8A"/></Style>
  <Style ss:ID="sb_sub"><Font ss:Size="9" ss:Color="#6B7280"/><Alignment ss:Horizontal="Left"/></Style>
  <Style ss:ID="sb_hdr">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center"/>
   <Font ss:Bold="1" ss:Color="#FFFFFF" ss:Size="10"/>
   <Interior ss:Color="#1E40AF" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#1D4ED8"/>
   <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#1D4ED8"/>
   <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#1D4ED8"/></Borders>
  </Style>
  <Style ss:ID="sb_even">
   <Alignment ss:Vertical="Center"/><Font ss:Size="10" ss:Color="#374151"/>
   <Interior ss:Color="#F0F9FF" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#DBEAFE"/>
   <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#DBEAFE"/>
   <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#DBEAFE"/></Borders>
  </Style>
  <Style ss:ID="sb_odd">
   <Alignment ss:Vertical="Center"/><Font ss:Size="10" ss:Color="#374151"/>
   <Interior ss:Color="#FFFFFF" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/>
   <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/>
   <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/></Borders>
  </Style>
  <Style ss:ID="sb_pred">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center"/><Font ss:Bold="1" ss:Size="10" ss:Color="#92400E"/>
   <Interior ss:Color="#FEF3C7" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#FDE68A"/>
   <Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#FDE68A"/>
   <Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#FDE68A"/></Borders>
  </Style>
 </Styles>`;

      const cols = colDefs.map(function(c) { return '<Column ss:Width="' + c.width + '"/>'; }).join('');
      const nc = colDefs.length - 1;
      const hdrCells = colDefs.map(function(c) {
        return '<Cell ss:StyleID="sb_hdr"><Data ss:Type="String">' + c.label + '</Data></Cell>';
      }).join('');

      let bodyRows = '';
      _bodegasData.forEach(function(d, i) {
        const sRow = i % 2 === 0 ? 'sb_even' : 'sb_odd';
        const sPred = d.es_predeterminada ? 'sb_pred' : sRow;
        const vals = [d.alias, d.calle, d.colonia, d.ciudad, d.estado, d.cp, d.referencia || ''];
        const cells = vals.map(function(v) {
          return '<Cell ss:StyleID="' + sRow + '"><Data ss:Type="String">' + _bXmlEsc(v) + '</Data></Cell>';
        }).join('');
        bodyRows += '<Row ss:Height="22">' + cells + '<Cell ss:StyleID="' + sPred + '"><Data ss:Type="String">' + (d.es_predeterminada ? '★ Sí' : 'No') + '</Data></Cell></Row>\n';
      });

      const xml = '<?xml version="1.0" encoding="UTF-8"?>\n<?mso-application progid="Excel.Sheet"?>\n' +
        '<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"' +
        ' xmlns:o="urn:schemas-microsoft-com:office:office"' +
        ' xmlns:x="urn:schemas-microsoft-com:office:excel"' +
        ' xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">' +
        styles +
        '<Worksheet ss:Name="Bodegas"><Table>' + cols +
        '<Row ss:Height="30"><Cell ss:MergeAcross="' + nc + '" ss:StyleID="sb_title"><Data ss:Type="String">Direcciones de Origen — Bodegas</Data></Cell></Row>' +
        '<Row ss:Height="18"><Cell ss:MergeAcross="' + nc + '" ss:StyleID="sb_sub"><Data ss:Type="String">Exportado el ' + fecha + '  •  Total: ' + _bodegasData.length + ' bodega(s)</Data></Cell></Row>' +
        '<Row ss:Height="8"><Cell><Data ss:Type="String"></Data></Cell></Row>' +
        '<Row ss:Height="26">' + hdrCells + '</Row>' +
        bodyRows +
        '</Table></Worksheet></Workbook>';

      const blob = new Blob([xml], { type: 'application/vnd.ms-excel' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url; a.download = 'bodegas.xls'; a.click();
      URL.revokeObjectURL(url);
    }

    function abrirModalImportarCSVBodegas() {
      document.getElementById('modalImportarCSVBodegas').style.display = 'flex';
      lucide.createIcons();
    }
    function cerrarModalImportarCSVBodegas() {
      document.getElementById('modalImportarCSVBodegas').style.display = 'none';
      document.getElementById('formImportarCSVBodegas').reset();
      document.getElementById('csvBodegasResult').style.display = 'none';
    }

    document.addEventListener('DOMContentLoaded', function() {
      const formCSV = document.getElementById('formImportarCSVBodegas');
      if (formCSV) {
        formCSV.addEventListener('submit', async function(e) {
          e.preventDefault();
          const formData = new FormData(this);
          const btn = this.querySelector('button[type=submit]');
          btn.disabled = true; btn.textContent = 'Importando...';
          try {
            const response = await fetch('/configuracion/direcciones/importar-csv', { method: 'POST', body: formData });
            const result = await response.json();
            const resultDiv = document.getElementById('csvBodegasResult');
            resultDiv.style.display = 'block';
            if (result.success && result.imported > 0) {
              resultDiv.style.background = '#dcfce7'; resultDiv.style.color = '#166534';
              resultDiv.textContent = '✅ ' + result.imported + ' bodega(s) importada(s)' + (result.errores > 0 ? ' — ' + result.errores + ' filas con error' : '');
              setTimeout(function() { cerrarModalImportarCSVBodegas(); location.reload(); }, 1800);
            } else if (result.success && result.imported === 0) {
              resultDiv.style.background = '#fef9c3'; resultDiv.style.color = '#854d0e';
              const hint = result.separador ? ' (separador: "' + result.separador + '", ' + result.totalLineas + ' filas)' : '';
              resultDiv.textContent = '⚠️ No se importó ninguna fila' + hint + '. Verifica que el archivo use , o ; y tenga: alias, calle, colonia, ciudad, estado, cp';
            } else {
              resultDiv.style.background = '#fee2e2'; resultDiv.style.color = '#991b1b';
              resultDiv.textContent = '❌ ' + (result.error || 'Error al importar');
            }
          } catch (err) {
            console.error(err); alert('Error al importar CSV');
          } finally {
            btn.disabled = false; btn.textContent = 'Importar';
          }
        });
      }

      const modalCSV = document.getElementById('modalImportarCSVBodegas');
      if (modalCSV) {
        modalCSV.addEventListener('click', function(e) { if (e.target === this) cerrarModalImportarCSVBodegas(); });
      }
    });
  </script>

  <!-- Modal Importar CSV Bodegas -->
  <div id="modalImportarCSVBodegas" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; padding:32px; width:480px; max-width:95vw; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h3 style="margin:0; font-size:1.2rem; font-weight:700; color:#1f2937; display:flex; align-items:center; gap:8px;">
          <i data-lucide="upload" style="width:20px;height:20px;color:#ec4899;"></i>
          Importar Bodegas desde CSV
        </h3>
        <button onclick="cerrarModalImportarCSVBodegas()" style="background:none;border:none;cursor:pointer;color:#6b7280;padding:4px;">
          <i data-lucide="x" style="width:20px;height:20px;"></i>
        </button>
      </div>
      <p style="color:#6b7280; font-size:0.875rem; margin-bottom:16px; line-height:1.5;">
        El archivo CSV debe tener las columnas:<br>
        <code style="background:#f3f4f6; padding:2px 6px; border-radius:4px; font-size:0.8rem;">alias, calle, colonia, ciudad, estado, cp, referencia</code>
      </p>
      <a href="data:text/csv;charset=utf-8,%EF%BB%BFalias%2Ccalle%2Ccolonia%2Cciudad%2Cestado%2Ccp%2Creferencia%0ABodega+Norte%2CAv+Industrial+50%2CParque+Industrial%2CMonterrey%2CNuevo+Le%C3%B3n%2C64000%2CPuerta+lateral" download="plantilla_bodegas.csv" style="display:inline-flex; align-items:center; gap:6px; font-size:0.8rem; color:#3b82f6; text-decoration:none; margin-bottom:20px; font-weight:600;">
        <i data-lucide="download" style="width:14px;height:14px;"></i> Descargar plantilla
      </a>
      <form id="formImportarCSVBodegas" enctype="multipart/form-data">
        <div style="margin-bottom:16px;">
          <label style="display:block; font-weight:600; color:#374151; margin-bottom:6px; font-size:0.875rem;">Archivo CSV</label>
          <input type="file" name="csv_file" accept=".csv,.txt" required style="width:100%; padding:10px; border:2px solid #e5e7eb; border-radius:8px; font-size:0.875rem; cursor:pointer;">
        </div>
        <div id="csvBodegasResult" style="display:none; padding:10px 14px; border-radius:8px; margin-bottom:12px; font-weight:600; font-size:0.875rem;"></div>
        <div style="display:flex; gap:10px; justify-content:flex-end;">
          <button type="button" onclick="cerrarModalImportarCSVBodegas()" style="padding:10px 20px; background:#f3f4f6; color:#374151; border:none; border-radius:8px; font-weight:600; cursor:pointer;">Cancelar</button>
          <button type="submit" style="padding:10px 20px; background:linear-gradient(135deg,#ec4899 0%,#db2777 100%); color:white; border:none; border-radius:8px; font-weight:700; cursor:pointer;">Importar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Print view para bodegas (solo visible al imprimir) -->
  <div id="print-bodegas" style="display:none;">
    <div style="font-family: 'Inter', Arial, sans-serif; padding: 0; color: #1f2937;">
      <!-- Header -->
      <div style="background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%); color: white; padding: 28px 36px; border-radius: 12px 12px 0 0;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
          <div>
            <div style="font-size: 0.72rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; opacity: 0.7; margin-bottom: 6px;">Reporte de Ubicaciones</div>
            <div style="font-size: 1.6rem; font-weight: 800; margin: 0 0 4px 0; line-height: 1.1;">Direcciones de Origen</div>
            <div style="font-size: 1rem; font-weight: 400; opacity: 0.85;">Bodegas y Puntos de Envío</div>
          </div>
          <div style="text-align: right; font-size: 0.8rem; opacity: 0.8; padding-top: 4px;">
            <div style="margin-bottom: 2px;">Fecha de generación</div>
            <div style="font-weight: 700; font-size: 0.9rem;"><%= new Date().toLocaleDateString('es-MX', {day:'2-digit', month:'long', year:'numeric'}) %></div>
            <div style="margin-top: 8px; font-size: 0.72rem; opacity: 0.7;"><%= direccionesEmpresa ? direccionesEmpresa.length : 0 %> bodega(s) registrada(s)</div>
          </div>
        </div>
      </div>
      <!-- Tabla -->
      <table style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr>
            <th style="padding: 11px 16px; background: #1e40af; color: white; text-align: left; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; border-right: 1px solid #2563eb;">Alias / Nombre</th>
            <th style="padding: 11px 16px; background: #1e40af; color: white; text-align: left; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; border-right: 1px solid #2563eb;">Calle y Colonia</th>
            <th style="padding: 11px 16px; background: #1e40af; color: white; text-align: left; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; border-right: 1px solid #2563eb;">Ciudad · Estado · CP</th>
            <th style="padding: 11px 16px; background: #1e40af; color: white; text-align: left; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase;">Referencia</th>
          </tr>
        </thead>
        <tbody>
          <% if (direccionesEmpresa && direccionesEmpresa.length > 0) { %>
            <% direccionesEmpresa.forEach(function(dir, i) { %>
              <tr style="background: <%= i % 2 === 0 ? '#ffffff' : '#f0f9ff' %>; border-bottom: 1px solid #e5e7eb;">
                <td style="padding: 12px 16px; font-size: 0.875rem; font-weight: 700; color: #1e3a8a; border-right: 1px solid #f3f4f6; vertical-align: top;">
                  <%= dir.alias %>
                  <% if (dir.es_predeterminada) { %>
                    <span style="display: inline-block; margin-left: 6px; padding: 1px 7px; background: #fef3c7; color: #92400e; border-radius: 4px; font-size: 0.65rem; font-weight: 700;">★ PRINCIPAL</span>
                  <% } %>
                </td>
                <td style="padding: 12px 16px; font-size: 0.82rem; color: #374151; border-right: 1px solid #f3f4f6; vertical-align: top;"><%= dir.calle %>, <%= dir.colonia %></td>
                <td style="padding: 12px 16px; font-size: 0.82rem; color: #374151; border-right: 1px solid #f3f4f6; vertical-align: top;"><%= dir.ciudad %>, <%= dir.estado %> &nbsp;<span style="font-weight:600;">CP <%= dir.cp %></span></td>
                <td style="padding: 12px 16px; font-size: 0.78rem; color: #6b7280; font-style: <%= dir.referencia ? 'normal' : 'italic' %>; vertical-align: top;"><%= dir.referencia || '—' %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="4" style="padding: 32px; text-align: center; color: #9ca3af; font-size: 0.875rem;">No hay bodegas registradas</td></tr>
          <% } %>
        </tbody>
      </table>
      <!-- Footer -->
      <div style="background: #f8fafc; border: 1px solid #e5e7eb; border-top: 3px solid #1e40af; padding: 12px 24px; display: flex; justify-content: space-between; align-items: center; border-radius: 0 0 12px 12px;">
        <span style="font-size: 0.72rem; color: #9ca3af;">Total: <%= direccionesEmpresa ? direccionesEmpresa.length : 0 %> bodega(s)</span>
        <span style="font-size: 0.72rem; color: #9ca3af;">Sistema de Tracking Logística</span>
      </div>
    </div>
  </div>

  <!-- Print CSS -->
  <style>
    @media print {
      body.imprimiendo-bodegas > * { display: none !important; }
      body.imprimiendo-bodegas #print-bodegas { display: block !important; }
      body.imprimiendo-bodegas { margin: 0; padding: 20px; background: white; }
      #print-bodegas * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
    }
  </style>
</body>
</html>