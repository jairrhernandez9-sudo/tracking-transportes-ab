                  style="margin: 0;">
                  <button type="submit"
                    style="padding: 8px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 8px; font-weight: 700; font-size: 0.88rem; cursor: pointer;">
                    <i data-lucide="trash-2" style="width:15px;height:15px;"></i>
