        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Mostrar Datos del Envío</div>
        <div class="switch-description">Mostrar peso y descripción del paquete</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_datos_envio_tracking" <%= config.tracking.mostrar_datos_envio_tracking ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Mostrar Historial Completo</div>
        <div class="switch-description">Mostrar todos los estados por los que pasó el envío</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_historial_completo_tracking" <%= config.tracking.mostrar_historial_completo_tracking ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <!-- FUNCIONALIDADES -->
        <div style="background: #d1fae5; border-left: 4px solid #10b981; padding: 16px 20px; border-radius: 8px; margin: 24px 0;">
        <strong style="color: #065f46; display: block; margin-bottom: 8px;">⚡ Funcionalidades</strong>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Mostrar Código QR</div>
        <div class="switch-description">Mostrar código QR para compartir el tracking</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_qr_tracking" <%= config.tracking.mostrar_qr_tracking ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Botón Exportar PDF</div>
        <div class="switch-description">Permitir descargar reporte en PDF</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_boton_pdf_tracking" <%= config.tracking.mostrar_boton_pdf_tracking ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Botón Compartir WhatsApp</div>
        <div class="switch-description">Permitir compartir el tracking por WhatsApp</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_boton_whatsapp_tracking" <%= config.tracking.mostrar_boton_whatsapp_tracking ? 'checked' : '' %>>
        <span class="slider"></span>
        </label>
        </div>
      
        <div class="switch-group">
        <div class="switch-label">
        <div class="switch-title">Botón Copiar Enlace</div>
        <div class="switch-description">Permitir copiar el enlace de tracking</div>
        </div>
        <label class="switch">
        <input type="checkbox" name="mostrar_boton_copiar_tracking" <%= config.tracking.mostrar_boton_copiar_tracking ? 'checked' : '' %>>
        <span class="slider"></span>
