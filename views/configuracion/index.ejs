                           onmouseover="if('<%= paginaInicio %>'!=='<%= op.valor %>'){this.style.borderColor='#93c5fd';this.style.background='#f8fafc'}"
                           onmouseout="if('<%= paginaInicio %>'!=='<%= op.valor %>'){this.style.borderColor='#e2e8f0';this.style.background='#fff'}">
