<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Portal de Seguimiento</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(160deg, #eef2ff 0%, #f8fafc 50%, #f0f7ff 100%);
      min-height: 100vh;
      color: #0f172a;
    }

    /* ══ HEADER ══════════════════════════════════════════════════════ */
    .portal-header {
      background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 55%, #2563eb 100%);
      padding: 0 32px;
      display: flex; align-items: center; justify-content: space-between;
      height: 68px;
      box-shadow: 0 4px 30px rgba(30, 58, 138, 0.4);
      position: sticky; top: 0; z-index: 100;
      overflow: hidden;
    }
    .portal-header::before {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
      background-size: 18px 18px;
      pointer-events: none;
    }
    .portal-header::after {
      content: '';
      position: absolute; top: -60px; right: -60px;
      width: 220px; height: 220px;
      background: radial-gradient(circle, rgba(255,255,255,.07) 0%, transparent 65%);
      pointer-events: none;
    }

    .portal-brand { display: flex; align-items: center; gap: 12px; position: relative; z-index: 1; }
    .portal-logo-wrap {
      background: rgba(255,255,255,0.95);
      border-radius: 10px;
      padding: 5px 8px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .portal-logo-img {
      height: 34px; max-width: 120px; object-fit: contain;
    }
    .portal-logo-fallback {
      width: 42px; height: 42px;
      background: rgba(255,255,255,0.12);
      backdrop-filter: blur(8px);
      border: 1.5px solid rgba(255,255,255,0.2);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .portal-brand-info { display: flex; flex-direction: column; gap: 1px; }
    .portal-brand-name { color: #fff; font-size: 16px; font-weight: 800; letter-spacing: -.2px; }
    .portal-brand-sub  {
      color: rgba(255,255,255,0.5); font-size: 10.5px; font-weight: 600;
      text-transform: uppercase; letter-spacing: .8px;
    }

    /* Separador y logo del cliente */
    .brand-separator {
      width: 1px; height: 36px;
      background: rgba(255,255,255,0.25);
      flex-shrink: 0; margin: 0 4px;
    }
    .cliente-logo-area { display: flex; align-items: center; gap: 8px; position: relative; }
    .cliente-logo-wrap {
      background: rgba(255,255,255,0.95);
      border-radius: 10px; padding: 4px 7px;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .cliente-logo-img { height: 30px; max-width: 100px; object-fit: contain; }
    .btn-logo-upload {
      width: 24px; height: 24px; border-radius: 50%;
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.3);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all .2s; flex-shrink: 0;
    }
    .btn-logo-upload:hover { background: rgba(255,255,255,0.3); }
    .btn-logo-upload-empty {
      display: flex; align-items: center; gap: 6px;
      padding: 5px 10px;
      background: rgba(255,255,255,0.1);
      border: 1px dashed rgba(255,255,255,0.3);
      border-radius: 8px; cursor: pointer; transition: all .2s;
      color: rgba(255,255,255,0.6); font-size: 11px; font-weight: 600;
    }
    .btn-logo-upload-empty:hover { background: rgba(255,255,255,0.2); color: #fff; }

    .portal-user-area { display: flex; align-items: center; gap: 10px; position: relative; z-index: 1; }
    .portal-user-info { text-align: right; }
    .portal-user-name    { color: #f1f5f9; font-size: 13px; font-weight: 700; }
    .portal-user-sucursal {
      color: rgba(255,255,255,0.55); font-size: 10.5px; font-weight: 600;
      display: flex; align-items: center; gap: 4px; justify-content: flex-end;
    }
    .portal-avatar {
      width: 38px; height: 38px; border-radius: 10px;
      background: rgba(255,255,255,0.15);
      border: 1.5px solid rgba(255,255,255,0.25);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 900; font-size: 15px; flex-shrink: 0;
    }
    .btn-logout {
      display: flex; align-items: center; gap: 6px;
      padding: 8px 14px;
      background: rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.75);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 10px; font-size: 12px; font-weight: 600;
      text-decoration: none; transition: all .2s;
    }
    .btn-logout:hover {
      background: rgba(255,255,255,0.18); color: #fff;
      border-color: rgba(255,255,255,0.3);
    }

    /* ══ MAIN ═════════════════════════════════════════════════════════ */
    .portal-main { max-width: 1220px; margin: 0 auto; padding: 36px 24px 60px; }

    /* ══ WELCOME HERO ═════════════════════════════════════════════════ */
    .welcome-hero {
      background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
      border-radius: 22px;
      padding: 30px 36px;
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 24px;
      box-shadow: 0 12px 40px rgba(37, 99, 235, 0.28);
      position: relative; overflow: hidden;
    }
    .welcome-hero::before {
      content: '';
      position: absolute; top: -50px; right: -50px;
      width: 250px; height: 250px;
      background: radial-gradient(circle, rgba(255,255,255,.12) 0%, transparent 65%);
      pointer-events: none;
    }
    .welcome-hero::after {
      content: '';
      position: absolute; bottom: -60px; left: 40%;
      width: 180px; height: 180px;
      background: radial-gradient(circle, rgba(255,255,255,.06) 0%, transparent 65%);
      pointer-events: none;
    }
    .welcome-left { position: relative; z-index: 1; }
    .welcome-eyebrow {
      font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.55);
      text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;
    }
    .welcome-name {
      font-size: 28px; font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 6px;
    }
    .welcome-sub { font-size: 14px; color: rgba(255,255,255,0.65); }
    .welcome-chip {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.14);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.22);
      color: #fff; border-radius: 50px; padding: 10px 18px;
      font-size: 13px; font-weight: 700; position: relative; z-index: 1;
      white-space: nowrap;
    }

    /* ══ STATS ════════════════════════════════════════════════════════ */
    .stats-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
      margin-bottom: 24px;
    }
    .stat-card {
      background: #fff; border-radius: 18px; padding: 22px 20px;
      box-shadow: 0 2px 16px rgba(0,0,0,.05);
      display: flex; align-items: flex-start; gap: 14px;
      border: 1px solid rgba(0,0,0,.04);
      transition: transform .2s, box-shadow .2s;
      cursor: default;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,.1); }
    .stat-icon {
      width: 50px; height: 50px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .stat-icon.blue   { background: linear-gradient(135deg, #dbeafe, #eff6ff); }
    .stat-icon.slate  { background: linear-gradient(135deg, #f1f5f9, #f8fafc); }
    .stat-icon.orange { background: linear-gradient(135deg, #ffedd5, #fff7ed); }
    .stat-icon.green  { background: linear-gradient(135deg, #dcfce7, #f0fdf4); }
    .stat-body { flex: 1; }
    .stat-num {
      font-size: 36px; font-weight: 900; line-height: 1;
      letter-spacing: -1.5px; margin-bottom: 4px;
    }
    .stat-num.blue   { color: #1d4ed8; }
    .stat-num.slate  { color: #475569; }
    .stat-num.orange { color: #c2410c; }
    .stat-num.green  { color: #15803d; }
    .stat-label {
      font-size: 12px; font-weight: 600; color: #94a3b8;
      text-transform: uppercase; letter-spacing: .5px;
    }

    /* ══ TOOLBAR ══════════════════════════════════════════════════════ */
    .toolbar-card {
      background: #fff; border-radius: 16px; padding: 16px 20px;
      box-shadow: 0 2px 12px rgba(0,0,0,.04);
      margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      border: 1px solid rgba(0,0,0,.04);
    }
    .search-box { flex: 1; min-width: 200px; position: relative; }
    .search-box i {
      position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
      width: 16px; height: 16px; color: #94a3b8; pointer-events: none;
    }
    .search-box input {
      width: 100%; padding: 11px 14px 11px 38px;
      border: 1.5px solid #e2e8f0; border-radius: 10px;
      font-size: 13px; outline: none; transition: all .2s;
      font-family: inherit; background: #f8fafc; color: #0f172a;
    }
    .search-box input:focus { border-color: #3b82f6; background: #fff; box-shadow: 0 0 0 3px rgba(59,130,246,.1); }
    .filter-select {
      padding: 11px 14px; border: 1.5px solid #e2e8f0; border-radius: 10px;
      font-size: 13px; font-family: inherit; background: #f8fafc;
      cursor: pointer; outline: none; transition: all .2s; color: #374151;
    }
    .filter-select:focus { border-color: #3b82f6; }
    .dir-select-wrap { position: relative; min-width: 175px; }
    .dir-select-wrap select {
      appearance: none; width: 100%;
      padding: 11px 30px 11px 14px;
      border: 1.5px solid #e2e8f0; border-radius: 10px;
      font-size: 13px; font-family: inherit; background: #f8fafc;
      cursor: pointer; outline: none; transition: all .2s; color: #374151;
    }
    .dir-select-wrap select:focus { border-color: #3b82f6; }
    .dir-select-wrap::after {
      content: ''; position: absolute; right: 11px; top: 50%;
      transform: translateY(-50%);
      border: 5px solid transparent; border-top-color: #94a3b8; margin-top: 3px;
      pointer-events: none;
    }
    .btn-buscar {
      display: flex; align-items: center; gap: 7px;
      padding: 11px 22px;
      background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
      color: #fff; border: none; border-radius: 10px;
      font-size: 13px; font-weight: 700; cursor: pointer;
      transition: all .2s; white-space: nowrap;
      box-shadow: 0 4px 14px rgba(37,99,235,.3);
    }
    .btn-buscar:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(37,99,235,.4);
    }
    .btn-limpiar {
      display: flex; align-items: center; gap: 6px;
      padding: 11px 16px; background: #f1f5f9; color: #64748b;
      border: 1.5px solid #e2e8f0; border-radius: 10px;
      font-size: 13px; font-weight: 600; text-decoration: none;
      transition: all .15s;
    }
    .btn-limpiar:hover { background: #e2e8f0; color: #374151; }

    /* ══ DIR ACTIVE BANNER ════════════════════════════════════════════ */
    .dir-banner {
      display: flex; align-items: center; gap: 10px;
      background: #eff6ff; border: 1.5px solid #bfdbfe; border-radius: 12px;
      padding: 11px 16px; margin-bottom: 16px;
      font-size: 13px; color: #1d4ed8; font-weight: 600;
    }
    .dir-banner a {
      color: #94a3b8; text-decoration: none; margin-left: auto;
      display: flex; align-items: center; transition: color .15s;
    }
    .dir-banner a:hover { color: #ef4444; }

    /* ══ TABLE CARD ═══════════════════════════════════════════════════ */
    .table-card {
      background: #fff; border-radius: 18px;
      box-shadow: 0 2px 16px rgba(0,0,0,.05);
      overflow: hidden; border: 1px solid rgba(0,0,0,.04);
    }
    .table-top {
      padding: 18px 24px;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid #f1f5f9;
    }
    .table-top h2 { font-size: 15px; font-weight: 800; color: #0f172a; }
    .table-count {
      display: inline-flex; align-items: center; gap: 5px;
      background: #eff6ff; color: #1d4ed8;
      border-radius: 20px; padding: 4px 12px;
      font-size: 12px; font-weight: 700;
    }

    table { width: 100%; border-collapse: collapse; }
    thead tr { background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%); }
    thead th {
      padding: 13px 16px; text-align: left;
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .6px; color: rgba(255,255,255,0.8);
      white-space: nowrap;
    }
    tbody tr { border-bottom: 1px solid #f8fafc; transition: background .12s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #f0f7ff; }
    tbody td { padding: 14px 16px; font-size: 13px; color: #374151; vertical-align: middle; }

    .tracking-link {
      font-weight: 800; font-size: 13px; color: #2563eb;
      text-decoration: none; letter-spacing: .3px; font-family: 'Courier New', monospace;
    }
    .tracking-link:hover { color: #1e3a8a; text-decoration: underline; }

    /* Badges estado */
    .badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 20px;
      font-size: 11px; font-weight: 700; white-space: nowrap;
    }
    .badge i { width: 10px; height: 10px; }
    .badge-creado       { background: #f1f5f9; color: #475569; }
    .badge-pendiente    { background: #fef3c7; color: #92400e; }
    .badge-en-transito  { background: #fff7ed; color: #c2410c; }
    .badge-entregado    { background: #dcfce7; color: #15803d; }
    .badge-cancelado    { background: #fee2e2; color: #dc2626; }
    .badge-en-bodega    { background: #fef9c3; color: #854d0e; }
    .badge-retrasado    { background: #ffedd5; color: #c2410c; }

    .ref-cell { font-size: 12px; color: #64748b; }
    .no-ref   { color: #d1d5db; }
    .dest-cell { font-size: 12px; color: #374151; max-width: 180px; }
    .fecha-cell { font-size: 12px; color: #64748b; white-space: nowrap; }

    .badge-parte {
      display: inline-flex; align-items: center; gap: 3px;
      background: #fef3c7; color: #92400e; border: 1px solid #fcd34d;
      border-radius: 5px; padding: 1px 6px; font-size: 10px; font-weight: 700; margin-left: 4px;
    }
    .badge-parte.complemento { background: #f0fdf4; color: #166534; border-color: #86efac; }

    .btn-ver {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 7px 14px;
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      color: #fff; border: none; border-radius: 8px;
      font-size: 12px; font-weight: 700; cursor: pointer;
      text-decoration: none; transition: all .2s;
      box-shadow: 0 2px 8px rgba(59,130,246,.25);
    }
    .btn-ver:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(37,99,235,.35);
    }

    /* Empty state */
    .empty-state { padding: 80px 24px; text-align: center; }
    .empty-icon {
      width: 80px; height: 80px; background: #eff6ff; border-radius: 24px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px;
    }
    .empty-state h3 { font-size: 17px; font-weight: 800; color: #1e293b; margin-bottom: 8px; }
    .empty-state p  { font-size: 14px; color: #94a3b8; }

    /* Pagination */
    .pagination {
      display: flex; justify-content: center; align-items: center; gap: 6px;
      padding: 22px;
    }
    .page-btn {
      padding: 7px 14px; border: 1.5px solid #e2e8f0; border-radius: 8px;
      font-size: 13px; font-weight: 600; color: #374151; background: #fff;
      text-decoration: none; transition: all .15s;
    }
    .page-btn:hover { border-color: #3b82f6; color: #3b82f6; }
    .page-btn.active {
      background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
      color: #fff; border-color: transparent;
      box-shadow: 0 2px 10px rgba(37,99,235,.3);
    }
    .page-btn.disabled { opacity: .35; pointer-events: none; }

    /* ══ RESPONSIVE ═══════════════════════════════════════════════════ */
    @media (max-width: 1024px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .portal-header { padding: 0 16px; }
      .portal-main   { padding: 20px 16px 40px; }
      .welcome-hero  { padding: 22px 20px; flex-direction: column; align-items: flex-start; gap: 18px; }
      .welcome-name  { font-size: 22px; }
      .stats-grid    { grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .toolbar-card  { gap: 8px; }
      .table-card    { overflow-x: auto; }
    }
    @media (max-width: 640px) {
      .portal-user-info { display: none; }
      table thead { display: none; }
      tbody td { display: block; padding: 6px 16px; }
      tbody td::before {
        content: attr(data-label); font-weight: 700; color: #94a3b8;
        font-size: 10px; display: block; text-transform: uppercase; margin-bottom: 2px;
      }
    }
    @media (max-width: 640px) {
      .brand-separator, .cliente-logo-area { display: none; }
    }
    @media (max-width: 480px) {
      .portal-brand-sub { display: none; }
      .welcome-chip { font-size: 12px; padding: 8px 14px; }
    }
  </style>
</head>
<body>

<!-- ══ HEADER ══ -->
<header class="portal-header">
  <div class="portal-brand">
    <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
      <div class="portal-logo-wrap">
        <img src="<%= logoUrl %>" alt="Logo" class="portal-logo-img">
      </div>
    <% } else { %>
      <div class="portal-logo-fallback">
        <i data-lucide="truck" style="width:20px;height:20px;color:#fff;"></i>
      </div>
    <% } %>
    <%# Logo del cliente — a la derecha del logo empresa %>
    <div class="brand-separator"></div>
    <div class="cliente-logo-area">
      <% if (typeof clienteLogoUrl !== 'undefined' && clienteLogoUrl) { %>
        <div class="portal-logo-wrap">
          <img src="<%= clienteLogoUrl %>" alt="Logo cliente" class="cliente-logo-img">
        </div>
        <button type="button" class="btn-logo-upload" title="Cambiar logo" onclick="document.getElementById('logoFileInput').click()">
          <i data-lucide="camera" style="width:12px;height:12px;color:rgba(255,255,255,0.8);"></i>
        </button>
      <% } else { %>
        <button type="button" class="btn-logo-upload-empty" title="Subir logo de tu empresa" onclick="document.getElementById('logoFileInput').click()">
          <i data-lucide="image-plus" style="width:13px;height:13px;"></i>
          <span>Tu logo</span>
        </button>
      <% } %>
    </div>

    <div class="portal-brand-info">
      <div class="portal-brand-name"><%= cliente.nombre_empresa %></div>
      <div class="portal-brand-sub">Portal de Seguimiento</div>
    </div>
  </div>

  <%# Formulario oculto para subir logo %>
  <form id="formLogoCliente" action="/portal-cliente/logo" method="POST" enctype="multipart/form-data" style="display:none;">
    <input type="file" id="logoFileInput" name="logo" accept="image/*" onchange="this.form.submit()">
  </form>

  <div class="portal-user-area">
    <div class="portal-user-info">
      <div class="portal-user-name"><%= user.nombre %></div>
      <div class="portal-user-sucursal">
        <i data-lucide="<%= (typeof sucursalLabel !== 'undefined' && sucursalLabel !== 'Todos los envíos') ? 'map-pin' : 'globe' %>" style="width:10px;height:10px;"></i>
        <%= typeof sucursalLabel !== 'undefined' ? sucursalLabel : 'Todos los envíos' %>
      </div>
    </div>
    <div class="portal-avatar">
      <%= user.nombre ? user.nombre.charAt(0).toUpperCase() : 'C' %>
    </div>
    <a href="/auth/logout" class="btn-logout">
      <i data-lucide="log-out" style="width:14px;height:14px;"></i>
      <span>Salir</span>
    </a>
  </div>
</header>

<!-- ══ MAIN ══ -->
<main class="portal-main">

  <!-- Welcome Hero -->
  <div class="welcome-hero">
    <div class="welcome-left">
      <div class="welcome-eyebrow">Portal de seguimiento</div>
      <div class="welcome-name">¡Hola, <%= user.nombre %>!</div>
      <div class="welcome-sub">Consulta el estado de tus envíos en tiempo real</div>
    </div>
    <div class="welcome-chip">
      <i data-lucide="building-2" style="width:16px;height:16px;"></i>
      <%= cliente.nombre_empresa %>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon blue">
        <i data-lucide="package-2" style="width:24px;height:24px;color:#2563eb;"></i>
      </div>
      <div class="stat-body">
        <div class="stat-num blue"><%= stats.total || 0 %></div>
        <div class="stat-label">Total envíos</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon slate">
        <i data-lucide="clock" style="width:24px;height:24px;color:#64748b;"></i>
      </div>
      <div class="stat-body">
        <div class="stat-num slate"><%= stats.creados || 0 %></div>
        <div class="stat-label">Creados</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon orange">
        <i data-lucide="truck" style="width:24px;height:24px;color:#ea580c;"></i>
      </div>
      <div class="stat-body">
        <div class="stat-num orange"><%= stats.en_transito || 0 %></div>
        <div class="stat-label">En tránsito</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon green">
        <i data-lucide="circle-check-big" style="width:24px;height:24px;color:#16a34a;"></i>
      </div>
      <div class="stat-body">
        <div class="stat-num green"><%= stats.entregados || 0 %></div>
        <div class="stat-label">Entregados</div>
      </div>
    </div>
  </div>

  <% if (typeof portalDeshabilitado !== 'undefined' && portalDeshabilitado) { %>
  <div style="background:#fff; border-radius:16px; padding:60px 40px; text-align:center; box-shadow:0 2px 12px rgba(0,0,0,.06); margin:30px 0;">
    <div style="width:80px;height:80px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
      <i data-lucide="lock" style="width:36px;height:36px;color:#dc2626;"></i>
    </div>
    <h2 style="font-size:1.4rem;font-weight:800;color:#1f2937;margin-bottom:10px;">Portal no disponible</h2>
    <p style="color:#6b7280;font-size:0.95rem;max-width:400px;margin:0 auto;">Tu cuenta ha sido deshabilitada temporalmente. Contactanos para más información.</p>
  </div>
  <% } else { %>

  <!-- Toolbar de búsqueda -->
  <form method="GET" action="/portal-cliente" class="toolbar-card">
    <div class="search-box">
      <i data-lucide="search"></i>
      <input type="text" name="buscar" placeholder="Buscar por tracking o referencia..."
             value="<%= filtros.buscar %>">
    </div>

    <% if (direcciones && direcciones.length > 0) { %>
    <div class="dir-select-wrap">
      <select name="direccion_id" onchange="this.form.submit()">
        <option value="">Todas las direcciones</option>
        <% direcciones.forEach(dir => { %>
          <option value="<%= dir.id %>" <%= filtros.direccion_id == dir.id ? 'selected' : '' %>>
            <%= dir.alias %> — <%= dir.ciudad %>
          </option>
        <% }); %>
      </select>
    </div>
    <% } %>

    <select name="estado" class="filter-select">
      <option value="todos"       <%= filtros.estado === 'todos'       ? 'selected' : '' %>>Todos los estados</option>
      <option value="creado"      <%= filtros.estado === 'creado'      ? 'selected' : '' %>>Creado</option>
      <option value="en-transito" <%= filtros.estado === 'en-transito' ? 'selected' : '' %>>En tránsito</option>
      <option value="en-bodega"   <%= filtros.estado === 'en-bodega'   ? 'selected' : '' %>>En bodega</option>
      <option value="entregado"   <%= filtros.estado === 'entregado'   ? 'selected' : '' %>>Entregado</option>
      <option value="retrasado"   <%= filtros.estado === 'retrasado'   ? 'selected' : '' %>>Retrasado</option>
      <option value="cancelado"   <%= filtros.estado === 'cancelado'   ? 'selected' : '' %>>Cancelado</option>
    </select>

    <button type="submit" class="btn-buscar">
      <i data-lucide="search" style="width:14px;height:14px;"></i>
      Buscar
    </button>
    <% if (filtros.buscar || filtros.estado !== 'todos' || filtros.direccion_id) { %>
      <a href="/portal-cliente" class="btn-limpiar">
        <i data-lucide="x" style="width:13px;height:13px;"></i>
        Limpiar
      </a>
    <% } %>
  </form>

  <!-- Badge de dirección activa -->
  <% if (filtros.direccion_id && direcciones) {
       const dirActiva = direcciones.find(d => d.id == filtros.direccion_id);
       if (dirActiva) { %>
  <div class="dir-banner">
    <i data-lucide="map-pin" style="width:15px;height:15px;flex-shrink:0;"></i>
    Filtrando por: <strong><%= dirActiva.alias %></strong> — <%= dirActiva.calle %>, <%= dirActiva.ciudad %>
    <a href="/portal-cliente">
      <i data-lucide="x" style="width:16px;height:16px;"></i>
    </a>
  </div>
  <% } } %>

  <!-- Tabla de envíos -->
  <div class="table-card">
    <div class="table-top">
      <h2>Mis Envíos</h2>
      <span class="table-count">
        <i data-lucide="package" style="width:12px;height:12px;"></i>
        <%= envios.length %> resultado(s)
      </span>
    </div>

    <% if (envios.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <i data-lucide="package-search" style="width:36px;height:36px;color:#3b82f6;"></i>
        </div>
        <h3>No se encontraron envíos</h3>
        <p>Intenta con otros filtros de búsqueda o revisa más tarde</p>
      </div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Tracking</th>
          <th>Referencia</th>
          <th>Destino</th>
          <th>Estado</th>
          <th>Fecha</th>
          <th>Entrega est.</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% envios.forEach(envio => { %>
        <tr>
          <td data-label="Tracking">
            <a href="/portal-cliente/envio/<%= envio.id %>" class="tracking-link">
              <%= envio.numero_tracking %>
            </a>
            <% if (envio.es_parcial) { %>
              <span class="badge-parte">PARTE 1</span>
            <% } else if (envio.es_complemento) { %>
              <span class="badge-parte complemento">PARTE <%= envio.numero_parte || '?' %></span>
            <% } %>
          </td>
          <td data-label="Referencia">
            <% if (envio.referencia_cliente) { %>
              <span class="ref-cell"><%= envio.referencia_cliente %></span>
            <% } else { %>
              <span class="no-ref">—</span>
            <% } %>
          </td>
          <td data-label="Destino">
            <span class="dest-cell"><%= envio.destino || '—' %></span>
          </td>
          <td data-label="Estado">
            <span class="badge badge-<%= envio.estado_actual %>">
              <%= envio.estado_actual.replace(/-/g,' ').toUpperCase() %>
            </span>
          </td>
          <td data-label="Fecha" class="fecha-cell">
            <%= new Date(envio.fecha_creacion).toLocaleDateString('es-MX', {day:'2-digit', month:'short', year:'2-digit', timeZone:'America/Mexico_City'}) %>
          </td>
          <td data-label="Entrega est." class="fecha-cell">
            <% if (envio.fecha_estimada_entrega) { %>
              <%= new Date(envio.fecha_estimada_entrega).toLocaleDateString('es-MX', {day:'2-digit', month:'short', year:'2-digit', timeZone:'America/Mexico_City'}) %>
            <% } else { %>
              <span style="color:#d1d5db;">—</span>
            <% } %>
          </td>
          <td>
            <a href="/portal-cliente/envio/<%= envio.id %>" class="btn-ver">
              <i data-lucide="eye" style="width:13px;height:13px;"></i>
              Ver
            </a>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>

    <!-- Paginación -->
    <% if (paginacion.total > 1) { %>
    <div class="pagination">
      <a href="?page=<%= paginacion.actual - 1 %>&buscar=<%= filtros.buscar %>&estado=<%= filtros.estado %>"
         class="page-btn <%= paginacion.actual <= 1 ? 'disabled' : '' %>">← Anterior</a>
      <% for (let p = 1; p <= paginacion.total; p++) { %>
        <a href="?page=<%= p %>&buscar=<%= filtros.buscar %>&estado=<%= filtros.estado %>"
           class="page-btn <%= p === paginacion.actual ? 'active' : '' %>"><%= p %></a>
      <% } %>
      <a href="?page=<%= paginacion.actual + 1 %>&buscar=<%= filtros.buscar %>&estado=<%= filtros.estado %>"
         class="page-btn <%= paginacion.actual >= paginacion.total ? 'disabled' : '' %>">Siguiente →</a>
    </div>
    <% } %>
    <% } %>
  </div>

  <% } %><!-- fin else portalDeshabilitado -->

</main>

<script>
  lucide.createIcons();
</script>
</body>
</html>
