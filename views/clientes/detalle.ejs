                    </button>
                  <% } %>
                  
                  <button 
                    class="btn-editar-direccion-cliente"
                    data-id="<%= dir.id %>"
                    data-alias="<%= dir.alias %>"
                    data-calle="<%= dir.calle %>"
                    data-colonia="<%= dir.colonia %>"
                    data-ciudad="<%= dir.ciudad %>"
                    data-estado="<%= dir.estado %>"
                    data-cp="<%= dir.cp %>"
                    data-referencia="<%= dir.referencia || '' %>"
                    data-tipo="<%= dir.tipo || 'destino' %>"
                    data-predeterminada="<%= dir.es_predeterminada ? '1' : '0' %>"
                    style="padding: 6px 10px; background: #3b82f6; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 0.75rem; font-weight: 600; transition: all 0.3s;"
                  >
                    <i data-lucide="edit-2" style="width: 14px; height: 14px;"></i>
                  </button>
                  
                  <button 
                    class="btn-eliminar-direccion"
                    data-direccion-id="<%= dir.id %>"
                    style="padding: 6px 10px; background: #ef4444; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 0.75rem; font-weight: 600; transition: all 0.3s;"
                  >
                    <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i>
                  </button>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div style="background: #f9fafb; padding: 32px; border-radius: 10px; text-align: center; border: 2px dashed #d1d5db; margin-top: 16px;">
            <i data-lucide="map-pin" style="width: 48px; height: 48px; color: #9ca3af; margin: 0 auto 12px; display: block;"></i>
