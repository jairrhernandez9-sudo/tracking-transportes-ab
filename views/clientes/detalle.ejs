                        🏙️ <%= dir.ciudad %>, <%= dir.estado %>, <%= dir.cp %>
                      </p>
                      <% if (dir.referencia) { %>
                        <p style="margin: 4px 0 0 0; padding: 6px 10px; background: #f9fafb; border-radius: 6px; font-size: 0.8rem;">
